{
  "name": "xgis",
  "private": true,
  "version": "0.0.1",
  "type": "module",
  "workspaces": ["compiler", "blueprint", "runtime", "playground", "site"],
  "scripts": {
    "build": "bun run --filter '*' build",
    "test": "vitest run",
    "dev": "bun run --filter @xgis/playground dev",
