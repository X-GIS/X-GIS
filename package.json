    "dev:all": "bun run --filter @xgis/playground --filter @xgis/site dev"
  },
  "devDependencies": {
    "@types/node": "^25.6.0",
    "@webgpu/types": "^0.1.69",
    "typescript": "5.6.3",
    "vitest": "^3.0.0"
  },
  "dependencies": {
    "earcut": "^3.0.2",
    "monaco-editor": "^0.55.1"
  }
}
