{
  "$schema": "https://raw.githubusercontent.com/martinring/tmlanguage/master/tmlanguage.json",
  "name": "X-GIS",
  "scopeName": "source.xgis",
  "patterns": [
    { "include": "#comments" },
    { "include": "#strings" },
    { "include": "#colors" },
    { "include": "#numbers" },
    { "include": "#keywords" },
    { "include": "#functions" },
    { "include": "#utilities" },
    { "include": "#fields" },
    { "include": "#operators" },
    { "include": "#modifiers" }
  ],
  "repository": {
    "comments": {
      "patterns": [
        {
          "name": "comment.line.double-slash.xgis",
          "match": "//.*$"
        },
        {
          "name": "comment.block.xgis",
          "begin": "/\\*",
          "end": "\\*/"
        }
      ]
    },
    "strings": {
      "patterns": [{
        "name": "string.quoted.double.xgis",
        "begin": "\"",
        "end": "\"",
        "patterns": [{
          "name": "constant.character.escape.xgis",
          "match": "\\\\."
        }]
      }]
    },
    "colors": {
      "patterns": [{
        "name": "constant.other.color.xgis",
        "match": "#[0-9a-fA-F]{3,8}\\b"
      }]
    },
    "numbers": {
      "patterns": [{
        "name": "constant.numeric.xgis",
        "match": "\\b\\d+(\\.\\d+)?\\b"
      }]
    },
    "keywords": {
      "patterns": [
        {
          "name": "keyword.control.xgis",
          "match": "\\b(source|layer|preset|import|let|fn|if|else|for|in|return|match|symbol)\\b"
        },
        {
          "name": "keyword.other.xgis",
          "match": "\\b(type|url|visible|hidden)\\b"
        },
        {
          "name": "constant.language.xgis",
          "match": "\\b(true|false|geojson|raster)\\b"
        }
      ]
    },
    "functions": {
      "patterns": [{
        "name": "support.function.xgis",
        "match": "\\b(categorical|gradient|match|clamp|min|max|abs|sqrt|log|sin|cos|tan|floor|ceil|round|pow|step|smoothstep|mix)\\b"
      }]
    },
    "utilities": {
      "patterns": [
        {
          "name": "support.constant.color.xgis",
          "match": "\\b(fill|stroke|bg)-(slate|gray|zinc|neutral|stone|red|orange|amber|yellow|lime|green|emerald|teal|cyan|sky|blue|indigo|violet|purple|fuchsia|pink|rose|white|black)(-\\d+)?\\b"
        },
        {
          "name": "support.constant.property.xgis",
          "match": "\\b(opacity|stroke|size|z-order)-\\d+\\b"
        },
        {
          "name": "keyword.other.utility.xgis",
          "match": "\\bapply-[a-zA-Z_][a-zA-Z0-9_]*\\b"
        }
      ]
    },
    "fields": {
      "patterns": [{
        "name": "variable.other.field.xgis",
        "match": "\\.[a-zA-Z_][a-zA-Z0-9_]*\\b"
      }]
    },
    "operators": {
      "patterns": [
        {
          "name": "keyword.operator.pipe.xgis",
          "match": "\\|"
        },
        {
          "name": "keyword.operator.arrow.xgis",
          "match": "->"
        },
        {
          "name": "keyword.operator.wildcard.xgis",
          "match": "\\b_\\b"
        },
        {
          "name": "keyword.operator.comparison.xgis",
          "match": "(==|!=|<=|>=|<|>|&&|\\|\\|)"
        }
      ]
    },
    "modifiers": {
      "patterns": [{
        "name": "keyword.other.modifier.xgis",
        "match": "\\bz\\d+:"
      }]
    }
  }
}
