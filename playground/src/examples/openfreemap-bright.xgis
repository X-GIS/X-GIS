}

layer railway_transit {
  source: openmaptiles
  sourceLayer: "transportation"
  filter: (.class == "transit") && (.brunnel != "tunnel")
  | stroke-#bababac4 z14:stroke-0.4 z20:stroke-1
}

layer railway_transit_hatching {
  source: openmaptiles
  sourceLayer: "transportation"
  filter: (.class == "transit") && (.brunnel != "tunnel")
  | stroke-#bababaad z14.5:stroke-0 z15:stroke-2 z20:stroke-6 stroke-dasharray-0.2-8
}

layer railway_service {
  source: openmaptiles
  sourceLayer: "transportation"
  filter: (.class == "rail") && (.service != null)
  | stroke-#bababac4 z14:stroke-0.4 z20:stroke-1
}

layer railway_service_hatching {
  source: openmaptiles
  sourceLayer: "transportation"
  filter: (.class == "rail") && (.service != null)
  | stroke-#bababaad z14.5:stroke-0 z15:stroke-2 z20:stroke-6 stroke-dasharray-0.2-8
}

layer railway {
  source: openmaptiles
  sourceLayer: "transportation"
  filter: (!(.service != null)) && (.brunnel != "bridge" && .brunnel != "tunnel") && (.class == "rail")
  | stroke-#bbb z14:stroke-0.4 z15:stroke-0.75 z20:stroke-2
}

layer railway_hatching {
  source: openmaptiles
  sourceLayer: "transportation"
  filter: (!(.service != null)) && (.brunnel != "bridge" && .brunnel != "tunnel") && (.class == "rail")
