layer cablecar_dash {
  source: openmaptiles
  sourceLayer: "transportation"
  minzoom: 13
  filter: .subclass == "cable_car"
  | stroke-#b3b3b3 z11:stroke-3 z19:stroke-5.5 stroke-dasharray-2-3
}

layer boundary_3 {
  source: openmaptiles
  sourceLayer: "boundary"
  minzoom: 5
  filter: (.admin_level >= 3) && (.admin_level <= 6) && (.maritime != 1) && (.disputed != 1) && (!(.claimed_by != null))
  | stroke-#b3b3b3 z7:stroke-1 z11:stroke-2 stroke-dasharray-1-1
}

layer boundary_2 {
  source: openmaptiles
  sourceLayer: "boundary"
  filter: (.admin_level == 2) && (.maritime != 1) && (.disputed != 1) && (!(.claimed_by != null))
  | stroke-#a4a2ae z3:stroke-1 z5:stroke-1.2 z12:stroke-3 z0:opacity-40 z4:opacity-100
}

layer boundary_disputed {
  source: openmaptiles
  sourceLayer: "boundary"
  filter: (.maritime != 1) && (.disputed == 1)
  | stroke-#a4a2ae z3:stroke-1 z5:stroke-1.2 z12:stroke-3 stroke-dasharray-1-2
}

