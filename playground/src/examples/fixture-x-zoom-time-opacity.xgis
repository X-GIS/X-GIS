/* Interaction fixture: zoom-opacity AND time-opacity composed.
 * The classifier must compose them multiplicatively. */
keyframes pulse {
  0%:   opacity-100
  50%:  opacity-50
  100%: opacity-100
}
source sq { type: geojson, url: "fixture-square.geojson" }
layer dual {
  source: sq
  | fill-emerald-500
  | opacity-[interpolate(zoom, 0, 80, 20, 80)]
  | animation-pulse animation-duration-1200 animation-infinite
}
