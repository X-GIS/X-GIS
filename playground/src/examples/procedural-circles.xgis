/* Data-driven SDF circles: radius from population data */

source land {
  type: geojson
  url: "ne_110m_land.geojson"
}

source cities {
  type: geojson
  url: "ne_110m_populated_places.geojson"
}

/* Dark land base */
layer ground {
  source: land
  | fill-slate-800 stroke-slate-700 stroke-0.5
}

/* Population circles — per-feature radius from sqrt(pop_max) */
layer population {
  source: cities
  | fill-rose-500 opacity-50 stroke-rose-300 stroke-1
  | size-[sqrt(.pop_max) / 80] flat
}
