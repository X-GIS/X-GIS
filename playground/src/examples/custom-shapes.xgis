/* Custom shapes — built-in SDF shapes via GPU storage buffer */

source land {
  type: geojson
  url: "ne_110m_land.geojson"
}

source cities {
  type: geojson
  url: "ne_110m_populated_places.geojson"
}

/* Dark land base */
layer ground {
  source: land
  | fill-slate-800 stroke-slate-700 stroke-0.5
}

/* Cities as stars */
layer markers {
  source: cities
  | shape-star fill-amber-400 stroke-amber-600 stroke-1 size-14
}
