/* Fixture: stroke pattern with anchor=end.
 * Pattern instance pinned at the line end — single dot at the
 * terminating vertex, contrast with anchor=start. */
symbol dot { path "M 0 -0.5 L 0.5 0 L 0 0.5 L -0.5 0 Z" }
source l { type: geojson, url: "fixture-line.geojson" }
layer anchored {
  source: l
  | stroke-amber-300 stroke-12
  | stroke-pattern-dot stroke-pattern-size-14px stroke-pattern-spacing-40px
  | stroke-pattern-anchor-end
}
