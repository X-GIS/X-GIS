---
const githubUrl = 'https://github.com/X-GIS/X-GIS'
const base = import.meta.env.BASE_URL.replace(/\/+$/, '')
const docsUrl = `${base}/docs`
const examplesUrl = `${base}/examples`
const convertUrl = `${base}/convert`
---

<section class="relative min-h-[100svh] flex items-center justify-center overflow-hidden pt-24 pb-16">
  <!-- Single subtle radial — the only "atmosphere" on the page. -->
  <div
    class="absolute inset-0 pointer-events-none"
    aria-hidden="true"
    style="background: radial-gradient(ellipse 80% 60% at 50% 30%, rgba(41, 151, 255, 0.10) 0%, rgba(41, 151, 255, 0) 60%);"
  ></div>

  <div class="relative w-full max-w-[1100px] mx-auto px-6 text-center">

    <p class="fade-up text-[13px] font-medium tracking-[-0.01em] text-accent mb-5"
       style="animation-delay: 100ms">
      Introducing X-GIS
    </p>

    <h1 class="fade-up font-sans font-medium text-fg leading-[0.96] tracking-[-0.045em]
               text-[52px] sm:text-[76px] lg:text-[96px] xl:text-[112px]"
        style="animation-delay: 240ms">
      A language for<br />
      <span class="bg-gradient-to-b from-fg to-fg-dim bg-clip-text text-transparent">cartography.</span>
    </h1>

    <p class="fade-up mt-7 mx-auto max-w-[620px] text-[18px] sm:text-[21px] leading-[1.4] text-fg-dim"
       style="animation-delay: 380ms">
      Declare what your map should look like.
      The compiler emits the WGSL shaders, buffer layouts, and projection math.
    </p>

    <div class="fade-up mt-10 flex flex-wrap items-center justify-center gap-4"
         style="animation-delay: 520ms">
      <a
        href={docsUrl}
        class="inline-flex items-center gap-2 px-6 h-11 rounded-full
               bg-accent hover:bg-accent-hover active:bg-accent-press
               text-white text-[15px] font-medium transition-colors"
      >
        Read the docs
        <svg viewBox="0 0 24 24" width="14" height="14" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round">
          <path d="M9 6l6 6-6 6"/>
        </svg>
      </a>
      <a
        href={examplesUrl}
        class="inline-flex items-center gap-2 px-6 h-11 rounded-full
               text-accent hover:text-accent-hover text-[15px] font-medium transition-colors"
      >
        View examples
        <svg viewBox="0 0 24 24" width="14" height="14" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round">
          <path d="M9 6l6 6-6 6"/>
        </svg>
      </a>
      <a
        href={convertUrl}
        class="inline-flex items-center gap-2 px-6 h-11 rounded-full
               text-fg-dim hover:text-fg text-[15px] font-medium transition-colors"
      >
        Convert from Mapbox
        <svg viewBox="0 0 24 24" width="14" height="14" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round">
          <path d="M9 6l6 6-6 6"/>
        </svg>
      </a>
    </div>

    <!-- Code (read-only) + the live map it renders. Not editable here —
         the playground is the surface for trying things. -->
    <div class="scale-fade mt-16 sm:mt-20 mx-auto max-w-[680px] text-left"
         style="animation-delay: 700ms">
      <div class="rounded-2xl bg-bg-card border border-line overflow-hidden">
        <pre class="m-0 px-7 py-7 font-mono text-[14px] sm:text-[15px] leading-[1.85] text-fg whitespace-pre overflow-x-auto"
><code><span class="kw">source</span> <span class="id">land</span> {`{`}
  <span class="kw">type</span><span class="pun">:</span> <span class="lit">geojson</span>
  <span class="kw">url</span><span class="pun">:</span> <span class="str">"data/land.xgvt"</span>
{`}`}

<span class="kw">layer</span> <span class="id">continents</span> {`{`}
  <span class="kw">source</span><span class="pun">:</span> <span class="id">land</span>
  <span class="pun">|</span> <span class="util">fill-zinc-200</span>
{`}`}</code></pre>

        <div class="border-t border-line"></div>

        <div class="relative bg-bg">
          <canvas
            id="hero-map"
            class="block w-full opacity-0 transition-opacity duration-700"
            style="height: 320px; touch-action: none;"
          ></canvas>
          <div
            id="hero-map-fallback"
            class="absolute inset-0 flex items-center justify-center text-fg-mute text-[13px] font-mono pointer-events-none"
          >
            Loading…
          </div>
        </div>
      </div>

      <p class="mt-5 text-center text-[12px] text-fg-mute">
        Want to tweak it? &nbsp;
        <a
          href={examplesUrl}
          class="text-accent hover:text-accent-hover transition-colors inline-flex items-center gap-1"
        >
          See more examples
          <svg viewBox="0 0 24 24" width="11" height="11" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round">
            <path d="M9 6l6 6-6 6"/>
          </svg>
        </a>
      </p>
    </div>

    <p class="fade-up mt-10 text-[12px] text-fg-mute font-mono"
       style="animation-delay: 900ms">
      WebGPU&nbsp; · &nbsp;Seven projections&nbsp; · &nbsp;MIT
    </p>
  </div>
</section>

<script>
  // The hero map mount is deferred until either (a) the canvas
  // intersects the viewport or (b) the user interacts with it. Eager
  // mount loaded ~397 KB of `@xgis/runtime` synchronously on first
  // paint and dominated the landing-page LCP. Lazy mount keeps the
  // landing route lightweight while the map still appears the moment
  // the user reaches it (typical scroll lag is fast enough that the
  // canvas is still visible by the time it lights up).
  type XGISMapType = import('@xgis/runtime').XGISMap

  const canvas = document.getElementById('hero-map') as HTMLCanvasElement | null
  const fallback = document.getElementById('hero-map-fallback')

  if (canvas) {
    let mountedMap: XGISMapType | null = null
    let mountStarted = false

    const startMount = async (): Promise<void> => {
      if (mountStarted) return
      mountStarted = true
      try {
        // Dynamic import — splits @xgis/runtime + @xgis/compiler out of
        // the landing-route bundle. Loaded only when the map needs to
        // render, not on every page view.
        const { XGISMap } = await import('@xgis/runtime')

        // Wheel-zoom fix: the runtime's controller passes WheelEvent
        // .clientX/Y straight into Camera.zoomAt which expects canvas-
        // local CSS pixels. For a centered hero canvas that puts the
        // focal point off by canvasLeft/Top pixels. Capture phase +
        // stopImmediatePropagation blocks the runtime's listener, then
        // we call zoomAt with corrected coords.
        canvas.addEventListener('wheel', (e) => {
          e.preventDefault()
          e.stopImmediatePropagation()
          if (!mountedMap) return
          const rect = canvas.getBoundingClientRect()
          const canvasX = e.clientX - rect.left
          const canvasY = e.clientY - rect.top
          const delta = -e.deltaY * (e.deltaMode === 1 ? 0.05 : 0.003)
          mountedMap.getCamera().zoomAt(
            Math.max(-1, Math.min(1, delta)),
            canvasX, canvasY,
            canvas.width, canvas.height,
          )
        }, { capture: true, passive: false })

        const baseUrl = window.location.pathname.endsWith('/')
          ? window.location.pathname
          : window.location.pathname.substring(0, window.location.pathname.lastIndexOf('/') + 1)

        // Use the precompiled .xgvt (Natural Earth 110m land) so the
        // hero bypasses the in-memory GeoJSON tiling path. The xgvt
        // path renders globally at any zoom without the parent-tile-
        // clip bug that the GeoJSON tiler hits at z<2.
        const source = `source land {
  type: geojson
  url: "data/land.xgvt"
}

layer continents {
  source: land
  | fill-zinc-200
}`

        mountedMap = new XGISMap(canvas)
        await mountedMap.run(source, baseUrl)
        // After run(), override the bounds-fit-picked camera with a
        // global-fit position. The xgvt source renders cleanly at any
        // zoom (unlike the in-memory GeoJSON tiler), so we just pick
        // a zoom that fits the full world width into the hero canvas.
        // Canvas is 678 css px wide; world @ z=1 is 512 px → zoom=1.4
        // gives 1.32 worlds visible (whole globe + a little wrap on
        // each side, which the world-copy enumeration handles).
        const c = mountedMap.getCamera()
        c.zoom = 1.4
        c.centerX = 0
        c.centerY = 0
        mountedMap.markCameraPositioned()
        mountedMap.invalidate()
        canvas.style.opacity = '1'
        if (fallback) fallback.style.display = 'none'
      } catch (err) {
        console.warn('[hero-map]', err)
        if (fallback) fallback.textContent = 'Map preview unavailable'
      }
    }

    // Trigger 1: viewport intersection. `rootMargin: 200px` starts the
    // mount slightly before the canvas scrolls into view so by the time
    // the user actually sees it, the runtime is already loading.
    if (typeof IntersectionObserver !== 'undefined') {
      const io = new IntersectionObserver((entries) => {
        for (const entry of entries) {
          if (entry.isIntersecting) {
            io.disconnect()
            startMount()
            break
          }
        }
      }, { rootMargin: '200px' })
      io.observe(canvas)
    } else {
      // Fallback: very old browsers without IO get an idle-callback
      // mount instead of "never".
      const idle = (window as { requestIdleCallback?: (cb: () => void) => void }).requestIdleCallback
        ?? ((cb: () => void) => setTimeout(cb, 1))
      idle(startMount)
    }

    // Trigger 2: any interaction shortcuts the IO wait — wheel/click
    // /keyboard means the user is engaging with the map area.
    const onInteract = (): void => {
      canvas.removeEventListener('pointerdown', onInteract)
      canvas.removeEventListener('focus', onInteract)
      startMount()
    }
    canvas.addEventListener('pointerdown', onInteract, { once: true, passive: true })
    canvas.addEventListener('focus', onInteract, { once: true })
  }
</script>

<style>
  /* Token coloring — same palette as before. */
  pre .kw   { color: #ff7ab2; }
  pre .id   { color: var(--color-fg); font-weight: 500; }
  pre .util { color: #a8c6fa; }
  pre .lit, pre .str { color: #d6c08a; }
  pre .pun  { color: var(--color-fg-faint); }
</style>
