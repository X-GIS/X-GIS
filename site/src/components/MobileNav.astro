---
// Mobile drawer trigger — the hamburger button that lives in the
// fixed header. The drawer itself is rendered separately by
// `MobileNavDrawer` (mounted at the body root via Base.astro) so
// the header's `backdrop-filter` doesn't trap the drawer's
// `position: fixed` to the header's bounding box.
//
// Wire-up is via element IDs (`mobile-nav-toggle` here,
// `mobile-nav-drawer` over there) — the drawer's script does the
// getElementById lookup.
---

<button
  type="button"
  id="mobile-nav-toggle"
  aria-label="Open menu"
  aria-expanded="false"
  aria-controls="mobile-nav-drawer"
  class="sm:hidden inline-flex items-center justify-center w-9 h-9 -mr-2 text-fg-dim hover:text-fg transition-colors"
>
  <svg viewBox="0 0 24 24" width="20" height="20" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
    <line x1="4" y1="7" x2="20" y2="7"/>
    <line x1="4" y1="13" x2="20" y2="13"/>
    <line x1="4" y1="19" x2="20" y2="19"/>
  </svg>
</button>
