---
const githubUrl = 'https://github.com/X-GIS/X-GIS'
const year = new Date().getFullYear()
const base = import.meta.env.BASE_URL.replace(/\/+$/, '')
const docsUrl = `${base}/docs`
const examplesUrl = `${base}/examples`
---

<footer class="border-t border-line">
  <div class="max-w-[1024px] mx-auto px-6 py-14 text-[13px] text-fg-mute">
    <div class="flex flex-col sm:flex-row sm:items-center gap-6 sm:gap-10">
      <p class="flex items-center gap-3">
        <span class="font-medium text-fg">X-GIS</span>
        <span class="text-fg-faint">·</span>
        <span>v0.0.1</span>
        <span class="text-fg-faint">·</span>
        <span>MIT License</span>
      </p>

      <nav class="flex flex-wrap items-center gap-x-7 gap-y-2 sm:ml-auto">
        <a href={docsUrl} class="hover:text-fg transition-colors">Docs</a>
        <a href={examplesUrl} class="hover:text-fg transition-colors">Examples</a>
        <a href={githubUrl} target="_blank" rel="noopener" class="hover:text-fg transition-colors">GitHub</a>
        <a href={`${githubUrl}/blob/main/SPEC.md`} target="_blank" rel="noopener" class="hover:text-fg transition-colors">Spec</a>
        <a href={`${githubUrl}/blob/main/ROADMAP.md`} target="_blank" rel="noopener" class="hover:text-fg transition-colors">Roadmap</a>
      </nav>
    </div>

    <p class="mt-10 text-fg-faint">
      Copyright © {year} X-GIS contributors. Built with Astro, Tailwind, and WebGPU.
    </p>
  </div>
</footer>
