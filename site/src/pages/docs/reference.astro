---
import Docs from '../../layouts/Docs.astro'
import { referenceSections, type ReferenceSection } from '../../content/reference-sections'

const base = import.meta.env.BASE_URL.replace(/\/+$/, '')
const playBase = import.meta.env.DEV
  ? 'https://localhost:3000/demo.html'
  : `${base}/play/demo.html`

const playUrl = (s: ReferenceSection) => {
  const q = `id=${s.demoId}${s.demoQuery ? `&${s.demoQuery}` : ''}`
  const hash = s.demoHash ? `#${s.demoHash}` : ''
  return `${playBase}?${q}${hash}`
}
---

<Docs
  current="reference"
  title="X-GIS — Language reference"
  description="The full .xgis language: sources, layers, utility classes, modifiers, filters, match expressions, background, presets, symbols, animation, projections, and the JavaScript runtime API."
>
  <header class="mb-12">
    <p class="text-[13px] font-medium text-accent mb-3 tracking-[-0.01em]">
      Reference
    </p>
    <h1 class="text-[36px] sm:text-[44px] lg:text-[52px] font-medium text-fg leading-[1.1] tracking-[-0.035em]">
      Language reference.
    </h1>
    <p class="mt-5 text-[16px] sm:text-[17px] leading-[1.6] text-fg-dim max-w-[680px]">
      Every snippet below is a real <code class="font-mono text-[15px] text-fg">.xgis</code> sample taken from the playground demos
      or compiler tests — copy any block and it parses + compiles as-is. Click <span class="font-mono text-[14px] text-fg">Try this →</span>
      next to a code block to launch the matching live demo.
    </p>
  </header>

  <article class="space-y-20">
    {referenceSections.map((s, i) => (
      <section id={s.id} class="scroll-mt-20">
        <p class="font-mono text-[12px] text-fg-mute uppercase tracking-wider mb-3">
          — {String(i + 1).padStart(2, '0')}
        </p>
        <h2 class="text-[26px] sm:text-[32px] font-medium text-fg leading-[1.15] tracking-[-0.02em] mb-4 pb-4 border-b border-line">
          {s.title}
        </h2>
        <p class="text-[15px] sm:text-[16px] leading-[1.65] text-fg-dim mb-6">
          {s.body}
        </p>
        {s.code && (
          <div class="rounded-2xl bg-bg-card border border-line overflow-hidden">
            <div class="flex items-center justify-between px-5 py-2.5 border-b border-line bg-bg-elev">
              <p class="font-mono text-[11px] text-fg-mute uppercase tracking-wider">
                {s.id}.xgis
              </p>
              {s.demoId && (
                <a
                  href={playUrl(s)}
                  class="inline-flex items-center gap-1.5 text-[12px] text-accent hover:text-accent-hover transition-colors"
                >
                  Try this
                  <svg viewBox="0 0 24 24" width="11" height="11" fill="none" stroke="currentColor" stroke-width="2.4" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                    <path d="M9 6l6 6-6 6"/>
                  </svg>
                </a>
              )}
            </div>
            <pre class="px-6 py-5 font-mono text-[13px] sm:text-[13.5px] leading-[1.7] text-fg overflow-x-auto whitespace-pre"><code>{s.code}</code></pre>
          </div>
        )}
      </section>
    ))}
  </article>
</Docs>
