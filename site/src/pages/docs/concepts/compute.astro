---
import Docs from '../../../layouts/Docs.astro'

interface Preset {
  id: string
  label: string
  blurb: string
  source: string
}

// Real xgis examples — each one round-trips through the actual
// compiler. Match the surface area in playground/src/examples/*.xgis
// so the user sees idioms that work in the live engine.
const presets: Preset[] = [
  {
    id: 'continent-match',
    label: 'continent-match',
    blurb: 'match() on a string property — lowers to a compute kernel',
    source: `source countries {
  type: geojson
  url: "ne_110m_countries.geojson"
}

layer continents {
  source: countries
  | fill match(.CONTINENT) {
      "Africa"        -> amber-600,
      "Asia"          -> rose-500,
      "Europe"        -> sky-500,
      "North America" -> emerald-500,
      "South America" -> lime-500,
      "Oceania"       -> violet-500,
      "Antarctica"    -> slate-300,
      _               -> gray-400
    }
    stroke-slate-700 stroke-0.5 opacity-90
}
`,
  },
  {
    id: 'osm-roads',
    label: 'osm-roads',
    blurb: 'Per-kind filter + tailwind paint — splits into six layers, merge-layers folds them',
    source: `source pm_world {
  type: pmtiles
  url: "/pmtiles-proxy/protomaps/v4.pmtiles"
}

layer roads_minor {
  source: pm_world
  sourceLayer: "roads"
  filter: .kind == "minor_road" || .kind == "service" || .kind == "path"
  | stroke-stone-400 stroke-0.5
}

layer roads_secondary {
  source: pm_world
  sourceLayer: "roads"
  filter: .kind == "secondary" || .kind == "tertiary"
  | stroke-yellow-200 stroke-1.5
}

layer roads_primary {
  source: pm_world
  sourceLayer: "roads"
  filter: .kind == "primary"
  | stroke-amber-300 stroke-2.5
}
`,
  },
  {
    id: 'zoom-interp',
    label: 'zoom interpolate',
    blurb: 'interpolate(zoom, …) — routes to the palette atlas, not compute',
    source: `source countries {
  type: geojson
  url: "ne_110m_countries.geojson"
}

layer ocean {
  source: countries
  | fill-[interpolate(zoom, 0, sky-200, 8, sky-500, 16, sky-700)]
    opacity-90
}
`,
  },
  {
    id: 'constant',
    label: 'constant fill',
    blurb: 'No deps — fills get inlined as WGSL literals',
    source: `source countries {
  type: geojson
  url: "ne_110m_countries.geojson"
}

layer all {
  source: countries
  | fill-emerald-500 stroke-emerald-700 stroke-1 opacity-90
}
`,
  },
  {
    id: 'large-match',
    label: 'large match (LUT)',
    blurb: 'At 16+ arms the kernel switches from an if-chain to a const-array LUT — O(1) lookup',
    source: `source roads {
  type: geojson
  url: "roads.geojson"
}

/* 18-arm match — exceeds MATCH_LUT_THRESHOLD (16), so compute-gen
 * emits \`const LUT: array<vec4<f32>, 18>\` + a single \`LUT[id]\`
 * read instead of an if-else chain. */
layer roads_by_kind {
  source: roads
  | fill match(.kind) {
      "highway"      -> orange-500,
      "trunk"        -> orange-400,
      "primary"      -> amber-400,
      "secondary"    -> yellow-300,
      "tertiary"     -> yellow-200,
      "residential"  -> stone-300,
      "service"      -> stone-200,
      "path"         -> stone-100,
      "track"        -> amber-200,
      "footway"      -> lime-200,
      "cycleway"     -> emerald-300,
      "bridleway"    -> emerald-200,
      "steps"        -> rose-200,
      "pedestrian"   -> violet-200,
      "living_street"-> indigo-200,
      "raceway"      -> red-500,
      "rail"         -> slate-500,
      "subway"       -> slate-400,
      _              -> gray-300
    }
}
`,
  },
]
const presetById = Object.fromEntries(presets.map(p => [p.id, p]))
const initialPreset = presets[0]
---

<Docs
  current="concepts/compute"
  title="X-GIS — Compute paint evaluation"
  description="Live compile-graph viewer. Type xgis source, watch the lexer / parser / IR / paint-routing / compute plan / WGSL kernel update in place."
>
  <header class="mb-10">
    <p class="text-[13px] font-medium text-accent mb-3 tracking-[-0.01em]">
      Concept · interactive
    </p>
    <h1 class="text-[36px] sm:text-[44px] lg:text-[52px] font-medium text-fg leading-[1.1] tracking-[-0.035em]">
      Compile graph — live.
    </h1>
    <p class="mt-5 text-[16px] sm:text-[17px] leading-[1.6] text-fg-dim max-w-[720px]">
      Type xgis on the left, the compiler runs in the browser, every
      stage on the right updates as you type — tokens, AST, IR Scene,
      optimised IR, paint-routing decisions, ComputePlanEntry list,
      and the actual WGSL the runtime would hand to WebGPU.
    </p>
  </header>

  <!-- Preset chips -->
  <div class="mb-3 flex flex-wrap gap-2 items-center">
    <span class="text-fg-mute text-[11px] uppercase tracking-wider mr-1">Preset</span>
    {presets.map(p => (
      <button type="button" data-preset-id={p.id}
              class:list={[
                'preset-chip px-3 py-1.5 rounded-md border text-[12px] transition-colors',
                p.id === initialPreset.id
                  ? 'border-accent bg-accent/15 text-accent'
                  : 'border-line bg-bg-elev text-fg-dim hover:border-accent hover:text-accent',
              ]}>
        {p.label}
      </button>
    ))}
  </div>
  <p id="preset-blurb" class="text-fg-mute text-[12px] mb-5">{initialPreset.blurb}</p>

  <!-- Editor + summary row -->
  <div class="grid grid-cols-1 lg:grid-cols-[minmax(0,1fr)_minmax(0,1.1fr)] gap-5 mb-8">
    <!-- Editor -->
    <div class="flex flex-col">
      <div class="flex items-center justify-between mb-2">
        <label for="xgis-src" class="text-fg-mute text-[11px] uppercase tracking-wider">xgis source</label>
        <span id="compile-status" class="text-[11px] text-fg-mute tabular-nums"></span>
      </div>
      <textarea id="xgis-src" spellcheck="false"
                class="flex-1 min-h-[420px] bg-bg-card border border-line rounded-md p-4 text-[12.5px] font-mono leading-[1.55] text-fg whitespace-pre focus:outline-none focus:border-accent resize-none">{initialPreset.source}</textarea>
    </div>

    <!-- Summary stats -->
    <div class="flex flex-col">
      <div class="flex items-center mb-2">
        <span class="text-fg-mute text-[11px] uppercase tracking-wider">Summary</span>
        <span id="err-badge" class="hidden ml-2 px-2 py-0.5 rounded-full bg-rose-500/15 text-rose-300 border border-rose-500/30 text-[10px]"></span>
      </div>
      <div class="grid grid-cols-2 gap-3 mb-3">
        <div class="border border-line rounded-md p-3 bg-bg-elev">
          <div class="text-fg-mute text-[10px] uppercase tracking-wider">Tokens</div>
          <div id="stat-tokens" class="text-fg text-[20px] font-medium tabular-nums">—</div>
        </div>
        <div class="border border-line rounded-md p-3 bg-bg-elev">
          <div class="text-fg-mute text-[10px] uppercase tracking-wider">Render nodes</div>
          <div id="stat-nodes" class="text-fg text-[20px] font-medium tabular-nums">—</div>
        </div>
        <div class="border border-line rounded-md p-3 bg-bg-elev">
          <div class="text-fg-mute text-[10px] uppercase tracking-wider">Optimised</div>
          <div id="stat-optimised" class="text-fg text-[20px] font-medium tabular-nums">—</div>
        </div>
        <div class="border border-line rounded-md p-3 bg-bg-elev">
          <div class="text-fg-mute text-[10px] uppercase tracking-wider">Compute entries</div>
          <div id="stat-entries" class="text-fg text-[20px] font-medium tabular-nums">—</div>
        </div>
      </div>

      <!-- Paint axis routing — horizontal bar -->
      <div class="border border-line rounded-md p-3 bg-bg-elev flex-1">
        <div class="text-fg-mute text-[10px] uppercase tracking-wider mb-2">Paint axis routing</div>
        <div id="route-bars" class="space-y-1.5"></div>
      </div>
    </div>
  </div>

  <!-- Stages — each <details> collapsible -->
  <div class="space-y-2">

    <details class="stage-card group" open>
      <summary class="stage-summary">
        <span class="stage-num">1</span>
        <span class="stage-title">Tokens</span>
        <span class="stage-sub">Lexer · <span id="badge-tokens">—</span> tokens</span>
        <span class="stage-arrow"></span>
      </summary>
      <div class="stage-body">
        <pre id="out-tokens" class="stage-pre"></pre>
      </div>
    </details>

    <details class="stage-card group">
      <summary class="stage-summary">
        <span class="stage-num">2</span>
        <span class="stage-title">AST</span>
        <span class="stage-sub">Parser · top-level statements: <span id="badge-ast">—</span></span>
        <span class="stage-arrow"></span>
      </summary>
      <div class="stage-body">
        <pre id="out-ast" class="stage-pre"></pre>
      </div>
    </details>

    <details class="stage-card group" open>
      <summary class="stage-summary">
        <span class="stage-num">3</span>
        <span class="stage-title">IR Scene</span>
        <span class="stage-sub">lower() · pre-optimisation · blueprint-style</span>
        <span class="stage-arrow"></span>
      </summary>
      <div class="stage-body">
        <div id="out-ir" class="ir-graph"></div>
        <details class="ir-raw-toggle">
          <summary>raw IR JSON</summary>
          <pre id="out-ir-json" class="stage-pre"></pre>
        </details>
      </div>
    </details>

    <details class="stage-card group" open>
      <summary class="stage-summary">
        <span class="stage-num">4</span>
        <span class="stage-title">Optimised IR</span>
        <span class="stage-sub">optimize() · merge-layers + fold-stops + fold-case + dead-layer-elim</span>
        <span class="stage-arrow"></span>
      </summary>
      <div class="stage-body">
        <div id="out-ir-opt" class="ir-graph"></div>
        <details class="ir-raw-toggle">
          <summary>raw optimised IR JSON</summary>
          <pre id="out-ir-opt-json" class="stage-pre"></pre>
        </details>
      </div>
    </details>

    <details class="stage-card group" open>
      <summary class="stage-summary">
        <span class="stage-num">5</span>
        <span class="stage-title">Paint routing</span>
        <span class="stage-sub">paint-routing · per axis classification</span>
        <span class="stage-arrow"></span>
      </summary>
      <div class="stage-body">
        <div id="out-routing" class="overflow-x-auto"></div>
      </div>
    </details>

    <details class="stage-card group" open>
      <summary class="stage-summary">
        <span class="stage-num">5b</span>
        <span class="stage-title">Palette atlas</span>
        <span class="stage-sub">collectPalette · <span id="badge-palette-colors">—</span> constants · <span id="badge-palette-gradients">—</span> gradients</span>
        <span class="stage-arrow"></span>
      </summary>
      <div class="stage-body">
        <div id="out-palette"></div>
      </div>
    </details>

    <details class="stage-card group" open>
      <summary class="stage-summary">
        <span class="stage-num">6</span>
        <span class="stage-title">Compute plan</span>
        <span class="stage-sub">planComputeKernels · <span id="badge-plan">—</span> entries, <span id="badge-unique">—</span> unique kernels</span>
        <span class="stage-arrow"></span>
      </summary>
      <div class="stage-body">
        <div id="out-plan" class="overflow-x-auto"></div>
      </div>
    </details>

    <details class="stage-card group" open>
      <summary class="stage-summary">
        <span class="stage-num">7</span>
        <span class="stage-title">Render-node WGSL</span>
        <span class="stage-sub">shader-gen · <span id="badge-render-shaders">—</span> variants · inline constants visible</span>
        <span class="stage-arrow"></span>
      </summary>
      <div class="stage-body">
        <div id="render-shader-tabs" class="flex flex-wrap gap-1 mb-2"></div>
        <pre id="out-render-shader" class="stage-pre"></pre>
      </div>
    </details>

    <details class="stage-card group" open>
      <summary class="stage-summary">
        <span class="stage-num">8</span>
        <span class="stage-title">Emitted compute kernels</span>
        <span class="stage-sub">compute-gen · kernel-by-kernel · data-driven only</span>
        <span class="stage-arrow"></span>
      </summary>
      <div class="stage-body">
        <div id="kernel-tabs" class="flex flex-wrap gap-1 mb-2"></div>
        <pre id="out-wgsl" class="stage-pre"></pre>
      </div>
    </details>

    <details class="stage-card group" open>
      <summary class="stage-summary">
        <span class="stage-num">9</span>
        <span class="stage-title">Live GPU timing</span>
        <span class="stage-sub">
          <span id="gpu-bench-status">measure runs in your browser via <code class="font-mono text-[11px]">timestamp-query</code></span>
        </span>
        <span class="stage-arrow"></span>
      </summary>
      <div class="stage-body">
        <div id="gpu-bench-unavailable" class="hidden text-fg-mute text-[12px] italic px-3 py-2">
          Live timing isn't available on this device — the WebGPU adapter doesn't
          advertise <code class="font-mono text-[11px]">timestamp-query</code>.
          The strategy badges above still tell you which path the runtime would
          take; numbers measured on a Chrome 121+ desktop are baked into the
          reference card below.
        </div>
        <div id="gpu-bench-panel" class="hidden">
          <div class="flex items-center gap-3 mb-3 flex-wrap">
            <label class="text-fg-mute text-[11px] uppercase tracking-wider">Synthetic features</label>
            <select id="gpu-bench-count" class="bg-bg border border-line rounded px-2 py-1 text-[12px] text-fg focus:outline-none focus:border-accent">
              <option value="256">256</option>
              <option value="1024">1024</option>
              <option value="4096" selected>4096</option>
              <option value="16384">16384</option>
              <option value="65536">65536</option>
            </select>
            <span class="text-fg-mute text-[11px]">×</span>
            <span id="gpu-bench-iter-info" class="text-fg-mute text-[11px]">200 dispatches</span>
            <button id="gpu-bench-run" type="button"
                    class="ml-auto px-3 py-1 bg-accent/15 border border-accent text-accent rounded text-[12px] hover:bg-accent/25 transition-colors">
              Re-measure
            </button>
          </div>
          <div id="gpu-bench-results" class="space-y-2"></div>
          <p class="text-fg-mute text-[10px] mt-3">
            Dispatches the actually-emitted kernel(s) above onto your GPU with
            uniform-random feature IDs, times the compute pass via timestamp
            queries, drops the warmup samples. Output buffers are discarded —
            nothing renders.
          </p>
        </div>
      </div>
    </details>

  </div>

  <!-- Reference card — kept compact, route definitions are the only
       static content that survived the rewrite. -->
  <section class="mt-12 pt-6 border-t border-line">
    <h2 class="text-[18px] font-medium text-fg mb-3">Routes — quick reference</h2>
    <div class="grid grid-cols-1 md:grid-cols-2 gap-3 text-[12px]">
      <div class="border border-line rounded-md p-3 bg-bg-elev">
        <span class="font-medium text-fg">InlineConstant</span>
        <span class="text-fg-mute"> · deps = ∅</span>
        <p class="mt-1 text-fg-dim">Folded to a WGSL literal at compile time. Zero per-frame cost.</p>
      </div>
      <div class="border border-line rounded-md p-3 bg-bg-elev">
        <span class="font-medium text-fg">PaletteZoom</span>
        <span class="text-fg-mute"> · deps ⊆ zoom</span>
        <p class="mt-1 text-fg-dim">Pre-baked gradient atlas. One <code class="font-mono text-[11px]">textureSampleLevel</code> per fragment.</p>
      </div>
      <div class="border border-line rounded-md p-3 bg-bg-elev border-l-[3px] border-l-accent">
        <span class="font-medium text-accent">ComputeFeature</span>
        <span class="text-fg-mute"> · deps include feature</span>
        <p class="mt-1 text-fg-dim">Per-feature compute kernel. Fragment shader reads from <code class="font-mono text-[11px]">compute_out[feat_id]</code>.</p>
      </div>
      <div class="border border-line rounded-md p-3 bg-bg-elev">
        <span class="font-medium text-fg">CpuUniform</span>
        <span class="text-fg-mute"> · time / conditional</span>
        <p class="mt-1 text-fg-dim">CPU resolves every frame, writes a uniform. Spec-complete but never the fast path.</p>
      </div>
    </div>

    <h2 class="text-[18px] font-medium text-fg mt-8 mb-3">Kernel lowering — strategies</h2>
    <p class="text-[13px] text-fg-dim mb-3 max-w-[820px]">
      Inside a ComputeFeature kernel, <code class="font-mono text-[12px] text-fg">compute-gen</code>
      picks the WGSL shape based on arm count. The threshold is
      <code class="font-mono text-[12px] text-fg">MATCH_LUT_THRESHOLD = 16</code>
      in <code class="font-mono text-[12px] text-fg">compiler/src/codegen/compute-gen.ts</code>.
    </p>
    <div class="grid grid-cols-1 md:grid-cols-2 gap-3 text-[12px]">
      <div class="border border-line rounded-md p-3 bg-bg-elev">
        <span class="strategy-tag strategy-ifchain">if-chain · O(N)</span>
        <span class="text-fg-mute ml-2">arms &lt; 16</span>
        <p class="mt-2 text-fg-dim">Sequential <code class="font-mono text-[11px]">if (id == K0)</code> / <code class="font-mono text-[11px]">else if</code> branches. Cheap for small arm sets — the WGSL compiler reduces them well + branch prediction matches per fragment.</p>
      </div>
      <div class="border border-line rounded-md p-3 bg-bg-elev">
        <span class="strategy-tag strategy-lut">LUT · O(1)</span>
        <span class="text-fg-mute ml-2">arms ≥ 16</span>
        <p class="mt-2 text-fg-dim">Const <code class="font-mono text-[11px]">array&lt;vec4&lt;f32&gt;, N&gt;</code> baked into the shader module. Single <code class="font-mono text-[11px]">LUT[id]</code> indexed read regardless of arm count. Demotiles' 428-country palette is the canonical fit.</p>
      </div>
    </div>
  </section>

  <style is:global>
    /* These rules style content injected via innerHTML from the live
       compile script (tok-* WGSL spans, route-tag / strategy-tag
       badges, bench rows, kernel tabs). Astro's default CSS scoping
       attaches a hash attribute to component-rendered DOM only —
       runtime-built nodes don't receive it, so the rules wouldn't
       reach them without `is:global`. The selectors are
       compute-page-specific (`tok-*` / `stage-*` / `route-*` etc.)
       so leakage to other pages is benign. */
    .stage-card {
      border: 1px solid var(--color-line, #1f2937);
      border-radius: 8px;
      background: var(--color-bg-elev, #0f1825);
      overflow: hidden;
    }
    .stage-card[open] {
      border-color: rgba(56, 189, 248, 0.35);
    }
    .stage-summary {
      display: flex;
      align-items: center;
      gap: 12px;
      padding: 10px 14px;
      cursor: pointer;
      list-style: none;
      user-select: none;
    }
    .stage-summary::-webkit-details-marker { display: none; }
    .stage-num {
      width: 22px; height: 22px;
      display: inline-flex;
      align-items: center; justify-content: center;
      border-radius: 11px;
      background: rgba(56, 189, 248, 0.12);
      color: #38bdf8;
      font: 600 11px/1 'DM Mono', monospace;
      flex-shrink: 0;
    }
    .stage-title {
      font-weight: 500;
      color: var(--color-fg, #c8d3e0);
      font-size: 13.5px;
    }
    .stage-sub {
      flex: 1;
      color: var(--color-fg-mute, #5a6a7e);
      font-size: 11.5px;
      font-family: 'DM Mono', monospace;
    }
    .stage-arrow {
      width: 8px; height: 8px;
      border-right: 1.5px solid #5a6a7e;
      border-bottom: 1.5px solid #5a6a7e;
      transform: rotate(45deg);
      transition: transform 0.15s;
    }
    .stage-card[open] .stage-arrow {
      transform: rotate(225deg);
    }
    .stage-body {
      padding: 0 14px 12px;
      border-top: 1px solid rgba(255, 255, 255, 0.04);
      padding-top: 12px;
    }
    .stage-pre {
      margin: 0;
      padding: 12px 14px;
      background: #0a1320;
      border: 1px solid #1f2937;
      border-radius: 6px;
      font-family: 'DM Mono', monospace;
      font-size: 11.5px;
      line-height: 1.55;
      color: #c8d3e0;
      overflow-x: auto;
      white-space: pre;
      max-height: 460px;
      overflow-y: auto;
    }

    /* Light syntax highlighting for emitted WGSL — same colour set the
       expressive-code default theme uses so the page reads consistent. */
    .tok-kw    { color: #c084fc; }
    .tok-type  { color: #38bdf8; }
    .tok-fn    { color: #fde68a; }
    .tok-num   { color: #fb923c; }
    .tok-str   { color: #86efac; }
    .tok-cmt   { color: #5a6a7e; font-style: italic; }
    .tok-attr  { color: #f9a8d4; }

    .kernel-tab {
      padding: 4px 10px;
      border-radius: 4px;
      border: 1px solid var(--color-line, #1f2937);
      background: var(--color-bg-card, #0a1320);
      color: var(--color-fg-mute, #5a6a7e);
      font: 500 11px/1.3 'DM Mono', monospace;
      cursor: pointer;
      transition: all 0.15s;
    }
    .kernel-tab:hover {
      color: var(--color-fg, #c8d3e0);
      border-color: rgba(56, 189, 248, 0.35);
    }
    .kernel-tab.active {
      color: #38bdf8;
      border-color: #38bdf8;
      background: rgba(56, 189, 248, 0.08);
    }

    .route-bar-row {
      display: flex;
      align-items: center;
      gap: 8px;
      font-family: 'DM Mono', monospace;
      font-size: 11px;
    }
    .route-bar-label {
      width: 130px;
      flex-shrink: 0;
      color: var(--color-fg-dim, #9ca3af);
    }
    .route-bar-track {
      flex: 1;
      height: 8px;
      background: rgba(255, 255, 255, 0.05);
      border-radius: 4px;
      overflow: hidden;
    }
    .route-bar-fill {
      height: 100%;
      border-radius: 4px;
      transition: width 0.18s ease;
    }
    .route-bar-count {
      width: 40px;
      text-align: right;
      color: var(--color-fg, #c8d3e0);
      tabular-nums: tabular-nums;
    }

    /* ── Blueprint-style IR scene graph ── */
    .ir-graph { display: flex; flex-direction: column; gap: 14px; }
    .ir-section-label {
      font: 500 10px/1 'DM Mono', monospace;
      letter-spacing: 0.06em;
      text-transform: uppercase;
      color: var(--color-fg-mute, #5a6a7e);
      margin-bottom: 4px;
    }
    .ir-source-row {
      display: flex; flex-wrap: wrap; gap: 8px;
    }
    .ir-source-card {
      border: 1px solid rgba(56, 189, 248, 0.35);
