  <script define:vars={{ presetSources: Object.fromEntries(presets.map(p => [p.id, p.source])) }}>
    // Pulls the preset map into the module-scope `presetSources` so the
    // chip click handler doesn't have to re-fetch.
    window.__xgisComputePresets = presetSources
  </script>

  <script>
    // Live compile graph. Runs the actual compiler stages — Lexer →
    // Parser → lower → optimize → emitCommands — on every keystroke
    // (debounced). Each stage gets its own card; the WGSL output is
    // tokenised + colourised here in the browser so users don't need
    // an external highlight library.
    import { Lexer, Parser, lower, optimize, emitCommands } from '@xgis/compiler'
    import { TokenType } from '../../../../../compiler/src/lexer/tokens'
    import { routeColorValue, routePropertyShape } from '../../../../../compiler/src/codegen/paint-routing'
    import { collectPalette } from '../../../../../compiler/src/codegen/palette'

    const presetSources = (window as unknown as { __xgisComputePresets: Record<string, string> }).__xgisComputePresets

    const $src = document.getElementById('xgis-src') as HTMLTextAreaElement
    const $status = document.getElementById('compile-status') as HTMLElement
    const $errBadge = document.getElementById('err-badge') as HTMLElement
    const $blurb = document.getElementById('preset-blurb') as HTMLElement
    const $statTokens = document.getElementById('stat-tokens') as HTMLElement
    const $statNodes = document.getElementById('stat-nodes') as HTMLElement
    const $statOptimised = document.getElementById('stat-optimised') as HTMLElement
    const $statEntries = document.getElementById('stat-entries') as HTMLElement
    const $routeBars = document.getElementById('route-bars') as HTMLElement
    const $badgeTokens = document.getElementById('badge-tokens') as HTMLElement
    const $badgeAst = document.getElementById('badge-ast') as HTMLElement
    const $badgePlan = document.getElementById('badge-plan') as HTMLElement
    const $badgeUnique = document.getElementById('badge-unique') as HTMLElement
    const $outTokens = document.getElementById('out-tokens') as HTMLElement
    const $outAst = document.getElementById('out-ast') as HTMLElement
    const $outIr = document.getElementById('out-ir') as HTMLElement
    const $outIrOpt = document.getElementById('out-ir-opt') as HTMLElement
    const $outIrJson = document.getElementById('out-ir-json') as HTMLElement
    const $outIrOptJson = document.getElementById('out-ir-opt-json') as HTMLElement
    const $outRouting = document.getElementById('out-routing') as HTMLElement
    const $outPlan = document.getElementById('out-plan') as HTMLElement
    const $outWgsl = document.getElementById('out-wgsl') as HTMLElement
    const $kernelTabs = document.getElementById('kernel-tabs') as HTMLElement
    const $outRenderShader = document.getElementById('out-render-shader') as HTMLElement
    const $renderShaderTabs = document.getElementById('render-shader-tabs') as HTMLElement
    const $badgeRenderShaders = document.getElementById('badge-render-shaders') as HTMLElement

    function setError(msg: string) {
      $errBadge.textContent = msg
      $errBadge.classList.remove('hidden')
    }
    function clearError() {
      $errBadge.classList.add('hidden')
      $errBadge.textContent = ''
    }

    // Pretty-print JSON with a stable key order so the user can diff
    // by eye across edits. Drops verbose / circular-ish fields (e.g.
    // shaderVariant.preamble — multi-kilobyte) so the IR view stays
    // skimmable. Replacer preserves arrays + numbers + strings.
    const HIDE_FIELDS = new Set([
      'preamble', 'fillExpr', 'strokeExpr', 'shaderVariant',
      'paintShapes', 'classification',
    ])
    function pretty(obj: unknown, maxDepth = 6): string {
      const seen = new WeakSet<object>()
      function walk(v: unknown, depth: number): unknown {
        if (depth > maxDepth) return '…'
        if (v === null || typeof v !== 'object') return v
        if (seen.has(v as object)) return '«cycle»'
        seen.add(v as object)
        if (Array.isArray(v)) return v.map(item => walk(item, depth + 1))
        const out: Record<string, unknown> = {}
        for (const k of Object.keys(v as object)) {
          if (HIDE_FIELDS.has(k)) continue
          out[k] = walk((v as Record<string, unknown>)[k], depth + 1)
        }
        return out
      }
      return JSON.stringify(walk(obj, 0), null, 2)
    }

    // ── Token-type label table (for pretty token output) ──
    // Build at module init by scanning the runtime enum so the labels
    // stay in lockstep with the lexer definitions.
    const tokenLabels: Record<number, string> = {}
    for (const k of Object.keys(TokenType)) {
      const v = (TokenType as Record<string, unknown>)[k]
      if (typeof v === 'number') tokenLabels[v] = k
    }

    function escapeHtml(s: string): string {
      return s
        .replace(/&/g, '&amp;')
        .replace(/</g, '&lt;')
        .replace(/>/g, '&gt;')
    }

    function renderTokens(tokens: Array<{ type: number; value: string; line: number; col: number }>): string {
      const lines: string[] = []
      let lastLine = 0
      for (const tok of tokens) {
        if (tok.line !== lastLine) {
          if (lines.length > 0) lines.push('')
          lines.push(`<span class="tok-cmt">L${tok.line.toString().padStart(3, ' ')}</span>`)
          lastLine = tok.line
        }
        const label = tokenLabels[tok.type] ?? String(tok.type)
        const val = tok.value.length > 0 && tok.value !== label
          ? ` <span class="tok-str">${escapeHtml(JSON.stringify(tok.value))}</span>`
          : ''
        lines.push(`  <span class="tok-kw">${label.padEnd(14)}</span>${val}`)
      }
      return lines.join('\n')
    }

    // ── WGSL syntax highlighter ──
    // Single-regex tokeniser that picks up everything compute-gen emits:
    // comments, attributes (`@compute`, `@group`, …), numbers with WGSL
    // suffixes (`18u`, `0.5f`), identifiers, operators. Order matters —
    // comments first, then attributes (otherwise the `@` would peel off
    // and the rest become a bare identifier).
    const WGSL_KW = new Set([
      'fn', 'var', 'let', 'const', 'if', 'else', 'return',
      'struct', 'storage', 'read', 'read_write', 'uniform', 'array',
      'for', 'while', 'break', 'continue', 'switch', 'case', 'default',
      'true', 'false',
    ])
    const WGSL_TY = new Set([
      'f32', 'i32', 'u32', 'bool', 'f16',
      'vec2', 'vec3', 'vec4',
      'mat2x2', 'mat3x3', 'mat4x4',
      'atomic', 'ptr',
    ])
    const WGSL_BUILTIN = new Set([
      // Functions compute-gen actually emits + a useful superset for
      // hand-written examples (textureSampleLevel etc.).
      'pack4x8unorm', 'unpack4x8unorm',
      'floor', 'ceil', 'round', 'fract', 'sign', 'abs',
      'min', 'max', 'clamp', 'mix', 'step', 'smoothstep',
      'sin', 'cos', 'tan', 'pow', 'sqrt', 'log', 'log2', 'exp', 'exp2',
      'textureSampleLevel', 'textureSample', 'textureLoad', 'textureDimensions',
      'select', 'dot', 'cross', 'normalize', 'length', 'distance',
      'atomicAdd', 'atomicLoad', 'atomicStore',
    ])
    // Master tokenizer regex. Each alternative is anchored so it
    // consumes maximum length first (longest-match wins).
    //   1. //… line comment
    //   2. /* … */ block comment (compute-gen doesn't emit these but
    //      hand-edited examples might).
    //   3. @ident attribute
    //   4. number with optional decimal, exponent, type suffix (uifh)
    //   5. identifier (letters, digits, underscore)
    //   6. anything else (single char operator/punctuation)
    const WGSL_TOKEN = /\/\/[^\n]*|\/\*[\s\S]*?\*\/|@[A-Za-z_][\w]*|[0-9]+\.[0-9]*(?:[eE][+-]?[0-9]+)?[fhiu]?|\.[0-9]+(?:[eE][+-]?[0-9]+)?[fhiu]?|[0-9]+(?:[eE][+-]?[0-9]+)?[fhiu]?|[A-Za-z_][\w]*|\s+|[^A-Za-z0-9_\s]/g
    function highlightWgsl(src: string): string {
      const out: string[] = []
      for (const m of src.matchAll(WGSL_TOKEN)) {
        const t = m[0]
        if (!t) continue
        if (t.startsWith('//') || t.startsWith('/*'))
          out.push(`<span class="tok-cmt">${escapeHtml(t)}</span>`)
        else if (t.startsWith('@'))
          out.push(`<span class="tok-attr">${escapeHtml(t)}</span>`)
        else if (/^[0-9]|^\.[0-9]/.test(t))
          out.push(`<span class="tok-num">${escapeHtml(t)}</span>`)
        else if (WGSL_KW.has(t))
          out.push(`<span class="tok-kw">${escapeHtml(t)}</span>`)
        else if (WGSL_TY.has(t))
          out.push(`<span class="tok-type">${escapeHtml(t)}</span>`)
        else if (WGSL_BUILTIN.has(t))
          out.push(`<span class="tok-fn">${escapeHtml(t)}</span>`)
        else
          out.push(escapeHtml(t))
      }
      return out.join('')
    }

    // ── IR scene → blueprint-style node graph ──
    // Replaces the JSON pretty-print with a card layout: sources at
    // the top (cyan), render nodes below (indigo). Each render node
    // shows its filter + paint axes with route classification baked
    // in, so the user reads "which paint expression is data-driven /
    // zoom-interpolated / constant" without diffing JSON.
    function compactExpr(e: unknown, depth = 0): string {
      if (e === null || e === undefined) return '—'
      if (typeof e === 'string') return JSON.stringify(e)
      if (typeof e === 'number' || typeof e === 'boolean') return String(e)
      if (Array.isArray(e)) {
        if (depth > 2) return '[…]'
        return '[' + e.map(x => compactExpr(x, depth + 1)).join(', ') + ']'
      }
      const o = e as Record<string, unknown>
      if (typeof o.kind === 'string') {
        // AST-ish node — compact "Kind(arg1, arg2)" form
        if (o.kind === 'StringLiteral') return JSON.stringify(o.value)
        if (o.kind === 'NumberLiteral') return String(o.value)
        if (o.kind === 'Identifier') return String(o.name ?? o.value ?? '?')
        if (o.kind === 'GetProperty') return `.${o.field ?? '?'}`
        if (o.kind === 'Call' && typeof o.callee === 'object' && o.callee) {
          const callee = (o.callee as Record<string, unknown>).name
            ?? (o.callee as Record<string, unknown>).value
            ?? '?'
          const args = Array.isArray(o.args) ? o.args.map(a => compactExpr(a, depth + 1)).join(', ') : ''
          return `${callee}(${args})`
        }
        if (depth > 2) return `${o.kind}(…)`
        const summary = Object.keys(o).filter(k => k !== 'kind').slice(0, 3).map(k =>
          `${k}=${compactExpr(o[k], depth + 1)}`,
        ).join(' ')
        return `${o.kind}(${summary})`
      }
      if (depth > 2) return '{…}'
      const keys = Object.keys(o).slice(0, 4)
      return '{' + keys.map(k => `${k}: ${compactExpr(o[k], depth + 1)}`).join(', ') + '}'
    }

    interface ColorRouteLike { kind: string }
    interface IrSceneLike {
      sources: ReadonlyArray<{ name?: string; type?: string; url?: string; sourceLayer?: string }>
      renderNodes: ReadonlyArray<{
        name?: string
        sourceRef?: string
        sourceLayer?: string
        filter?: unknown
        fill?: { kind: string; rgba?: number[]; value?: unknown; expr?: { ast?: unknown } }
        stroke?: {
          color?: { kind: string; rgba?: number[]; value?: unknown; expr?: { ast?: unknown } }
          width?: unknown
        }
        opacity?: unknown
        label?: { text?: unknown }
      }>
    }

    function renderIrCards(target: HTMLElement, scene: IrSceneLike, palette: unknown): void {
      const lines: string[] = []
      // Sources strip — one row of cards.
      lines.push('<div class="ir-section-label">Sources</div>')
      lines.push('<div class="ir-source-row">')
      if (scene.sources.length === 0) {
        lines.push('<div class="ir-empty">No sources declared</div>')
      } else {
        for (const s of scene.sources) {
          const name = s.name ?? '<unnamed>'
          const type = s.type ?? '?'
          const url = s.url ?? ''
          lines.push(
            `<div class="ir-source-card">`
            + `<div class="ir-card-title">${escapeHtml(name)}</div>`
            + `<div class="ir-card-meta">${escapeHtml(type)}</div>`
            + (url ? `<div class="ir-card-url">${escapeHtml(url)}</div>` : '')
            + `</div>`,
          )
        }
      }
      lines.push('</div>')

      lines.push('<div class="ir-section-label">Render nodes</div>')
      if (scene.renderNodes.length === 0) {
        lines.push('<div class="ir-empty">No render nodes</div>')
      } else {
        lines.push('<div class="ir-node-list">')
        for (const node of scene.renderNodes) {
          const name = node.name || '<unnamed>'
          const src = node.sourceRef ?? '—'
          const sourceLayer = node.sourceLayer
          const axes: Array<{ axis: string; expr: string; route: string }> = []
          if (node.fill && node.fill.kind !== 'none') {
            const r = routeColorValue(node.fill as never, palette as never) as ColorRouteLike
            axes.push({ axis: 'fill', expr: describeRoute(node.fill, r), route: r.kind })
          }
          if (node.stroke?.color && node.stroke.color.kind !== 'none') {
            const r = routeColorValue(node.stroke.color as never, palette as never) as ColorRouteLike
            axes.push({ axis: 'stroke', expr: describeRoute(node.stroke.color, r), route: r.kind })
          }
          if (node.opacity) {
            const r = routePropertyShape(node.opacity as never, palette as never) as ColorRouteLike
            axes.push({ axis: 'opacity', expr: describeRoute(node.opacity, r), route: r.kind })
          }
          if (node.stroke?.width) {
            const r = routePropertyShape(node.stroke.width as never, palette as never) as ColorRouteLike
            axes.push({ axis: 'stroke-width', expr: describeRoute(node.stroke.width, r), route: r.kind })
          }
          if (node.label?.text !== undefined) {
            axes.push({ axis: 'label', expr: compactExpr(node.label.text), route: 'cpu-uniform' })
          }
          const filterStr = node.filter !== undefined ? compactExpr(node.filter) : ''
          lines.push(`<div class="ir-node-card">`)
          lines.push(`  <div class="ir-node-header">`)
          lines.push(`    <span class="ir-node-name">${escapeHtml(name)}</span>`)
          lines.push(`    <span class="ir-node-source">← ${escapeHtml(src)}${sourceLayer ? ` <span class="ir-node-sublayer">${escapeHtml(sourceLayer)}</span>` : ''}</span>`)
          lines.push(`  </div>`)
          if (filterStr) {
            lines.push(`  <div class="ir-node-filter"><span class="ir-meta-label">filter</span> <code>${escapeHtml(filterStr)}</code></div>`)
          }
          if (axes.length === 0) {
            lines.push(`  <div class="ir-node-noaxes">no paint axes</div>`)
          } else {
            lines.push(`  <div class="ir-node-axes">`)
            for (const a of axes) {
              lines.push(`    <div class="ir-axis-row">`)
              lines.push(`      <span class="ir-axis-name">${escapeHtml(a.axis)}</span>`)
              lines.push(`      <span class="route-tag ${a.route}">${routeLabel(a.route)}</span>`)
              lines.push(`      <span class="ir-axis-detail">${escapeHtml(a.expr)}</span>`)
              lines.push(`    </div>`)
            }
            lines.push(`  </div>`)
          }
          lines.push(`</div>`)
        }
        lines.push('</div>')
      }
      target.innerHTML = lines.join('\n')
    }

    // ── Palette atlas visualisation ──
    // The compiler's `collectPalette()` walks the optimised IR and
    // pulls every paint property whose deps are constant-or-zoom into
    // a centralised pool (4 arrays: colors / scalars / colorGradients
    // / scalarGradients). Runtime uploads each gradient as one row of
    // an Nx1 storage texture and the shader samples it via
    // `textureSampleLevel(palette, ...)` instead of CPU-resolving the
    // zoom interpolate every frame.
    //
    // Visualising the pool answers the user's "팔레트 줌이 실제로
    //쓰이는지" question directly: a non-empty colorGradients list
    // means the compiler routed at least one paint axis through the
    // palette atlas and the runtime is sampling textures (not
    // writing per-frame uniforms) for that paint. Each gradient is
    // rendered as a horizontal CSS strip so the colour ramp at each
    // zoom level is immediately readable.
    interface PaletteLike {
      colors: ReadonlyArray<readonly [number, number, number, number]>
      scalars: ReadonlyArray<number>
      colorGradients: ReadonlyArray<{
        stops: ReadonlyArray<{ zoom: number; value: readonly [number, number, number, number] }>
        base: number
      }>
      scalarGradients: ReadonlyArray<{
        stops: ReadonlyArray<{ zoom: number; value: number }>
        base: number
      }>
    }
    function rgbaToCss(rgba: readonly [number, number, number, number]): string {
      const r = Math.round(rgba[0] * 255)
      const g = Math.round(rgba[1] * 255)
      const b = Math.round(rgba[2] * 255)
      return `rgba(${r}, ${g}, ${b}, ${rgba[3].toFixed(2)})`
    }
    function rgbaToHex(rgba: readonly [number, number, number, number]): string {
      const hex = (n: number): string => Math.round(n * 255).toString(16).padStart(2, '0')
      return `#${hex(rgba[0])}${hex(rgba[1])}${hex(rgba[2])}`
    }
    function buildColorGradientCss(g: PaletteLike['colorGradients'][number]): string {
      // Map stop.zoom into 0..100% across the [minZoom, maxZoom] range
      if (g.stops.length === 0) return ''
      if (g.stops.length === 1) return rgbaToCss(g.stops[0]!.value)
      const minZ = g.stops[0]!.zoom
      const maxZ = g.stops[g.stops.length - 1]!.zoom
      const span = maxZ - minZ
      if (span <= 0) return rgbaToCss(g.stops[0]!.value)
      const stops = g.stops.map(s => {
        const pct = ((s.zoom - minZ) / span * 100).toFixed(2)
        return `${rgbaToCss(s.value)} ${pct}%`
      })
      return `linear-gradient(to right, ${stops.join(', ')})`
    }
    function buildScalarGradientCss(g: PaletteLike['scalarGradients'][number]): string {
      if (g.stops.length === 0) return ''
      // Normalise values to 0..1 and render as grayscale so the user
      // sees the shape of the interpolation rather than the absolute
      // magnitude (the label below shows min/max).
      const vals = g.stops.map(s => s.value)
      const vMin = Math.min(...vals)
      const vMax = Math.max(...vals)
      const vSpan = vMax - vMin || 1
      const minZ = g.stops[0]!.zoom
      const maxZ = g.stops[g.stops.length - 1]!.zoom
      const span = maxZ - minZ
      if (span <= 0) return `rgb(${Math.round((vals[0]! - vMin) / vSpan * 255)}, 0, 200)`
      const stops = g.stops.map(s => {
        const pct = ((s.zoom - minZ) / span * 100).toFixed(2)
        const gray = Math.round((s.value - vMin) / vSpan * 255)
        // Tint with indigo so it's visually distinct from RGB gradients
        return `rgb(${Math.round(gray * 0.4)}, ${Math.round(gray * 0.5)}, ${Math.round(gray * 0.9 + 30)}) ${pct}%`
      })
      return `linear-gradient(to right, ${stops.join(', ')})`
    }
    function renderPaletteAtlas(target: HTMLElement, palette: PaletteLike): void {
      const $badgeColors = document.getElementById('badge-palette-colors') as HTMLElement
      const $badgeGrads = document.getElementById('badge-palette-gradients') as HTMLElement
      const cConst = palette.colors.length
      const sConst = palette.scalars.length
      const cGrad = palette.colorGradients.length
      const sGrad = palette.scalarGradients.length
      $badgeColors.textContent = String(cConst + sConst)
      $badgeGrads.textContent = String(cGrad + sGrad)

      const lines: string[] = []
      if (cConst === 0 && sConst === 0 && cGrad === 0 && sGrad === 0) {
        lines.push('<div class="ir-empty">Palette is empty — no constant or zoom-interpolated paint axes in this scene.</div>')
        target.innerHTML = lines.join('\n')
        return
      }

      if (cConst > 0) {
        lines.push('<div class="palette-section-label">Constant colours</div>')
        lines.push('<div class="palette-color-swatches">')
        for (let i = 0; i < palette.colors.length; i++) {
          const c = palette.colors[i]!
          const css = rgbaToCss(c)
          const hex = rgbaToHex(c)
          lines.push(`<div class="palette-swatch" title="${hex}"><span class="palette-swatch-fill" style="background:${css}"></span><span class="palette-swatch-label">#${i} ${hex}</span></div>`)
        }
        lines.push('</div>')
      }

      if (sConst > 0) {
        lines.push('<div class="palette-section-label">Constant scalars</div>')
        lines.push('<div class="palette-scalar-row">')
        for (let i = 0; i < palette.scalars.length; i++) {
          lines.push(`<span class="palette-scalar-chip">#${i} ${palette.scalars[i]!.toFixed(3)}</span>`)
        }
        lines.push('</div>')
      }

      if (cGrad > 0) {
        lines.push('<div class="palette-section-label">Colour zoom gradients</div>')
        lines.push('<div class="palette-gradient-list">')
        for (let i = 0; i < palette.colorGradients.length; i++) {
          const g = palette.colorGradients[i]!
          const minZ = g.stops[0]?.zoom ?? 0
          const maxZ = g.stops[g.stops.length - 1]?.zoom ?? 0
          const css = buildColorGradientCss(g)
          const swatchTags = g.stops.map(s => `<span class="palette-stop" title="z=${s.zoom}: ${rgbaToHex(s.value)}"></span>`).join('')
          lines.push(`<div class="palette-gradient-row">`)
          lines.push(`  <span class="palette-grad-id">#${i}</span>`)
          lines.push(`  <span class="palette-grad-min">z${minZ.toFixed(1)}</span>`)
          lines.push(`  <div class="palette-grad-strip" style="background:${css}">${swatchTags}</div>`)
          lines.push(`  <span class="palette-grad-max">z${maxZ.toFixed(1)}</span>`)
          lines.push(`  <span class="palette-grad-base">base ${g.base === 1 ? 'linear' : g.base.toFixed(2)}</span>`)
          lines.push(`</div>`)
        }
        lines.push('</div>')
      }

      if (sGrad > 0) {
        lines.push('<div class="palette-section-label">Scalar zoom gradients</div>')
        lines.push('<div class="palette-gradient-list">')
        for (let i = 0; i < palette.scalarGradients.length; i++) {
          const g = palette.scalarGradients[i]!
          const minZ = g.stops[0]?.zoom ?? 0
          const maxZ = g.stops[g.stops.length - 1]?.zoom ?? 0
          const vals = g.stops.map(s => s.value)
          const vMin = Math.min(...vals).toFixed(2)
          const vMax = Math.max(...vals).toFixed(2)
          const css = buildScalarGradientCss(g)
          lines.push(`<div class="palette-gradient-row">`)
          lines.push(`  <span class="palette-grad-id">#${i}</span>`)
          lines.push(`  <span class="palette-grad-min">z${minZ.toFixed(1)} v${vMin}</span>`)
          lines.push(`  <div class="palette-grad-strip" style="background:${css}"></div>`)
          lines.push(`  <span class="palette-grad-max">z${maxZ.toFixed(1)} v${vMax}</span>`)
          lines.push(`  <span class="palette-grad-base">base ${g.base === 1 ? 'linear' : g.base.toFixed(2)}</span>`)
          lines.push(`</div>`)
        }
        lines.push('</div>')
      }

      target.innerHTML = lines.join('\n')
    }

    function renderRoutes(routes: Array<{ count: number; key: string; label: string; color: string }>): void {
      const total = routes.reduce((a, b) => a + b.count, 0) || 1
      $routeBars.innerHTML = ''
      for (const r of routes) {
        const pct = (r.count / total) * 100
        const row = document.createElement('div')
        row.className = 'route-bar-row'
        row.innerHTML = `
          <div class="route-bar-label">${r.label}</div>
          <div class="route-bar-track">
            <div class="route-bar-fill" style="width:${pct.toFixed(1)}%;background:${r.color}"></div>
          </div>
          <div class="route-bar-count">${r.count}</div>
        `
        $routeBars.appendChild(row)
      }
    }

    interface RoutingRow {
      nodeName: string
      axis: string
      route: string
      detail: string
    }
    function renderRoutingTable(rows: RoutingRow[]): void {
      if (rows.length === 0) {
        $outRouting.innerHTML = '<div class="text-fg-mute text-[12px] italic">No paint axes — empty scene?</div>'
        return
      }
      const html = ['<table class="routing-table"><thead><tr>']
      html.push('<th>Render node</th><th>Axis</th><th>Route</th><th>Detail</th>')
      html.push('</tr></thead><tbody>')
      for (const r of rows) {
        html.push(`<tr><td>${escapeHtml(r.nodeName)}</td>`)
        html.push(`<td>${escapeHtml(r.axis)}</td>`)
        html.push(`<td><span class="route-tag ${r.route}">${routeLabel(r.route)}</span></td>`)
        html.push(`<td>${escapeHtml(r.detail)}</td></tr>`)
      }
      html.push('</tbody></table>')
      $outRouting.innerHTML = html.join('')
    }
    function routeLabel(kind: string): string {
      return kind === 'inline-constant' ? 'InlineConstant'
           : kind === 'palette-zoom'    ? 'PaletteZoom'
           : kind === 'compute-feature' ? 'ComputeFeature'
           : kind === 'cpu-uniform'     ? 'CpuUniform'
           : kind
    }

    function describeRoute(value: any, route: any): string {
      if (route.kind === 'inline-constant') {
        if (value.kind === 'constant' && Array.isArray(value.rgba)) {
          const hex = '#' + value.rgba.slice(0, 3)
            .map((c: number) => Math.round(c * 255).toString(16).padStart(2, '0')).join('')
          return `constant ${hex}${value.rgba[3] < 1 ? ` @${(value.rgba[3] * 100).toFixed(0)}%` : ''}`
        }
        if (value.kind === 'constant') return `constant ${value.value}`
        return 'inlined'
      }
      if (route.kind === 'palette-zoom') {
        return `gradient #${route.gradientIndex} · zoom-interpolated`
      }
      if (route.kind === 'compute-feature') {
        return 'kernel dispatched per tile'
      }
      return value.kind ?? 'cpu eval'
    }

    interface PlanView {
      nodeName: string
      axis: string
      kernelName: string
      fingerprint: string
      fields: string[]
      armCount: number
      wgsl: string
      /** Which lowering strategy compute-gen picked. Derived from the
       *  emitted body — `const LUT: array<...>` decl means the LUT
       *  path fired; otherwise it's the if-else chain. The threshold
       *  is MATCH_LUT_THRESHOLD (=16) in compute-gen.ts. */
      strategy: 'if-chain' | 'lut' | 'ternary' | 'unknown'
    }

    function detectStrategy(wgsl: string, entryPoint: string): PlanView['strategy'] {
      if (/^const LUT:\s*array</m.test(wgsl)) return 'lut'
      if (entryPoint === 'eval_match' || entryPoint === 'eval_case') return 'if-chain'
      if (entryPoint?.startsWith('eval_ternary')) return 'ternary'
      return 'unknown'
    }
    function strategyLabel(s: PlanView['strategy']): string {
      return s === 'lut'      ? 'LUT · O(1)'
           : s === 'if-chain' ? 'if-chain · O(N)'
           : s === 'ternary'  ? 'ternary'
           : 'kernel'
    }
    function strategyClass(s: PlanView['strategy']): string {
      return s === 'lut'      ? 'strategy-lut'
           : s === 'if-chain' ? 'strategy-ifchain'
           : 'strategy-other'
    }
    function renderPlanTable(entries: PlanView[]): void {
      if (entries.length === 0) {
        $outPlan.innerHTML = '<div class="text-fg-mute text-[12px] italic">No data-driven paint axes — nothing routed to compute.</div>'
        $outWgsl.innerHTML = '<div style="color:#5a6a7e;font-style:italic">No WGSL — change the source to introduce a match() / data-driven expression.</div>'
        $kernelTabs.innerHTML = ''
        return
      }
      const html = ['<table class="routing-table"><thead><tr>']
      html.push('<th>Render node</th><th>Axis</th><th>Fields</th><th>Arms</th><th>Strategy</th><th>Kernel</th>')
      html.push('</tr></thead><tbody>')
      for (const e of entries) {
        html.push(`<tr><td>${escapeHtml(e.nodeName)}</td>`)
        html.push(`<td>${escapeHtml(e.axis)}</td>`)
        html.push(`<td>${escapeHtml(e.fields.join(', ') || '—')}</td>`)
        html.push(`<td>${e.armCount > 0 ? e.armCount : '—'}</td>`)
        html.push(`<td><span class="strategy-tag ${strategyClass(e.strategy)}">${strategyLabel(e.strategy)}</span></td>`)
        html.push(`<td>${escapeHtml(e.kernelName)}</td></tr>`)
      }
      html.push('</tbody></table>')
      $outPlan.innerHTML = html.join('')

      // Unique kernel tabs.
      const uniqByKey = new Map<string, PlanView>()
      for (const e of entries) if (!uniqByKey.has(e.fingerprint)) uniqByKey.set(e.fingerprint, e)
      $kernelTabs.innerHTML = ''
      let first = true
      let activeWgsl = ''
      uniqByKey.forEach((e, key) => {
        const btn = document.createElement('button')
        btn.type = 'button'
        btn.className = 'kernel-tab' + (first ? ' active' : '')
        btn.innerHTML = `${escapeHtml(e.kernelName)} · ${escapeHtml(e.fields.join(',') || '—')} · ${e.armCount} arm${e.armCount === 1 ? '' : 's'}`
          + ` <span class="strategy-tag inline ${strategyClass(e.strategy)}">${strategyLabel(e.strategy)}</span>`
        btn.addEventListener('click', () => {
          $kernelTabs.querySelectorAll('.kernel-tab').forEach(b => b.classList.remove('active'))
          btn.classList.add('active')
          $outWgsl.innerHTML = highlightWgsl(e.wgsl)
        })
        if (first) activeWgsl = e.wgsl
        first = false
        $kernelTabs.appendChild(btn)
      })
      $outWgsl.innerHTML = highlightWgsl(activeWgsl)
    }

    // ── Stage 7: per-render-node shader emit ──
    // Renders the WGSL preamble + fillExpr + strokeExpr of each
    // ShowCommand's shaderVariant. Unlike Stage 8 (compute kernels),
    // this includes EVERY render node — constant fills, zoom-
    // interpolated, and data-driven — so the user can see how the
    // compiler folded constants (e.g. `fill-#334155` becomes a
    // literal `vec4<f32>(0.20, 0.31, 0.33, 1.0)` in fillExpr) and
    // wired up palette atlas sampling vs compute-buffer reads.
    interface RenderShaderView {
      nodeName: string
      key: string
      preamble: string
      fillExpr: string
      strokeExpr: string
      fillPreamble: string
      strokePreamble: string
      paletteColorGradients: number[]
      needsFeatureBuffer: boolean
    }
    function assembleRenderShader(v: RenderShaderView): string {
      const out: string[] = []
      out.push(`// variant key: ${v.key}`)
      if (v.paletteColorGradients.length > 0) {
        out.push(`// palette colour gradients: [${v.paletteColorGradients.join(', ')}]`)
      }
      if (v.needsFeatureBuffer) {
        out.push(`// needs per-feature data buffer (data-driven paint)`)
      }
      out.push('')
      if (v.preamble.trim()) {
        out.push('// ── preamble ──')
        out.push(v.preamble.trim())
        out.push('')
      }
      out.push('// ── fillExpr ──')
      if (v.fillPreamble.trim()) {
        out.push(v.fillPreamble.trim())
      }
      out.push(`fn fill_color() -> vec4<f32> { return ${v.fillExpr}; }`)
      out.push('')
      out.push('// ── strokeExpr ──')
      if (v.strokePreamble.trim()) {
        out.push(v.strokePreamble.trim())
      }
      out.push(`fn stroke_color() -> vec4<f32> { return ${v.strokeExpr}; }`)
      return out.join('\n')
    }
    function renderRenderShaderTabs(views: RenderShaderView[]): void {
      $badgeRenderShaders.textContent = String(views.length)
      $renderShaderTabs.innerHTML = ''
      if (views.length === 0) {
        $outRenderShader.innerHTML = '<div style="color:#5a6a7e;font-style:italic">No render-node shaders emitted — empty scene?</div>'
        return
      }
      let first = true
      let activeWgsl = ''
      for (const v of views) {
        const btn = document.createElement('button')
        btn.type = 'button'
        btn.className = 'kernel-tab' + (first ? ' active' : '')
        btn.innerHTML = escapeHtml(v.nodeName)
        const wgsl = assembleRenderShader(v)
        btn.addEventListener('click', () => {
          $renderShaderTabs.querySelectorAll('.kernel-tab').forEach(b => b.classList.remove('active'))
          btn.classList.add('active')
          $outRenderShader.innerHTML = highlightWgsl(wgsl)
        })
        if (first) activeWgsl = wgsl
        first = false
        $renderShaderTabs.appendChild(btn)
      }
      $outRenderShader.innerHTML = highlightWgsl(activeWgsl)
    }

    function compile(src: string): void {
      const t0 = performance.now()
      try {
        clearError()
        const tokens = new Lexer(src).tokenize()
        const program = new Parser(tokens).parse()
        const sceneRaw = lower(program)
        const scene = optimize(sceneRaw, program)
        const palette = collectPalette(scene)

        // Stage 1 — tokens
        $statTokens.textContent = String(tokens.length)
        $badgeTokens.textContent = String(tokens.length)
        $outTokens.innerHTML = renderTokens(tokens)

        // Stage 2 — AST
        $badgeAst.textContent = String(program.body.length)
        $outAst.textContent = pretty(program, 8)

        // Stage 3 — raw IR (blueprint-style node cards + collapsed JSON)
        $statNodes.textContent = String(sceneRaw.renderNodes.length)
        renderIrCards($outIr, sceneRaw as unknown as IrSceneLike, palette)
        $outIrJson.textContent = pretty({
          sources: sceneRaw.sources,
          renderNodes: sceneRaw.renderNodes,
          symbols: sceneRaw.symbols,
        }, 8)

        // Stage 4 — optimised IR
        $statOptimised.textContent = String(scene.renderNodes.length)
        renderIrCards($outIrOpt, scene as unknown as IrSceneLike, palette)
        $outIrOptJson.textContent = pretty({
          sources: scene.sources,
          renderNodes: scene.renderNodes,
          symbols: scene.symbols,
        }, 8)

        // Stage 5 — paint routing per axis
        const routeCounts: Record<string, number> = {
          'inline-constant': 0, 'palette-zoom': 0,
          'compute-feature': 0, 'cpu-uniform': 0,
        }
        const routingRows: RoutingRow[] = []
        for (const node of scene.renderNodes) {
          const nodeName = node.name || `<unnamed ${routingRows.length}>`
          if (node.fill && node.fill.kind !== 'none') {
            const r = routeColorValue(node.fill, palette)
            routeCounts[r.kind] = (routeCounts[r.kind] ?? 0) + 1
            routingRows.push({ nodeName, axis: 'fill', route: r.kind, detail: describeRoute(node.fill, r) })
          }
          if (node.stroke?.color && node.stroke.color.kind !== 'none') {
            const r = routeColorValue(node.stroke.color, palette)
            routeCounts[r.kind] = (routeCounts[r.kind] ?? 0) + 1
            routingRows.push({ nodeName, axis: 'stroke', route: r.kind, detail: describeRoute(node.stroke.color, r) })
          }
          if (node.opacity) {
            const r = routePropertyShape(node.opacity, palette)
            routeCounts[r.kind] = (routeCounts[r.kind] ?? 0) + 1
            routingRows.push({ nodeName, axis: 'opacity', route: r.kind, detail: describeRoute(node.opacity, r) })
          }
          if (node.stroke?.width) {
            const r = routePropertyShape(node.stroke.width, palette)
            routeCounts[r.kind] = (routeCounts[r.kind] ?? 0) + 1
            routingRows.push({ nodeName, axis: 'stroke-width', route: r.kind, detail: describeRoute(node.stroke.width, r) })
          }
        }
        renderRoutes([
          { count: routeCounts['inline-constant'], key: 'inline-constant',
            label: 'InlineConstant', color: 'rgba(120,140,160,0.55)' },
          { count: routeCounts['palette-zoom'],    key: 'palette-zoom',
            label: 'PaletteZoom',    color: 'rgba(99,102,241,0.65)'  },
          { count: routeCounts['compute-feature'], key: 'compute-feature',
            label: 'ComputeFeature', color: 'rgba(56,189,248,0.75)'  },
          { count: routeCounts['cpu-uniform'],     key: 'cpu-uniform',
            label: 'CpuUniform',     color: 'rgba(245,158,11,0.65)'  },
        ])
        renderRoutingTable(routingRows)

        // Stage 5b — palette atlas visualisation (constants + gradients)
        const $outPalette = document.getElementById('out-palette') as HTMLElement
        renderPaletteAtlas($outPalette, palette as unknown as PaletteLike)

        // Stage 6 + 7 + 8 — compute plan + render shaders + compute kernels
        const commands = emitCommands(scene, {
          enablePaletteSampling: true,
          enableComputePath: true,
        }) as { computePlan?: any[]; shows?: any[] }

        // Stage 7 — per-render-node shader emit (fill/stroke + preamble)
        const shows = commands.shows ?? []
        const renderShaderViews: RenderShaderView[] = []
        for (const show of shows) {
          const v = show.shaderVariant
          if (!v) continue
          renderShaderViews.push({
            nodeName: show.targetName || show.layerName || show.sourceLayer || `<unnamed>`,
            key: v.key ?? '',
            preamble: v.preamble ?? '',
            fillExpr: v.fillExpr ?? 'vec4<f32>(0.0)',
            strokeExpr: v.strokeExpr ?? 'vec4<f32>(0.0)',
            fillPreamble: v.fillPreamble ?? '',
            strokePreamble: v.strokePreamble ?? '',
            paletteColorGradients: v.paletteColorGradients ?? [],
            needsFeatureBuffer: !!v.needsFeatureBuffer,
          })
        }
        renderRenderShaderTabs(renderShaderViews)

        const plan = commands.computePlan ?? []
        $statEntries.textContent = String(plan.length)
        $badgePlan.textContent = String(plan.length)
        const uniqueKernels = new Set(plan.map(e => e.kernel)).size
        $badgeUnique.textContent = String(uniqueKernels)

        const planViews: PlanView[] = plan.map((e: any, i: number) => {
          const node = scene.renderNodes[e.renderNodeIndex]
          const k = e.kernel
          const armCount = Object.values(e.categoryOrder ?? {}).reduce(
            (sum: number, arr: any) => sum + (Array.isArray(arr) ? arr.length : 0), 0,
          ) as number
          const wgsl = k.wgsl ?? ''
          return {
            nodeName: node?.name || `<${e.renderNodeIndex}>`,
            axis: e.paintAxis,
            kernelName: k.entryPoint ?? `kernel_${i}`,
            fingerprint: (k.entryPoint ?? '') + '\x1F' + wgsl,
            fields: e.fieldOrder ?? [],
            armCount,
            wgsl,
            strategy: detectStrategy(wgsl, k.entryPoint ?? ''),
          }
        })
        renderPlanTable(planViews)

        // Hand the unique-kernel set to the live GPU bench. dedup by
        // fingerprint so re-measuring the same kernel twice doesn't
        // double the work. setBenchKernels is defined further down in
        // this script block; it triggers a measurement if WebGPU +
        // timestamp-query are both available, otherwise no-op.
        const uniqByKernelKey = new Map<string, PlanView>()
        for (const v of planViews) {
          if (!uniqByKernelKey.has(v.fingerprint)) uniqByKernelKey.set(v.fingerprint, v)
        }
        const benchKernels = [...uniqByKernelKey.values()].map(v => ({
          kernelName: v.kernelName,
          strategy: v.strategy,
          armCount: v.armCount,
          wgsl: v.wgsl,
          categoryOrder: {},
        }))
        const setter = (window as unknown as { __setBenchKernels?: (k: typeof benchKernels) => void }).__setBenchKernels
        if (setter) setter(benchKernels)

        const ms = performance.now() - t0
        $status.textContent = `compiled in ${ms.toFixed(1)} ms`
      } catch (e: any) {
        setError(e?.message ?? String(e))
        $status.textContent = ''
      }
    }

    // Debounced live recompile — 150 ms is fast enough to feel
    // immediate while skipping intermediate keystrokes during fast typing.
    let pending = 0
    function scheduleCompile() {
      if (pending) clearTimeout(pending)
      pending = window.setTimeout(() => {
        pending = 0
        compile($src.value)
      }, 150)
    }
    $src.addEventListener('input', scheduleCompile)

    // Preset chips — swap source + visual state.
    document.querySelectorAll<HTMLButtonElement>('.preset-chip').forEach(btn => {
      btn.addEventListener('click', () => {
        const id = btn.dataset.presetId ?? ''
        const src = presetSources[id]
        if (!src) return
        $src.value = src
        $blurb.textContent = btn.title || (btn.parentElement?.querySelector(`[data-preset-id="${id}"]`) as HTMLElement)?.textContent || ''
        document.querySelectorAll<HTMLButtonElement>('.preset-chip').forEach(b => {
          b.classList.remove('border-accent', 'bg-accent/15', 'text-accent')
          b.classList.add('border-line', 'bg-bg-elev', 'text-fg-dim')
        })
        btn.classList.remove('border-line', 'bg-bg-elev', 'text-fg-dim')
        btn.classList.add('border-accent', 'bg-accent/15', 'text-accent')
        compile(src)
      })
    })

    // ════════════════════════════════════════════════════════════════
    // Live GPU timing — dispatches each unique emitted kernel onto a
    // local WebGPU device + measures with timestamp-query. Pure CSR;
    // never blocks the compile graph display (no-ops if WebGPU /
    // timestamp-query aren't available).
    // ════════════════════════════════════════════════════════════════

    const $benchStatus = document.getElementById('gpu-bench-status') as HTMLElement
    const $benchPanel = document.getElementById('gpu-bench-panel') as HTMLElement
    const $benchUnavail = document.getElementById('gpu-bench-unavailable') as HTMLElement
    const $benchCount = document.getElementById('gpu-bench-count') as HTMLSelectElement
    const $benchIterInfo = document.getElementById('gpu-bench-iter-info') as HTMLElement
    const $benchRun = document.getElementById('gpu-bench-run') as HTMLButtonElement
    const $benchResults = document.getElementById('gpu-bench-results') as HTMLElement

    interface GpuCtx {
      device: GPUDevice
      hasTimestamp: boolean
    }
    let gpuCtxPromise: Promise<GpuCtx | null> | null = null

    /** Initialise (and cache) a WebGPU device with `timestamp-query`
     *  when the adapter offers it. Null on adapter failure or browser
     *  without WebGPU support. Cached so re-measure clicks reuse the
     *  same device. */
    function getGpuCtx(): Promise<GpuCtx | null> {
      if (gpuCtxPromise) return gpuCtxPromise
      gpuCtxPromise = (async (): Promise<GpuCtx | null> => {
        if (typeof navigator === 'undefined' || !navigator.gpu) return null
        try {
          const adapter = await navigator.gpu.requestAdapter({ powerPreference: 'high-performance' })
            ?? await navigator.gpu.requestAdapter()
          if (!adapter) return null
          const features: GPUFeatureName[] = []
          const hasTimestamp = adapter.features.has('timestamp-query')
          if (hasTimestamp) features.push('timestamp-query')
          const device = await adapter.requestDevice(features.length > 0 ? { requiredFeatures: features } : undefined)
          device.lost.then(() => { gpuCtxPromise = null })
          return { device, hasTimestamp }
        } catch {
          return null
        }
      })()
      return gpuCtxPromise
    }

    interface BenchResult {
      kernelName: string
      strategy: string
      armCount: number
      medianNs: number
      p95Ns: number
      meanNs: number
      stdNs: number
      sampleCount: number
    }

    interface KernelToBench {
      kernelName: string
      strategy: string
      armCount: number
      wgsl: string
      categoryOrder: Record<string, readonly string[]>
    }

    /** Dispatch `iterations` of one kernel against `featureCount`
     *  synthetic features (uniform random IDs in [0, armCount)).
     *  Returns per-dispatch ns deltas extracted from a 2-slot timestamp
     *  pair (begin + end of each compute pass). Warmup runs are dropped
     *  by the caller. */
    async function timeKernel(
      ctx: GpuCtx,
      kernel: KernelToBench,
      featureCount: number,
      iterations: number,
    ): Promise<number[]> {
      const { device, hasTimestamp } = ctx
      if (!hasTimestamp) return []

      let module: GPUShaderModule
      try {
        module = device.createShaderModule({ code: kernel.wgsl })
      } catch { return [] }
      const pipeline = device.createComputePipeline({
        layout: 'auto',
        compute: { module, entryPoint: kernel.kernelName.startsWith('eval_') ? kernel.kernelName : 'eval_match' },
      })

      // Synthetic feature data: one f32 per feature in [0, armCount).
      // armCount=0 (ternary / non-categorical) falls back to a tiny
      // [0..1) spread.
      const arm = kernel.armCount > 0 ? kernel.armCount : 4
      const feat = new Float32Array(Math.max(featureCount, 1))
      for (let i = 0; i < feat.length; i++) feat[i] = Math.floor(Math.random() * arm)
      const featBuf = device.createBuffer({
        size: Math.max(feat.byteLength, 16),
        usage: GPUBufferUsage.STORAGE | GPUBufferUsage.COPY_DST,
      })
      device.queue.writeBuffer(featBuf, 0, feat)

      const outBuf = device.createBuffer({
        size: Math.max(feat.length * 4, 16),
        usage: GPUBufferUsage.STORAGE,
      })

      // u_count is a vec4<u32> uniform (16 bytes minimum for uniform
      // bindings in WebGPU) — kernel reads .x.
      const countBuf = device.createBuffer({
        size: 16, usage: GPUBufferUsage.UNIFORM | GPUBufferUsage.COPY_DST,
      })
      device.queue.writeBuffer(countBuf, 0, new Uint32Array([feat.length, 0, 0, 0]))

      const bindGroup = device.createBindGroup({
        layout: pipeline.getBindGroupLayout(0),
        entries: [
          { binding: 0, resource: { buffer: featBuf } },
          { binding: 1, resource: { buffer: outBuf } },
          { binding: 2, resource: { buffer: countBuf } },
        ],
      })

      const totalSlots = iterations * 2
      const querySet = device.createQuerySet({ type: 'timestamp', count: totalSlots })
      const resolveBuf = device.createBuffer({
        size: totalSlots * 8,
        usage: GPUBufferUsage.QUERY_RESOLVE | GPUBufferUsage.COPY_SRC,
      })
      const readBuf = device.createBuffer({
        size: totalSlots * 8,
        usage: GPUBufferUsage.MAP_READ | GPUBufferUsage.COPY_DST,
      })

      const encoder = device.createCommandEncoder()
      const workgroups = Math.ceil(feat.length / 64)
      for (let i = 0; i < iterations; i++) {
        const pass = encoder.beginComputePass({
          timestampWrites: {
            querySet,
            beginningOfPassWriteIndex: i * 2,
            endOfPassWriteIndex: i * 2 + 1,
          },
        })
        pass.setPipeline(pipeline)
        pass.setBindGroup(0, bindGroup)
        pass.dispatchWorkgroups(workgroups)
        pass.end()
      }
      encoder.resolveQuerySet(querySet, 0, totalSlots, resolveBuf, 0)
      encoder.copyBufferToBuffer(resolveBuf, 0, readBuf, 0, totalSlots * 8)
      device.queue.submit([encoder.finish()])

      await readBuf.mapAsync(GPUMapMode.READ)
      const view = new BigUint64Array(readBuf.getMappedRange())
      const out: number[] = []
      for (let i = 0; i < iterations; i++) {
        const a = view[i * 2], b = view[i * 2 + 1]
        if (b > a) out.push(Number(b - a))
      }
      readBuf.unmap()
      // Cleanup — buffers are tied to this dispatch's lifetime only.
      featBuf.destroy(); outBuf.destroy(); countBuf.destroy()
      resolveBuf.destroy(); readBuf.destroy(); querySet.destroy()
      return out
    }

    function stats(arr: number[]): { median: number; p95: number; mean: number; std: number } {
      if (arr.length === 0) return { median: 0, p95: 0, mean: 0, std: 0 }
      const sorted = [...arr].sort((a, b) => a - b)
      const median = sorted[Math.floor(sorted.length / 2)]!
      const p95 = sorted[Math.min(sorted.length - 1, Math.floor(sorted.length * 0.95))]!
      const mean = arr.reduce((a, b) => a + b, 0) / arr.length
      const variance = arr.reduce((s, v) => s + (v - mean) ** 2, 0) / arr.length
      return { median, p95, mean, std: Math.sqrt(variance) }
    }

    function renderBenchResults(results: BenchResult[]): void {
      $benchResults.innerHTML = ''
      if (results.length === 0) {
        $benchResults.innerHTML = '<div class="text-fg-mute text-[12px] italic">No kernels to measure — change the source to introduce a match() that lowers to compute.</div>'
        return
      }
      // Header row.
      const head = document.createElement('div')
      head.className = 'bench-row bench-row-head'
      head.innerHTML = `
        <span>Kernel · strategy</span>
        <span class="bench-num">median μs</span>
        <span class="bench-num">p95 μs</span>
        <span class="bench-num">mean ± std</span>
      `
      $benchResults.appendChild(head)
      // Find max for relative bar width.
      const maxMedian = Math.max(...results.map(r => r.medianNs), 1)
      for (const r of results) {
        const row = document.createElement('div')
        row.className = 'bench-row'
        const us = (ns: number) => (ns / 1000).toFixed(2)
        row.innerHTML = `
          <span class="bench-name">${escapeHtml(r.kernelName)} <span class="strategy-tag inline ${strategyClass(r.strategy as never)}">${strategyLabel(r.strategy as never)}</span></span>
          <span class="bench-num">${us(r.medianNs)}</span>
          <span class="bench-num muted">${us(r.p95Ns)}</span>
          <span class="bench-num muted">${us(r.meanNs)} ± ${us(r.stdNs)}</span>
          <div class="bench-bar"><span style="width:${(r.medianNs / maxMedian * 100).toFixed(1)}%"></span></div>
        `
        $benchResults.appendChild(row)
      }
    }

    let lastKernels: KernelToBench[] = []

    async function runBench(): Promise<void> {
      $benchStatus.textContent = 'measuring…'
      $benchRun.disabled = true
      try {
        const ctx = await getGpuCtx()
        if (!ctx || !ctx.hasTimestamp) {
          $benchPanel.classList.add('hidden')
          $benchUnavail.classList.remove('hidden')
          $benchStatus.textContent = 'unavailable'
          return
        }
        $benchPanel.classList.remove('hidden')
        $benchUnavail.classList.add('hidden')

        const featureCount = parseInt($benchCount.value, 10) || 4096
        const totalIter = 250
        const warmup = 50
        $benchIterInfo.textContent = `${totalIter - warmup} dispatches (after ${warmup} warmup)`

        const results: BenchResult[] = []
        for (const k of lastKernels) {
          const samples = await timeKernel(ctx, k, featureCount, totalIter)
          const useful = samples.slice(warmup)
          const s = stats(useful)
          results.push({
            kernelName: k.kernelName,
            strategy: k.strategy,
            armCount: k.armCount,
            medianNs: s.median,
            p95Ns: s.p95,
            meanNs: s.mean,
            stdNs: s.std,
            sampleCount: useful.length,
          })
        }
        renderBenchResults(results)
        $benchStatus.textContent = `${featureCount.toLocaleString()} features × ${totalIter - warmup} dispatches`
      } catch (e: any) {
        $benchStatus.textContent = `error: ${e?.message ?? e}`
      } finally {
        $benchRun.disabled = false
      }
    }

    /** Caller (compile()) hands a snapshot of the unique kernels —
     *  same data the WGSL viewer renders. The bench section reuses
     *  the strategy detection + arm count already computed there. */
    ;(window as unknown as { __setBenchKernels: (k: KernelToBench[]) => void }).__setBenchKernels = (kernels: KernelToBench[]) => {
      lastKernels = kernels
      if (kernels.length === 0) {
        renderBenchResults([])
        return
      }
      runBench()
    }

    $benchRun.addEventListener('click', () => { runBench() })
    $benchCount.addEventListener('change', () => { runBench() })

    // First-paint kernel sync — run the initial preset NOW that the
    // bench's `__setBenchKernels` setter is wired up, so compile() can
    // trigger the GPU bench immediately. The earlier (pre-bench) call
    // to compile() during module init wouldn't have found the setter.
    getGpuCtx().then(ctx => {
      if (!ctx) {
        $benchPanel.classList.add('hidden')
        $benchUnavail.classList.remove('hidden')
        $benchStatus.textContent = 'WebGPU unavailable'
      } else if (!ctx.hasTimestamp) {
        $benchPanel.classList.add('hidden')
        $benchUnavail.classList.remove('hidden')
        $benchStatus.textContent = 'timestamp-query unsupported'
      } else {
        $benchPanel.classList.remove('hidden')
      }
    })
    compile($src.value)
  </script>
