          <div class="mb-2 flex flex-wrap gap-2">
            <label for="kernel-picker" class="text-fg-mute text-[11px] uppercase tracking-wider self-center">Kernel</label>
            <select id="kernel-picker" class="bg-bg border border-line rounded px-3 py-1 text-[12px] text-fg focus:outline-none focus:border-accent"></select>
          </div>
          <pre id="wgsl-out" class="text-[12px] font-mono whitespace-pre bg-bg-card border border-line rounded-md p-4 overflow-x-auto leading-[1.5]"></pre>
        </div>

      </div>
    </section>

  </article>

  <script>
    // Real-time analyzer. Imports the compiler + diagnostics directly so
    // the same code that runs at engine compile time runs here. Mirrors
    // `convert.astro`'s pattern for fetch + paste fallback, but the
    // output stays in this page (no playground redirect) — we want the
    // user to see the routing decisions, not the rendered map.
    import { convertMapboxStyle, Lexer, Parser, lower, optimize, emitCommands } from '@xgis/compiler'
    import { routeColorValue } from '../../../../../compiler/src/codegen/paint-routing'
    import { collectPalette } from '../../../../../compiler/src/codegen/palette'

    const $url = document.getElementById('style-url') as HTMLInputElement
    const $json = document.getElementById('style-json') as HTMLTextAreaElement
    const $fetch = document.getElementById('analyze-fetch-btn') as HTMLButtonElement
    const $analyze = document.getElementById('analyze-btn') as HTMLButtonElement
    const $showPaste = document.getElementById('analyze-show-paste') as HTMLButtonElement
    const $pasteSection = document.getElementById('analyze-paste-section') as HTMLElement
    const $status = document.getElementById('analyze-status') as HTMLParagraphElement
    const $results = document.getElementById('analyze-results') as HTMLElement
    const $statNodes = document.getElementById('stat-nodes') as HTMLElement
    const $statEntries = document.getElementById('stat-entries') as HTMLElement
    const $statKernels = document.getElementById('stat-kernels') as HTMLElement
    const $statDedup = document.getElementById('stat-dedup') as HTMLElement
    const $histogram = document.getElementById('route-histogram') as HTMLElement
    const $planEmpty = document.getElementById('plan-empty') as HTMLElement
    const $planWrapper = document.getElementById('plan-table-wrapper') as HTMLElement
    const $planBody = document.getElementById('plan-tbody') as HTMLElement
    const $wgslSection = document.getElementById('wgsl-section') as HTMLElement
    const $kernelPicker = document.getElementById('kernel-picker') as HTMLSelectElement
    const $wgslOut = document.getElementById('wgsl-out') as HTMLElement

    function setStatus(msg: string, kind?: 'ok' | 'err') {
      $status.textContent = msg
      $status.style.color = kind === 'err' ? '#f87171' : kind === 'ok' ? '#86efac' : ''
    }

    function renderHistogram(buckets: { label: string; count: number; color: string; blurb: string }[]) {
      const total = buckets.reduce((a, b) => a + b.count, 0) || 1
      $histogram.innerHTML = ''
      for (const b of buckets) {
        const pct = (b.count / total) * 100
        const row = document.createElement('div')
        row.className = 'flex items-center gap-3'
        row.innerHTML = `
          <div class="w-[140px] text-[12px] text-fg-dim flex-shrink-0">${b.label}</div>
          <div class="flex-1 h-[20px] bg-bg-card rounded-md overflow-hidden relative">
            <div style="width:${pct.toFixed(1)}%;background:${b.color}" class="h-full transition-all"></div>
            <span class="absolute inset-0 flex items-center px-2 text-[11px] font-mono text-fg">${b.count} <span class="text-fg-mute ml-1">(${pct.toFixed(1)}%)</span></span>
          </div>
          <div class="w-[280px] text-[11px] text-fg-mute hidden md:block">${b.blurb}</div>
        `
        $histogram.appendChild(row)
      }
    }

    interface PlanEntryView {
      renderNodeIndex: number
      paintAxis: string
      kernelName: string
      kernelKey: string
      fields: string[]
      armCount: number
      wgsl: string
    }

    function renderPlanTable(entries: PlanEntryView[]) {
      $planBody.innerHTML = ''
      if (entries.length === 0) {
        $planEmpty.classList.remove('hidden')
        $planWrapper.classList.add('hidden')
        $wgslSection.classList.add('hidden')
        return
      }
      $planEmpty.classList.add('hidden')
      $planWrapper.classList.remove('hidden')
      $wgslSection.classList.remove('hidden')
      for (const e of entries) {
        const tr = document.createElement('tr')
        tr.className = 'border-t border-line'
        tr.innerHTML = `
          <td class="px-3 py-2 text-fg-dim tabular-nums">${e.renderNodeIndex}</td>
          <td class="px-3 py-2 text-fg">${e.paintAxis}</td>
          <td class="px-3 py-2 font-mono text-[11px] text-fg-dim">${e.kernelName}</td>
          <td class="px-3 py-2 font-mono text-[11px] text-fg-dim">${e.fields.join(', ')}</td>
          <td class="px-3 py-2 tabular-nums text-fg-dim">${e.armCount > 0 ? e.armCount : '—'}</td>
        `
        $planBody.appendChild(tr)
      }

      // Kernel picker — one option per unique kernel (deduped by fingerprint).
      const uniqueByKey = new Map<string, PlanEntryView>()
      for (const e of entries) if (!uniqueByKey.has(e.kernelKey)) uniqueByKey.set(e.kernelKey, e)
      $kernelPicker.innerHTML = ''
      for (const [_, e] of uniqueByKey) {
        const opt = document.createElement('option')
        opt.value = e.kernelKey
        opt.textContent = `${e.kernelName} (${e.fields.join(',')})`
        $kernelPicker.appendChild(opt)
      }
      $kernelPicker.onchange = () => {
        const sel = $kernelPicker.value
        const hit = uniqueByKey.get(sel)
        if (hit) $wgslOut.textContent = hit.wgsl
      }
      const first = uniqueByKey.values().next().value
      if (first) $wgslOut.textContent = first.wgsl
    }

    function analyze(xgisSrc: string) {
      try {
        const tokens = new Lexer(xgisSrc).tokenize()
        const program = new Parser(tokens).parse()
        const sceneRaw = lower(program)
        const scene = optimize(sceneRaw, program)

        // Collect palette so paint-routing can resolve PaletteZoom.
        const palette = collectPalette(scene)

        // Walk every render node × paint axis → classify route.
        const routeCounts = { inline: 0, palette: 0, compute: 0, cpu: 0 }
        for (const node of scene.renderNodes) {
          const axes: Array<{ value: any; name: string }> = [
            { value: node.fill, name: 'fill' },
            { value: node.stroke?.color, name: 'stroke' },
          ]
          for (const ax of axes) {
            if (!ax.value || ax.value.kind === 'none') continue
            const route = routeColorValue(ax.value, palette)
            switch (route.kind) {
              case 'inline-constant': routeCounts.inline++; break
              case 'palette-zoom':    routeCounts.palette++; break
              case 'compute-feature': routeCounts.compute++; break
              case 'cpu-uniform':     routeCounts.cpu++; break
            }
          }
        }

        renderHistogram([
          { label: 'InlineConstant', count: routeCounts.inline,
            color: 'rgba(120,140,160,0.6)',
            blurb: 'Bakedin WGSL literal — no per-frame work' },
          { label: 'PaletteZoom',    count: routeCounts.palette,
            color: 'rgba(99,102,241,0.6)',
            blurb: 'Atlas texture sample on u.zoom' },
          { label: 'ComputeFeature', count: routeCounts.compute,
            color: 'rgba(56,189,248,0.7)',
            blurb: 'GPU compute kernel → storage buffer' },
          { label: 'CpuUniform',     count: routeCounts.cpu,
            color: 'rgba(245,158,11,0.6)',
            blurb: 'CPU resolves per frame → uniform write' },
        ])

        // Emit full SceneCommands so we have the actual compute plan +
        // kernels the runtime would use. enablePaletteSampling on, scalar
        // off, computePath on (matches the runtime's emit options).
        const commands = emitCommands(scene, {
          enablePaletteSampling: true,
          enableComputePath: true,
        })
        const plan = (commands as { computePlan?: any[] }).computePlan ?? []

        $statNodes.textContent = String(scene.renderNodes.length)
        $statEntries.textContent = String(plan.length)
        const uniqueKernels = new Set(plan.map((e: any) => e.kernel)).size
        $statKernels.textContent = String(uniqueKernels)
        $statDedup.textContent = String(Math.max(0, plan.length - uniqueKernels))

        const entryViews: PlanEntryView[] = plan.map((e: any, i: number) => {
          const k = e.kernel
          const armCount = Object.values(e.categoryOrder ?? {}).reduce(
            (sum: number, arr: any) => sum + (Array.isArray(arr) ? arr.length : 0), 0,
          ) as number
          return {
            renderNodeIndex: e.renderNodeIndex,
            paintAxis: e.paintAxis,
            kernelName: k.entryPoint ?? `kernel_${i}`,
            kernelKey: (k.entryPoint ?? '') + '\x1F' + (k.wgsl ?? ''),
            fields: e.fieldOrder ?? [],
            armCount,
            wgsl: k.wgsl ?? '',
          }
        })
        renderPlanTable(entryViews)

        $results.classList.remove('hidden')
        setStatus(
          plan.length > 0
            ? `Analyzed — ${plan.length} compute entries, ${uniqueKernels} unique kernel${uniqueKernels === 1 ? '' : 's'}.`
            : `Analyzed — no compute entries (style has no data-driven paint).`,
          'ok',
        )
      } catch (e: any) {
        setStatus('Analyze failed: ' + (e?.message || e), 'err')
        $results.classList.add('hidden')
      }
    }

    function runOnMapbox(mapboxJson: string) {
      try {
        const parsed = JSON.parse(mapboxJson)
        const xgis = convertMapboxStyle(parsed)
        analyze(xgis)
      } catch (e: any) {
        setStatus('Conversion failed: ' + (e?.message || e), 'err')
      }
    }

    // Preset chip → fill URL + fetch.
    document.querySelectorAll<HTMLButtonElement>('.preset-chip').forEach(btn => {
      btn.addEventListener('click', () => {
        $url.value = btn.dataset.presetUrl ?? ''
        $fetch.click()
      })
    })

    $fetch.addEventListener('click', async () => {
      const url = $url.value.trim()
      if (!url) { setStatus('Enter a URL or pick a preset.', 'err'); return }
      setStatus('Fetching…')
      try {
        const resp = await fetch(url, { mode: 'cors' })
        if (!resp.ok) { setStatus(`HTTP ${resp.status} ${resp.statusText}`, 'err'); return }
        const text = await resp.text()
        runOnMapbox(text)
      } catch (e: any) {
        setStatus('Fetch failed (likely CORS): ' + (e?.message || e), 'err')
      }
    })

    $analyze.addEventListener('click', () => {
      const text = $json.value.trim()
      if (!text) { setStatus('Paste JSON first.', 'err'); return }
      runOnMapbox(text)
    })

    $showPaste.addEventListener('click', () => {
      $pasteSection.classList.toggle('hidden')
    })
  </script>
</Docs>
