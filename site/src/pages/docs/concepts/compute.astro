---
import Docs from '../../../layouts/Docs.astro'

interface Preset {
  id: string
  label: string
  blurb: string
  source: string
}

// Real xgis examples — each one round-trips through the actual
// compiler. Match the surface area in playground/src/examples/*.xgis
// so the user sees idioms that work in the live engine.
const presets: Preset[] = [
  {
    id: 'continent-match',
    label: 'continent-match',
    blurb: 'match() on a string property — lowers to a compute kernel',
    source: `source countries {
  type: geojson
  url: "ne_110m_countries.geojson"
}

layer continents {
  source: countries
  | fill match(.CONTINENT) {
      "Africa"        -> amber-600,
      "Asia"          -> rose-500,
      "Europe"        -> sky-500,
      "North America" -> emerald-500,
      "South America" -> lime-500,
      "Oceania"       -> violet-500,
      "Antarctica"    -> slate-300,
      _               -> gray-400
    }
    stroke-slate-700 stroke-0.5 opacity-90
}
`,
  },
  {
    id: 'osm-roads',
    label: 'osm-roads',
    blurb: 'Per-kind filter + tailwind paint — splits into six layers, merge-layers folds them',
    source: `source pm_world {
  type: pmtiles
  url: "/pmtiles-proxy/protomaps/v4.pmtiles"
}

layer roads_minor {
  source: pm_world
  sourceLayer: "roads"
  filter: .kind == "minor_road" || .kind == "service" || .kind == "path"
  | stroke-stone-400 stroke-0.5
}

layer roads_secondary {
  source: pm_world
  sourceLayer: "roads"
  filter: .kind == "secondary" || .kind == "tertiary"
  | stroke-yellow-200 stroke-1.5
}

layer roads_primary {
  source: pm_world
  sourceLayer: "roads"
  filter: .kind == "primary"
  | stroke-amber-300 stroke-2.5
}
`,
  },
  {
    id: 'zoom-interp',
    label: 'zoom interpolate',
    blurb: 'interpolate(zoom, …) — routes to the palette atlas, not compute',
    source: `source countries {
  type: geojson
  url: "ne_110m_countries.geojson"
}

layer ocean {
  source: countries
  | fill interpolate(zoom, 0, sky-200, 8, sky-500, 16, sky-700)
    opacity-90
}
`,
  },
  {
    id: 'constant',
    label: 'constant fill',
    blurb: 'No deps — fills get inlined as WGSL literals',
    source: `source countries {
  type: geojson
  url: "ne_110m_countries.geojson"
}

layer all {
  source: countries
  | fill-emerald-500 stroke-emerald-700 stroke-1 opacity-90
}
`,
  },
  {
    id: 'large-match',
    label: 'large match (LUT)',
    blurb: 'At 16+ arms the kernel switches from an if-chain to a const-array LUT — O(1) lookup',
    source: `source roads {
  type: geojson
  url: "roads.geojson"
}

/* 18-arm match — exceeds MATCH_LUT_THRESHOLD (16), so compute-gen
 * emits \`const LUT: array<vec4<f32>, 18>\` + a single \`LUT[id]\`
 * read instead of an if-else chain. */
layer roads_by_kind {
  source: roads
  | fill match(.kind) {
      "highway"      -> orange-500,
      "trunk"        -> orange-400,
      "primary"      -> amber-400,
      "secondary"    -> yellow-300,
      "tertiary"     -> yellow-200,
      "residential"  -> stone-300,
      "service"      -> stone-200,
      "path"         -> stone-100,
      "track"        -> amber-200,
      "footway"      -> lime-200,
      "cycleway"     -> emerald-300,
      "bridleway"    -> emerald-200,
      "steps"        -> rose-200,
      "pedestrian"   -> violet-200,
      "living_street"-> indigo-200,
      "raceway"      -> red-500,
      "rail"         -> slate-500,
      "subway"       -> slate-400,
      _              -> gray-300
    }
}
`,
  },
]
const presetById = Object.fromEntries(presets.map(p => [p.id, p]))
const initialPreset = presets[0]
---

<Docs
  current="concepts/compute"
  title="X-GIS — Compute paint evaluation"
  description="Live compile-graph viewer. Type xgis source, watch the lexer / parser / IR / paint-routing / compute plan / WGSL kernel update in place."
>
  <header class="mb-10">
    <p class="text-[13px] font-medium text-accent mb-3 tracking-[-0.01em]">
      Concept · interactive
    </p>
    <h1 class="text-[36px] sm:text-[44px] lg:text-[52px] font-medium text-fg leading-[1.1] tracking-[-0.035em]">
      Compile graph — live.
    </h1>
    <p class="mt-5 text-[16px] sm:text-[17px] leading-[1.6] text-fg-dim max-w-[720px]">
      Type xgis on the left, the compiler runs in the browser, every
      stage on the right updates as you type — tokens, AST, IR Scene,
      optimised IR, paint-routing decisions, ComputePlanEntry list,
      and the actual WGSL the runtime would hand to WebGPU.
    </p>
  </header>

  <!-- Preset chips -->
  <div class="mb-3 flex flex-wrap gap-2 items-center">
    <span class="text-fg-mute text-[11px] uppercase tracking-wider mr-1">Preset</span>
    {presets.map(p => (
      <button type="button" data-preset-id={p.id}
              class:list={[
                'preset-chip px-3 py-1.5 rounded-md border text-[12px] transition-colors',
                p.id === initialPreset.id
                  ? 'border-accent bg-accent/15 text-accent'
                  : 'border-line bg-bg-elev text-fg-dim hover:border-accent hover:text-accent',
              ]}>
        {p.label}
      </button>
    ))}
  </div>
  <p id="preset-blurb" class="text-fg-mute text-[12px] mb-5">{initialPreset.blurb}</p>

  <!-- Editor + summary row -->
  <div class="grid grid-cols-1 lg:grid-cols-[minmax(0,1fr)_minmax(0,1.1fr)] gap-5 mb-8">
    <!-- Editor -->
    <div class="flex flex-col">
      <div class="flex items-center justify-between mb-2">
        <label for="xgis-src" class="text-fg-mute text-[11px] uppercase tracking-wider">xgis source</label>
        <span id="compile-status" class="text-[11px] text-fg-mute tabular-nums"></span>
      </div>
      <textarea id="xgis-src" spellcheck="false"
                class="flex-1 min-h-[420px] bg-bg-card border border-line rounded-md p-4 text-[12.5px] font-mono leading-[1.55] text-fg whitespace-pre focus:outline-none focus:border-accent resize-none">{initialPreset.source}</textarea>
    </div>

    <!-- Summary stats -->
    <div class="flex flex-col">
      <div class="flex items-center mb-2">
        <span class="text-fg-mute text-[11px] uppercase tracking-wider">Summary</span>
        <span id="err-badge" class="hidden ml-2 px-2 py-0.5 rounded-full bg-rose-500/15 text-rose-300 border border-rose-500/30 text-[10px]"></span>
      </div>
      <div class="grid grid-cols-2 gap-3 mb-3">
        <div class="border border-line rounded-md p-3 bg-bg-elev">
          <div class="text-fg-mute text-[10px] uppercase tracking-wider">Tokens</div>
          <div id="stat-tokens" class="text-fg text-[20px] font-medium tabular-nums">—</div>
        </div>
        <div class="border border-line rounded-md p-3 bg-bg-elev">
          <div class="text-fg-mute text-[10px] uppercase tracking-wider">Render nodes</div>
          <div id="stat-nodes" class="text-fg text-[20px] font-medium tabular-nums">—</div>
        </div>
        <div class="border border-line rounded-md p-3 bg-bg-elev">
          <div class="text-fg-mute text-[10px] uppercase tracking-wider">Optimised</div>
          <div id="stat-optimised" class="text-fg text-[20px] font-medium tabular-nums">—</div>
        </div>
        <div class="border border-line rounded-md p-3 bg-bg-elev">
          <div class="text-fg-mute text-[10px] uppercase tracking-wider">Compute entries</div>
          <div id="stat-entries" class="text-fg text-[20px] font-medium tabular-nums">—</div>
        </div>
      </div>

      <!-- Paint axis routing — horizontal bar -->
      <div class="border border-line rounded-md p-3 bg-bg-elev flex-1">
        <div class="text-fg-mute text-[10px] uppercase tracking-wider mb-2">Paint axis routing</div>
        <div id="route-bars" class="space-y-1.5"></div>
      </div>
    </div>
  </div>

  <!-- Stages — each <details> collapsible -->
  <div class="space-y-2">

    <details class="stage-card group" open>
      <summary class="stage-summary">
        <span class="stage-num">1</span>
        <span class="stage-title">Tokens</span>
        <span class="stage-sub">Lexer · <span id="badge-tokens">—</span> tokens</span>
        <span class="stage-arrow"></span>
      </summary>
      <div class="stage-body">
        <pre id="out-tokens" class="stage-pre"></pre>
      </div>
    </details>

    <details class="stage-card group">
      <summary class="stage-summary">
        <span class="stage-num">2</span>
        <span class="stage-title">AST</span>
        <span class="stage-sub">Parser · top-level statements: <span id="badge-ast">—</span></span>
        <span class="stage-arrow"></span>
      </summary>
      <div class="stage-body">
        <pre id="out-ast" class="stage-pre"></pre>
      </div>
    </details>

    <details class="stage-card group">
      <summary class="stage-summary">
        <span class="stage-num">3</span>
        <span class="stage-title">IR Scene</span>
        <span class="stage-sub">lower() · pre-optimisation</span>
        <span class="stage-arrow"></span>
      </summary>
      <div class="stage-body">
        <pre id="out-ir" class="stage-pre"></pre>
      </div>
    </details>

    <details class="stage-card group">
      <summary class="stage-summary">
        <span class="stage-num">4</span>
        <span class="stage-title">Optimised IR</span>
        <span class="stage-sub">optimize() · merge-layers + fold-stops + fold-case + dead-layer-elim</span>
        <span class="stage-arrow"></span>
      </summary>
      <div class="stage-body">
        <pre id="out-ir-opt" class="stage-pre"></pre>
      </div>
    </details>

    <details class="stage-card group" open>
      <summary class="stage-summary">
        <span class="stage-num">5</span>
        <span class="stage-title">Paint routing</span>
        <span class="stage-sub">paint-routing · per axis classification</span>
        <span class="stage-arrow"></span>
      </summary>
      <div class="stage-body">
        <div id="out-routing" class="overflow-x-auto"></div>
      </div>
    </details>

    <details class="stage-card group" open>
      <summary class="stage-summary">
        <span class="stage-num">6</span>
        <span class="stage-title">Compute plan</span>
        <span class="stage-sub">planComputeKernels · <span id="badge-plan">—</span> entries, <span id="badge-unique">—</span> unique kernels</span>
        <span class="stage-arrow"></span>
      </summary>
      <div class="stage-body">
        <div id="out-plan" class="overflow-x-auto"></div>
      </div>
    </details>

    <details class="stage-card group" open>
      <summary class="stage-summary">
        <span class="stage-num">7</span>
        <span class="stage-title">Emitted WGSL</span>
        <span class="stage-sub">compute-gen · kernel-by-kernel</span>
        <span class="stage-arrow"></span>
      </summary>
      <div class="stage-body">
        <div id="kernel-tabs" class="flex flex-wrap gap-1 mb-2"></div>
        <pre id="out-wgsl" class="stage-pre"></pre>
      </div>
    </details>

  </div>

  <!-- Reference card — kept compact, route definitions are the only
       static content that survived the rewrite. -->
  <section class="mt-12 pt-6 border-t border-line">
    <h2 class="text-[18px] font-medium text-fg mb-3">Routes — quick reference</h2>
    <div class="grid grid-cols-1 md:grid-cols-2 gap-3 text-[12px]">
      <div class="border border-line rounded-md p-3 bg-bg-elev">
        <span class="font-medium text-fg">InlineConstant</span>
        <span class="text-fg-mute"> · deps = ∅</span>
        <p class="mt-1 text-fg-dim">Folded to a WGSL literal at compile time. Zero per-frame cost.</p>
      </div>
      <div class="border border-line rounded-md p-3 bg-bg-elev">
        <span class="font-medium text-fg">PaletteZoom</span>
        <span class="text-fg-mute"> · deps ⊆ zoom</span>
        <p class="mt-1 text-fg-dim">Pre-baked gradient atlas. One <code class="font-mono text-[11px]">textureSampleLevel</code> per fragment.</p>
      </div>
      <div class="border border-line rounded-md p-3 bg-bg-elev border-l-[3px] border-l-accent">
        <span class="font-medium text-accent">ComputeFeature</span>
        <span class="text-fg-mute"> · deps include feature</span>
        <p class="mt-1 text-fg-dim">Per-feature compute kernel. Fragment shader reads from <code class="font-mono text-[11px]">compute_out[feat_id]</code>.</p>
      </div>
      <div class="border border-line rounded-md p-3 bg-bg-elev">
        <span class="font-medium text-fg">CpuUniform</span>
        <span class="text-fg-mute"> · time / conditional</span>
        <p class="mt-1 text-fg-dim">CPU resolves every frame, writes a uniform. Spec-complete but never the fast path.</p>
      </div>
    </div>

    <h2 class="text-[18px] font-medium text-fg mt-8 mb-3">Kernel lowering — strategies</h2>
    <p class="text-[13px] text-fg-dim mb-3 max-w-[820px]">
      Inside a ComputeFeature kernel, <code class="font-mono text-[12px] text-fg">compute-gen</code>
      picks the WGSL shape based on arm count. The threshold is
      <code class="font-mono text-[12px] text-fg">MATCH_LUT_THRESHOLD = 16</code>
      in <code class="font-mono text-[12px] text-fg">compiler/src/codegen/compute-gen.ts</code>.
    </p>
    <div class="grid grid-cols-1 md:grid-cols-2 gap-3 text-[12px]">
      <div class="border border-line rounded-md p-3 bg-bg-elev">
        <span class="strategy-tag strategy-ifchain">if-chain · O(N)</span>
        <span class="text-fg-mute ml-2">arms &lt; 16</span>
        <p class="mt-2 text-fg-dim">Sequential <code class="font-mono text-[11px]">if (id == K0)</code> / <code class="font-mono text-[11px]">else if</code> branches. Cheap for small arm sets — the WGSL compiler reduces them well + branch prediction matches per fragment.</p>
      </div>
      <div class="border border-line rounded-md p-3 bg-bg-elev">
        <span class="strategy-tag strategy-lut">LUT · O(1)</span>
        <span class="text-fg-mute ml-2">arms ≥ 16</span>
        <p class="mt-2 text-fg-dim">Const <code class="font-mono text-[11px]">array&lt;vec4&lt;f32&gt;, N&gt;</code> baked into the shader module. Single <code class="font-mono text-[11px]">LUT[id]</code> indexed read regardless of arm count. Demotiles' 428-country palette is the canonical fit.</p>
      </div>
    </div>
  </section>

  <style>
    .stage-card {
      border: 1px solid var(--color-line, #1f2937);
      border-radius: 8px;
      background: var(--color-bg-elev, #0f1825);
      overflow: hidden;
    }
    .stage-card[open] {
      border-color: rgba(56, 189, 248, 0.35);
    }
    .stage-summary {
      display: flex;
      align-items: center;
      gap: 12px;
      padding: 10px 14px;
      cursor: pointer;
      list-style: none;
      user-select: none;
    }
    .stage-summary::-webkit-details-marker { display: none; }
    .stage-num {
      width: 22px; height: 22px;
      display: inline-flex;
      align-items: center; justify-content: center;
      border-radius: 11px;
      background: rgba(56, 189, 248, 0.12);
      color: #38bdf8;
      font: 600 11px/1 'DM Mono', monospace;
      flex-shrink: 0;
    }
    .stage-title {
      font-weight: 500;
      color: var(--color-fg, #c8d3e0);
      font-size: 13.5px;
    }
    .stage-sub {
      flex: 1;
      color: var(--color-fg-mute, #5a6a7e);
      font-size: 11.5px;
      font-family: 'DM Mono', monospace;
    }
    .stage-arrow {
      width: 8px; height: 8px;
      border-right: 1.5px solid #5a6a7e;
      border-bottom: 1.5px solid #5a6a7e;
      transform: rotate(45deg);
      transition: transform 0.15s;
    }
    .stage-card[open] .stage-arrow {
      transform: rotate(225deg);
    }
    .stage-body {
      padding: 0 14px 12px;
      border-top: 1px solid rgba(255, 255, 255, 0.04);
      padding-top: 12px;
    }
    .stage-pre {
      margin: 0;
      padding: 12px 14px;
      background: #0a1320;
      border: 1px solid #1f2937;
      border-radius: 6px;
      font-family: 'DM Mono', monospace;
      font-size: 11.5px;
      line-height: 1.55;
      color: #c8d3e0;
      overflow-x: auto;
      white-space: pre;
      max-height: 460px;
      overflow-y: auto;
    }

    /* Light syntax highlighting for emitted WGSL — same colour set the
       expressive-code default theme uses so the page reads consistent. */
    .tok-kw    { color: #c084fc; }
    .tok-type  { color: #38bdf8; }
    .tok-fn    { color: #fde68a; }
    .tok-num   { color: #fb923c; }
    .tok-str   { color: #86efac; }
    .tok-cmt   { color: #5a6a7e; font-style: italic; }
    .tok-attr  { color: #f9a8d4; }

    .kernel-tab {
      padding: 4px 10px;
      border-radius: 4px;
      border: 1px solid var(--color-line, #1f2937);
      background: var(--color-bg-card, #0a1320);
      color: var(--color-fg-mute, #5a6a7e);
      font: 500 11px/1.3 'DM Mono', monospace;
      cursor: pointer;
      transition: all 0.15s;
    }
    .kernel-tab:hover {
      color: var(--color-fg, #c8d3e0);
      border-color: rgba(56, 189, 248, 0.35);
    }
    .kernel-tab.active {
      color: #38bdf8;
      border-color: #38bdf8;
      background: rgba(56, 189, 248, 0.08);
    }

    .route-bar-row {
      display: flex;
      align-items: center;
      gap: 8px;
      font-family: 'DM Mono', monospace;
      font-size: 11px;
    }
    .route-bar-label {
      width: 130px;
      flex-shrink: 0;
      color: var(--color-fg-dim, #9ca3af);
    }
    .route-bar-track {
      flex: 1;
      height: 8px;
      background: rgba(255, 255, 255, 0.05);
      border-radius: 4px;
      overflow: hidden;
    }
    .route-bar-fill {
      height: 100%;
      border-radius: 4px;
      transition: width 0.18s ease;
    }
    .route-bar-count {
      width: 40px;
      text-align: right;
      color: var(--color-fg, #c8d3e0);
      tabular-nums: tabular-nums;
    }

    .routing-table {
      width: 100%;
      font-family: 'DM Mono', monospace;
      font-size: 11.5px;
      border-collapse: collapse;
    }
    .routing-table th,
    .routing-table td {
      padding: 6px 12px;
      text-align: left;
      border-bottom: 1px solid rgba(255, 255, 255, 0.04);
    }
    .routing-table th {
      color: var(--color-fg-mute, #5a6a7e);
      font-weight: 500;
      font-size: 10px;
      text-transform: uppercase;
      letter-spacing: 0.05em;
    }
    .routing-table td:nth-child(1) { color: #c8d3e0; }
    .routing-table td:nth-child(2) { color: #9ca3af; }
    .route-tag {
      display: inline-block;
      padding: 1px 7px;
      border-radius: 3px;
      font-size: 10.5px;
      font-weight: 500;
    }
    .route-tag.inline-constant { background: rgba(120,140,160,0.18); color: #cbd5e1; }
    .route-tag.palette-zoom    { background: rgba(99,102,241,0.18);  color: #a5b4fc; }
    .route-tag.compute-feature { background: rgba(56,189,248,0.20);  color: #38bdf8; }
    .route-tag.cpu-uniform     { background: rgba(245,158,11,0.18);  color: #fbbf24; }

    .strategy-tag {
      display: inline-block;
      padding: 1px 6px;
      border-radius: 3px;
      font-size: 10px;
      font-weight: 500;
      font-family: 'DM Mono', monospace;
      letter-spacing: 0.01em;
    }
    .strategy-tag.inline { margin-left: 6px; }
    .strategy-tag.strategy-lut      { background: rgba(34,197,94,0.18);  color: #86efac; }
    .strategy-tag.strategy-ifchain  { background: rgba(251,191,36,0.15); color: #fde047; }
    .strategy-tag.strategy-other    { background: rgba(120,140,160,0.18); color: #cbd5e1; }
  </style>

  <script define:vars={{ presetSources: Object.fromEntries(presets.map(p => [p.id, p.source])) }}>
    // Pulls the preset map into the module-scope `presetSources` so the
    // chip click handler doesn't have to re-fetch.
    window.__xgisComputePresets = presetSources
  </script>

  <script>
    // Live compile graph. Runs the actual compiler stages — Lexer →
    // Parser → lower → optimize → emitCommands — on every keystroke
    // (debounced). Each stage gets its own card; the WGSL output is
    // tokenised + colourised here in the browser so users don't need
    // an external highlight library.
    import { Lexer, Parser, lower, optimize, emitCommands } from '@xgis/compiler'
    import { TokenType } from '../../../../../compiler/src/lexer/tokens'
    import { routeColorValue, routePropertyShape } from '../../../../../compiler/src/codegen/paint-routing'
    import { collectPalette } from '../../../../../compiler/src/codegen/palette'

    const presetSources = (window as unknown as { __xgisComputePresets: Record<string, string> }).__xgisComputePresets

    const $src = document.getElementById('xgis-src') as HTMLTextAreaElement
    const $status = document.getElementById('compile-status') as HTMLElement
    const $errBadge = document.getElementById('err-badge') as HTMLElement
    const $blurb = document.getElementById('preset-blurb') as HTMLElement
    const $statTokens = document.getElementById('stat-tokens') as HTMLElement
    const $statNodes = document.getElementById('stat-nodes') as HTMLElement
    const $statOptimised = document.getElementById('stat-optimised') as HTMLElement
    const $statEntries = document.getElementById('stat-entries') as HTMLElement
    const $routeBars = document.getElementById('route-bars') as HTMLElement
    const $badgeTokens = document.getElementById('badge-tokens') as HTMLElement
    const $badgeAst = document.getElementById('badge-ast') as HTMLElement
    const $badgePlan = document.getElementById('badge-plan') as HTMLElement
    const $badgeUnique = document.getElementById('badge-unique') as HTMLElement
    const $outTokens = document.getElementById('out-tokens') as HTMLElement
    const $outAst = document.getElementById('out-ast') as HTMLElement
    const $outIr = document.getElementById('out-ir') as HTMLElement
    const $outIrOpt = document.getElementById('out-ir-opt') as HTMLElement
    const $outRouting = document.getElementById('out-routing') as HTMLElement
    const $outPlan = document.getElementById('out-plan') as HTMLElement
    const $outWgsl = document.getElementById('out-wgsl') as HTMLElement
    const $kernelTabs = document.getElementById('kernel-tabs') as HTMLElement

    function setError(msg: string) {
      $errBadge.textContent = msg
      $errBadge.classList.remove('hidden')
    }
    function clearError() {
      $errBadge.classList.add('hidden')
      $errBadge.textContent = ''
    }

    // Pretty-print JSON with a stable key order so the user can diff
    // by eye across edits. Drops verbose / circular-ish fields (e.g.
    // shaderVariant.preamble — multi-kilobyte) so the IR view stays
    // skimmable. Replacer preserves arrays + numbers + strings.
    const HIDE_FIELDS = new Set([
      'preamble', 'fillExpr', 'strokeExpr', 'shaderVariant',
      'paintShapes', 'classification',
    ])
    function pretty(obj: unknown, maxDepth = 6): string {
      const seen = new WeakSet<object>()
      function walk(v: unknown, depth: number): unknown {
        if (depth > maxDepth) return '…'
        if (v === null || typeof v !== 'object') return v
        if (seen.has(v as object)) return '«cycle»'
        seen.add(v as object)
        if (Array.isArray(v)) return v.map(item => walk(item, depth + 1))
        const out: Record<string, unknown> = {}
        for (const k of Object.keys(v as object)) {
          if (HIDE_FIELDS.has(k)) continue
          out[k] = walk((v as Record<string, unknown>)[k], depth + 1)
        }
        return out
      }
      return JSON.stringify(walk(obj, 0), null, 2)
    }

    // ── Token-type label table (for pretty token output) ──
    // Build at module init by scanning the runtime enum so the labels
    // stay in lockstep with the lexer definitions.
    const tokenLabels: Record<number, string> = {}
    for (const k of Object.keys(TokenType)) {
      const v = (TokenType as Record<string, unknown>)[k]
      if (typeof v === 'number') tokenLabels[v] = k
    }

    function escapeHtml(s: string): string {
      return s
        .replace(/&/g, '&amp;')
        .replace(/</g, '&lt;')
        .replace(/>/g, '&gt;')
    }

    function renderTokens(tokens: Array<{ type: number; value: string; line: number; col: number }>): string {
      const lines: string[] = []
      let lastLine = 0
      for (const tok of tokens) {
        if (tok.line !== lastLine) {
          if (lines.length > 0) lines.push('')
          lines.push(`<span class="tok-cmt">L${tok.line.toString().padStart(3, ' ')}</span>`)
          lastLine = tok.line
        }
        const label = tokenLabels[tok.type] ?? String(tok.type)
        const val = tok.value.length > 0 && tok.value !== label
          ? ` <span class="tok-str">${escapeHtml(JSON.stringify(tok.value))}</span>`
          : ''
        lines.push(`  <span class="tok-kw">${label.padEnd(14)}</span>${val}`)
      }
      return lines.join('\n')
    }

    // ── WGSL syntax highlighter ──
    // Minimal regex sweep — covers the keywords compute-gen.ts emits,
    // which is a tiny subset of WGSL. False-positives are fine inside
    // string literals (none exist in emitted kernels). Avoid lookbehind
    // for Safari ≤ 16 compatibility.
    const WGSL_KW = new Set([
      'fn', 'var', 'let', 'const', 'if', 'else', 'return',
      'struct', 'storage', 'read', 'read_write', 'uniform', 'array',
    ])
    const WGSL_TY = new Set([
      'f32', 'i32', 'u32', 'bool',
      'vec2', 'vec3', 'vec4', 'mat4x4', 'mat3x3',
      'vec2<f32>', 'vec3<f32>', 'vec4<f32>', 'vec3<u32>', 'vec4<u32>',
    ])
    const WGSL_FN = new Set([
      'pack4x8unorm', 'unpack4x8unorm', 'floor', 'min', 'max', 'mix', 'clamp',
      'textureSampleLevel', 'textureLoad', 'textureDimensions',
    ])
    function highlightWgsl(src: string): string {
      const out: string[] = []
      // Line-by-line — handle `// …` comments per line.
      for (const rawLine of src.split('\n')) {
        const cmtIdx = rawLine.indexOf('//')
        const code = cmtIdx === -1 ? rawLine : rawLine.slice(0, cmtIdx)
        const cmt = cmtIdx === -1 ? '' : rawLine.slice(cmtIdx)
        // Tokenise code part by splitting on a wide separator regex
        // that captures the delimiters so we can preserve them.
        const parts = code.split(/(\s+|[(){}\[\]<>,;:=+\-*/.@])/)
        const html: string[] = []
        for (const part of parts) {
          if (!part) continue
          if (/^\s+$/.test(part)) { html.push(part); continue }
          if (WGSL_KW.has(part))         html.push(`<span class="tok-kw">${escapeHtml(part)}</span>`)
          else if (WGSL_TY.has(part))    html.push(`<span class="tok-type">${escapeHtml(part)}</span>`)
          else if (WGSL_FN.has(part))    html.push(`<span class="tok-fn">${escapeHtml(part)}</span>`)
          else if (/^@\w+$/.test(part))  html.push(`<span class="tok-attr">${escapeHtml(part)}</span>`)
          else if (/^-?\d/.test(part))   html.push(`<span class="tok-num">${escapeHtml(part)}</span>`)
          else                           html.push(escapeHtml(part))
        }
        if (cmt) html.push(`<span class="tok-cmt">${escapeHtml(cmt)}</span>`)
        out.push(html.join(''))
      }
      return out.join('\n')
    }

    function renderRoutes(routes: Array<{ count: number; key: string; label: string; color: string }>): void {
      const total = routes.reduce((a, b) => a + b.count, 0) || 1
      $routeBars.innerHTML = ''
      for (const r of routes) {
        const pct = (r.count / total) * 100
        const row = document.createElement('div')
        row.className = 'route-bar-row'
        row.innerHTML = `
          <div class="route-bar-label">${r.label}</div>
          <div class="route-bar-track">
            <div class="route-bar-fill" style="width:${pct.toFixed(1)}%;background:${r.color}"></div>
          </div>
          <div class="route-bar-count">${r.count}</div>
        `
        $routeBars.appendChild(row)
      }
    }

    interface RoutingRow {
      nodeName: string
      axis: string
      route: string
      detail: string
    }
    function renderRoutingTable(rows: RoutingRow[]): void {
      if (rows.length === 0) {
        $outRouting.innerHTML = '<div class="text-fg-mute text-[12px] italic">No paint axes — empty scene?</div>'
        return
      }
      const html = ['<table class="routing-table"><thead><tr>']
      html.push('<th>Render node</th><th>Axis</th><th>Route</th><th>Detail</th>')
      html.push('</tr></thead><tbody>')
      for (const r of rows) {
        html.push(`<tr><td>${escapeHtml(r.nodeName)}</td>`)
        html.push(`<td>${escapeHtml(r.axis)}</td>`)
        html.push(`<td><span class="route-tag ${r.route}">${routeLabel(r.route)}</span></td>`)
        html.push(`<td>${escapeHtml(r.detail)}</td></tr>`)
      }
      html.push('</tbody></table>')
      $outRouting.innerHTML = html.join('')
    }
    function routeLabel(kind: string): string {
      return kind === 'inline-constant' ? 'InlineConstant'
           : kind === 'palette-zoom'    ? 'PaletteZoom'
           : kind === 'compute-feature' ? 'ComputeFeature'
           : kind === 'cpu-uniform'     ? 'CpuUniform'
           : kind
    }

    function describeRoute(value: any, route: any): string {
      if (route.kind === 'inline-constant') {
        if (value.kind === 'constant' && Array.isArray(value.rgba)) {
          const hex = '#' + value.rgba.slice(0, 3)
            .map((c: number) => Math.round(c * 255).toString(16).padStart(2, '0')).join('')
          return `constant ${hex}${value.rgba[3] < 1 ? ` @${(value.rgba[3] * 100).toFixed(0)}%` : ''}`
        }
        if (value.kind === 'constant') return `constant ${value.value}`
        return 'inlined'
      }
      if (route.kind === 'palette-zoom') {
        return `gradient #${route.gradientIndex} · zoom-interpolated`
      }
      if (route.kind === 'compute-feature') {
        return 'kernel dispatched per tile'
      }
      return value.kind ?? 'cpu eval'
    }

    interface PlanView {
      nodeName: string
      axis: string
      kernelName: string
      fingerprint: string
      fields: string[]
      armCount: number
      wgsl: string
      /** Which lowering strategy compute-gen picked. Derived from the
       *  emitted body — `const LUT: array<...>` decl means the LUT
       *  path fired; otherwise it's the if-else chain. The threshold
       *  is MATCH_LUT_THRESHOLD (=16) in compute-gen.ts. */
      strategy: 'if-chain' | 'lut' | 'ternary' | 'unknown'
    }

    function detectStrategy(wgsl: string, entryPoint: string): PlanView['strategy'] {
      if (/^const LUT:\s*array</m.test(wgsl)) return 'lut'
      if (entryPoint === 'eval_match' || entryPoint === 'eval_case') return 'if-chain'
      if (entryPoint?.startsWith('eval_ternary')) return 'ternary'
      return 'unknown'
    }
    function strategyLabel(s: PlanView['strategy']): string {
      return s === 'lut'      ? 'LUT · O(1)'
           : s === 'if-chain' ? 'if-chain · O(N)'
           : s === 'ternary'  ? 'ternary'
           : 'kernel'
    }
    function strategyClass(s: PlanView['strategy']): string {
      return s === 'lut'      ? 'strategy-lut'
           : s === 'if-chain' ? 'strategy-ifchain'
           : 'strategy-other'
    }
    function renderPlanTable(entries: PlanView[]): void {
      if (entries.length === 0) {
        $outPlan.innerHTML = '<div class="text-fg-mute text-[12px] italic">No data-driven paint axes — nothing routed to compute.</div>'
        $outWgsl.innerHTML = '<div style="color:#5a6a7e;font-style:italic">No WGSL — change the source to introduce a match() / data-driven expression.</div>'
        $kernelTabs.innerHTML = ''
        return
      }
      const html = ['<table class="routing-table"><thead><tr>']
      html.push('<th>Render node</th><th>Axis</th><th>Fields</th><th>Arms</th><th>Strategy</th><th>Kernel</th>')
      html.push('</tr></thead><tbody>')
      for (const e of entries) {
        html.push(`<tr><td>${escapeHtml(e.nodeName)}</td>`)
        html.push(`<td>${escapeHtml(e.axis)}</td>`)
        html.push(`<td>${escapeHtml(e.fields.join(', ') || '—')}</td>`)
        html.push(`<td>${e.armCount > 0 ? e.armCount : '—'}</td>`)
        html.push(`<td><span class="strategy-tag ${strategyClass(e.strategy)}">${strategyLabel(e.strategy)}</span></td>`)
        html.push(`<td>${escapeHtml(e.kernelName)}</td></tr>`)
      }
      html.push('</tbody></table>')
      $outPlan.innerHTML = html.join('')

      // Unique kernel tabs.
      const uniqByKey = new Map<string, PlanView>()
      for (const e of entries) if (!uniqByKey.has(e.fingerprint)) uniqByKey.set(e.fingerprint, e)
      $kernelTabs.innerHTML = ''
      let first = true
      let activeWgsl = ''
      uniqByKey.forEach((e, key) => {
        const btn = document.createElement('button')
        btn.type = 'button'
        btn.className = 'kernel-tab' + (first ? ' active' : '')
        btn.innerHTML = `${escapeHtml(e.kernelName)} · ${escapeHtml(e.fields.join(',') || '—')} · ${e.armCount} arm${e.armCount === 1 ? '' : 's'}`
          + ` <span class="strategy-tag inline ${strategyClass(e.strategy)}">${strategyLabel(e.strategy)}</span>`
        btn.addEventListener('click', () => {
          $kernelTabs.querySelectorAll('.kernel-tab').forEach(b => b.classList.remove('active'))
          btn.classList.add('active')
          $outWgsl.innerHTML = highlightWgsl(e.wgsl)
        })
        if (first) activeWgsl = e.wgsl
        first = false
        $kernelTabs.appendChild(btn)
      })
      $outWgsl.innerHTML = highlightWgsl(activeWgsl)
    }

    function compile(src: string): void {
      const t0 = performance.now()
      try {
        clearError()
        const tokens = new Lexer(src).tokenize()
        const program = new Parser(tokens).parse()
        const sceneRaw = lower(program)
        const scene = optimize(sceneRaw, program)
        const palette = collectPalette(scene)

        // Stage 1 — tokens
        $statTokens.textContent = String(tokens.length)
        $badgeTokens.textContent = String(tokens.length)
        $outTokens.innerHTML = renderTokens(tokens)

        // Stage 2 — AST
        $badgeAst.textContent = String(program.body.length)
        $outAst.textContent = pretty(program, 8)

        // Stage 3 — raw IR
        $statNodes.textContent = String(sceneRaw.renderNodes.length)
        $outIr.textContent = pretty({
          sources: sceneRaw.sources,
          renderNodes: sceneRaw.renderNodes,
          symbols: sceneRaw.symbols,
        }, 5)

        // Stage 4 — optimised IR
        $statOptimised.textContent = String(scene.renderNodes.length)
        $outIrOpt.textContent = pretty({
          sources: scene.sources,
          renderNodes: scene.renderNodes,
          symbols: scene.symbols,
        }, 5)

        // Stage 5 — paint routing per axis
        const routeCounts: Record<string, number> = {
          'inline-constant': 0, 'palette-zoom': 0,
          'compute-feature': 0, 'cpu-uniform': 0,
        }
        const routingRows: RoutingRow[] = []
        for (const node of scene.renderNodes) {
          const nodeName = node.name || `<unnamed ${routingRows.length}>`
          if (node.fill && node.fill.kind !== 'none') {
            const r = routeColorValue(node.fill, palette)
            routeCounts[r.kind] = (routeCounts[r.kind] ?? 0) + 1
            routingRows.push({ nodeName, axis: 'fill', route: r.kind, detail: describeRoute(node.fill, r) })
          }
          if (node.stroke?.color && node.stroke.color.kind !== 'none') {
            const r = routeColorValue(node.stroke.color, palette)
            routeCounts[r.kind] = (routeCounts[r.kind] ?? 0) + 1
            routingRows.push({ nodeName, axis: 'stroke', route: r.kind, detail: describeRoute(node.stroke.color, r) })
          }
          if (node.opacity) {
            const r = routePropertyShape(node.opacity, palette)
            routeCounts[r.kind] = (routeCounts[r.kind] ?? 0) + 1
            routingRows.push({ nodeName, axis: 'opacity', route: r.kind, detail: describeRoute(node.opacity, r) })
          }
          if (node.stroke?.width) {
            const r = routePropertyShape(node.stroke.width, palette)
            routeCounts[r.kind] = (routeCounts[r.kind] ?? 0) + 1
            routingRows.push({ nodeName, axis: 'stroke-width', route: r.kind, detail: describeRoute(node.stroke.width, r) })
          }
        }
        renderRoutes([
          { count: routeCounts['inline-constant'], key: 'inline-constant',
            label: 'InlineConstant', color: 'rgba(120,140,160,0.55)' },
          { count: routeCounts['palette-zoom'],    key: 'palette-zoom',
            label: 'PaletteZoom',    color: 'rgba(99,102,241,0.65)'  },
          { count: routeCounts['compute-feature'], key: 'compute-feature',
            label: 'ComputeFeature', color: 'rgba(56,189,248,0.75)'  },
          { count: routeCounts['cpu-uniform'],     key: 'cpu-uniform',
            label: 'CpuUniform',     color: 'rgba(245,158,11,0.65)'  },
        ])
        renderRoutingTable(routingRows)

        // Stage 6 + 7 — compute plan + WGSL
        const commands = emitCommands(scene, {
          enablePaletteSampling: true,
          enableComputePath: true,
        }) as { computePlan?: any[] }
        const plan = commands.computePlan ?? []
        $statEntries.textContent = String(plan.length)
        $badgePlan.textContent = String(plan.length)
        const uniqueKernels = new Set(plan.map(e => e.kernel)).size
        $badgeUnique.textContent = String(uniqueKernels)

        const planViews: PlanView[] = plan.map((e: any, i: number) => {
          const node = scene.renderNodes[e.renderNodeIndex]
          const k = e.kernel
          const armCount = Object.values(e.categoryOrder ?? {}).reduce(
            (sum: number, arr: any) => sum + (Array.isArray(arr) ? arr.length : 0), 0,
          ) as number
          const wgsl = k.wgsl ?? ''
          return {
            nodeName: node?.name || `<${e.renderNodeIndex}>`,
            axis: e.paintAxis,
            kernelName: k.entryPoint ?? `kernel_${i}`,
            fingerprint: (k.entryPoint ?? '') + '\x1F' + wgsl,
            fields: e.fieldOrder ?? [],
            armCount,
            wgsl,
            strategy: detectStrategy(wgsl, k.entryPoint ?? ''),
          }
        })
        renderPlanTable(planViews)

        const ms = performance.now() - t0
        $status.textContent = `compiled in ${ms.toFixed(1)} ms`
      } catch (e: any) {
        setError(e?.message ?? String(e))
        $status.textContent = ''
      }
    }

    // Debounced live recompile — 150 ms is fast enough to feel
    // immediate while skipping intermediate keystrokes during fast typing.
    let pending = 0
    function scheduleCompile() {
      if (pending) clearTimeout(pending)
      pending = window.setTimeout(() => {
        pending = 0
        compile($src.value)
      }, 150)
    }
    $src.addEventListener('input', scheduleCompile)

    // Preset chips — swap source + visual state.
    document.querySelectorAll<HTMLButtonElement>('.preset-chip').forEach(btn => {
      btn.addEventListener('click', () => {
        const id = btn.dataset.presetId ?? ''
        const src = presetSources[id]
        if (!src) return
        $src.value = src
        $blurb.textContent = btn.title || (btn.parentElement?.querySelector(`[data-preset-id="${id}"]`) as HTMLElement)?.textContent || ''
        document.querySelectorAll<HTMLButtonElement>('.preset-chip').forEach(b => {
          b.classList.remove('border-accent', 'bg-accent/15', 'text-accent')
          b.classList.add('border-line', 'bg-bg-elev', 'text-fg-dim')
        })
        btn.classList.remove('border-line', 'bg-bg-elev', 'text-fg-dim')
        btn.classList.add('border-accent', 'bg-accent/15', 'text-accent')
        compile(src)
      })
    })

    // First paint — run the initial preset through the pipeline.
    compile($src.value)
  </script>
