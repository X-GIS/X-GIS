---
import Base from '../layouts/Base.astro'
import Header from '../components/Header.astro'
import Footer from '../components/Footer.astro'
import '@xgis/blueprint/blueprint.css'

// Same playground handoff contract the /convert page uses: prod is
// same-origin (sessionStorage), dev is cross-origin (base64 URL hash).
const base = import.meta.env.BASE_URL.replace(/\/+$/, '')
const playgroundUrl = `${base}/play/demo.html`
---

<Base
  title="X-GIS — Blueprint"
  description="Compose X-GIS maps visually: a node-based blueprint editor that generates .xgis source and opens it in the playground."
>
  <Header />
  <main class="max-w-[1400px] mx-auto px-6 pt-20 pb-16">
    <div class="flex items-baseline justify-between flex-wrap gap-2">
      <h1 class="text-[22px] font-medium tracking-tight">Blueprint</h1>
      <p class="text-fg-dim text-[12px]">
        Drag canvas to pan · <kbd class="px-1 border border-line rounded">⇧</kbd>+drag to box-select ·
        right-click to add · drag a pin to connect ·
        <kbd class="px-1 border border-line rounded">⌘Z</kbd> undo
      </p>
    </div>

    <!-- ── Toolbar ── -->
    <div class="mt-5 flex flex-wrap items-center gap-2 text-[12px]">
      <select
        id="bp-add"
        class="bg-bg-elev border border-line rounded px-3 py-2 focus:outline-none focus:border-accent"
      >
        <option value="">+ Add node…</option>
        <option value="source">Source</option>
        <option value="layer">Layer</option>
        <option value="style">Style</option>
        <option value="preset">Preset</option>
        <option value="symbol">Symbol</option>
        <option value="fn">Function</option>
        <option value="import">Import</option>
        <option value="background">Background</option>
        <option value="reroute">Reroute</option>
        <option value="map">Map (output)</option>
      </select>
      <div class="flex rounded border border-line overflow-hidden bg-bg-elev">
        <button id="bp-undo" title="Undo (⌘Z)" class="px-2.5 py-2 text-fg-dim hover:text-fg hover:bg-bg-hover transition-colors">↶</button>
        <button id="bp-redo" title="Redo (⌘⇧Z)" class="px-2.5 py-2 text-fg-dim hover:text-fg hover:bg-bg-hover transition-colors border-l border-line">↷</button>
      </div>
      <button id="bp-fit" class="px-3 py-2 bg-bg-elev border border-line rounded text-fg-dim hover:text-fg hover:border-fg-dim transition-colors">Fit</button>
      <button id="bp-comment" class="px-3 py-2 bg-bg-elev border border-line rounded text-fg-dim hover:text-fg hover:border-fg-dim transition-colors">+ Comment</button>
      <label class="flex items-center gap-1.5 px-3 py-2 bg-bg-elev border border-line rounded text-fg-dim cursor-pointer select-none">
        <input id="bp-snap" type="checkbox" class="accent-accent" /> snap
      </label>
      <button
        id="bp-reset"
        class="px-3 py-2 bg-bg-elev border border-line rounded text-fg-dim hover:text-fg hover:border-fg-dim transition-colors"
        >Reset view</button
      >
      <button
        id="bp-new"
        class="px-3 py-2 bg-bg-elev border border-line rounded text-fg-dim hover:text-fg hover:border-fg-dim transition-colors"
        >New</button
      >
      <span id="bp-status" class="ml-auto text-[11px] px-2 py-1 rounded-full border"></span>
    </div>

    <!-- ── Import an existing style → nodes ── -->
    <details class="mt-3 border border-line rounded-md bg-bg-elev">
      <summary
        class="cursor-pointer select-none px-3 py-2 text-[12px] text-fg-dim hover:text-fg"
      >
        Import a style → blueprint
        <span class="text-fg-mute">(OpenFreeMap / MapLibre / any style.json / .xgis)</span>
      </summary>
      <div class="px-3 pb-3 pt-1 border-t border-line">
        <div class="flex flex-wrap gap-2 mb-3">
          {
            [
              { n: 'OpenFreeMap · Liberty', u: 'https://tiles.openfreemap.org/styles/liberty' },
              { n: 'OpenFreeMap · Bright', u: 'https://tiles.openfreemap.org/styles/bright' },
              { n: 'OpenFreeMap · Positron', u: 'https://tiles.openfreemap.org/styles/positron' },
              { n: 'MapLibre · Demotiles', u: 'https://demotiles.maplibre.org/style.json' },
            ].map((p) => (
              <button
                type="button"
                class="bp-chip px-3 py-1.5 rounded-md border border-line bg-bg text-[12px] text-fg-dim hover:border-accent hover:text-fg transition-colors"
                data-url={p.u}
              >
                {p.n}
              </button>
            ))
          }
        </div>
        <div class="flex flex-wrap gap-2 items-center">
          <input
            id="bp-imp-url"
            type="url"
            placeholder="https://example.com/style.json"
            class="flex-1 min-w-[240px] bg-bg border border-line rounded px-3 py-2 text-[12px] focus:outline-none focus:border-accent"
          />
          <button
            id="bp-imp-fetch"
            class="px-3 py-2 bg-accent/15 border border-accent text-accent rounded text-[12px] hover:bg-accent/25 transition-colors"
            >Fetch &amp; build</button
          >
        </div>
        <textarea
          id="bp-imp-paste"
          rows="3"
          placeholder="…or paste a Mapbox/MapLibre style JSON, or raw .xgis source, then Build"
          class="mt-2 w-full bg-bg border border-line rounded px-3 py-2 text-[12px] font-mono focus:outline-none focus:border-accent"
        ></textarea>
        <button
          id="bp-imp-build"
          class="mt-2 px-3 py-2 bg-bg border border-line rounded text-[12px] text-fg-dim hover:text-fg hover:border-fg-dim transition-colors"
          >Build from pasted text</button
        >
      </div>
    </details>

    <!-- ── Editor + source ── -->
    <div class="mt-3 grid grid-cols-1 lg:grid-cols-[1fr_400px] gap-3">
      <div
        id="bp-viewport"
        class="relative overflow-hidden rounded-md border border-line bg-bg-elev"
        style="height: min(74vh, 760px); min-height: 460px;"
      >
      </div>

      <div class="flex flex-col gap-3 min-h-0" data-playground-url={playgroundUrl}>
        <!-- Live preview -->
        <div class="flex flex-col rounded-md border border-line bg-bg-elev overflow-hidden">
          <div class="flex items-center gap-2 px-3 py-2 border-b border-line">
            <span class="text-fg text-[11px] tracking-wide uppercase">live preview</span>
            <label class="ml-auto flex items-center gap-1.5 text-[11px] text-fg-dim cursor-pointer select-none">
              <input id="bp-live" type="checkbox" checked class="accent-accent" />
              live
            </label>
            <button
              id="bp-render"
              class="px-2.5 py-1 bg-bg border border-line rounded text-[11px] text-fg-dim hover:text-fg hover:border-fg-dim transition-colors"
              >Render now</button
            >
          </div>
          <div class="relative bg-bg" style="height: 300px;">
            <canvas id="bp-canvas" class="absolute inset-0 w-full h-full block"></canvas>
            <div
              id="bp-prev-msg"
              class="absolute inset-x-0 bottom-0 px-3 py-1.5 text-[11px] text-fg-dim bg-bg/80 backdrop-blur-sm pointer-events-none"
            ></div>
          </div>
        </div>

        <!-- Inspector -->
        <div class="flex flex-col rounded-md border border-line bg-bg-elev overflow-hidden">
          <div class="px-3 py-2 border-b border-line text-fg text-[11px] tracking-wide uppercase">
            inspector
          </div>
          <div
            id="bp-inspector"
            class="px-3 py-2.5 overflow-y-auto"
            style="max-height: 26vh;"
          ></div>
        </div>

        <!-- Source -->
        <div class="flex flex-col flex-1 min-h-0 rounded-md border border-line bg-bg-elev">
          <div class="flex items-center gap-2 px-3 py-2 border-b border-line">
            <span class="text-fg text-[11px] tracking-wide uppercase">xgis source</span>
            <div class="ml-auto flex gap-2">
              <button
                id="bp-copy"
                class="px-2.5 py-1 bg-bg border border-line rounded text-[11px] text-fg-dim hover:text-fg hover:border-fg-dim transition-colors"
                >Copy</button
              >
              <button
                id="bp-open"
                class="px-2.5 py-1 bg-accent/15 border border-accent text-accent rounded text-[11px] hover:bg-accent/25 transition-colors"
                >Open in playground</button
              >
            </div>
          </div>
          <textarea
            id="bp-out"
            readonly
            spellcheck="false"
            class="flex-1 min-h-[160px] bg-bg px-3 py-2 text-[12px] font-mono whitespace-pre resize-none focus:outline-none"
          ></textarea>
          <p id="bp-msg" class="px-3 py-2 text-fg-dim text-[11px] border-t border-line min-h-[1.6em]"></p>
        </div>
      </div>
    </div>
  </main>
  <Footer />

  <script>
    // Real ES module (see /convert page note): required for the
    // `@xgis/compiler` + `@xgis/blueprint` workspace imports to resolve.
    import { Lexer, Parser } from '@xgis/compiler'
    import {
      BlueprintEditor,
      graphToXgis,
      importText,
      styleToGraph,
      starterGraph,
      type BPGraph,
      type NodeType,
    } from '@xgis/blueprint'

    const LS_KEY = 'xgis-blueprint-v1'
    const vp = document.getElementById('bp-viewport') as HTMLElement
    const $out = document.getElementById('bp-out') as HTMLTextAreaElement
    const $msg = document.getElementById('bp-msg') as HTMLParagraphElement
    const $status = document.getElementById('bp-status') as HTMLElement
    const $add = document.getElementById('bp-add') as HTMLSelectElement
    const $reset = document.getElementById('bp-reset') as HTMLButtonElement
    const $new = document.getElementById('bp-new') as HTMLButtonElement
    const $copy = document.getElementById('bp-copy') as HTMLButtonElement
    const $open = document.getElementById('bp-open') as HTMLButtonElement
    const $inspector = document.getElementById('bp-inspector') as HTMLElement
    const $undo = document.getElementById('bp-undo') as HTMLButtonElement
    const $redo = document.getElementById('bp-redo') as HTMLButtonElement
    const $fit = document.getElementById('bp-fit') as HTMLButtonElement
    const $comment = document.getElementById('bp-comment') as HTMLButtonElement
    const $snap = document.getElementById('bp-snap') as HTMLInputElement
    const playgroundUrl =
      (document.querySelector('[data-playground-url]') as HTMLElement | null)?.dataset
        .playgroundUrl ?? ''

    // ── Live preview (runtime embedded in-page) ──
    // The heavy WebGPU runtime is dynamically imported on first
    // render so it code-splits out of the initial page bundle.
    const $canvas = document.getElementById('bp-canvas') as HTMLCanvasElement
    const $prevMsg = document.getElementById('bp-prev-msg') as HTMLElement
    const $live = document.getElementById('bp-live') as HTMLInputElement
    const $render = document.getElementById('bp-render') as HTMLButtonElement
    const dataBase = (import.meta.env.BASE_URL || '/') + 'data/'

    // eslint-disable-next-line @typescript-eslint/no-explicit-any
    let MapCtor: any = null
    // eslint-disable-next-line @typescript-eslint/no-explicit-any
    let preview: any = null
    let renderToken = 0
    let prevTimer: number | undefined

    async function renderPreview(src: string) {
      if (!src.trim()) return
      const token = ++renderToken
      $prevMsg.textContent = 'Rendering…'
      try {
        if (!MapCtor) {
          const mod = await import('@xgis/runtime')
          MapCtor = mod.XGISMap
        }
        if (token !== renderToken) return // a newer render superseded us
        try {
          preview?.stop()
        } catch {
          /* prior map may not have started */
        }
        preview = new MapCtor($canvas)
        await preview.run(src, dataBase)
        if (token !== renderToken) return
        $prevMsg.textContent = ''
      } catch (e: any) {
        if (token === renderToken) $prevMsg.textContent = 'Preview: ' + String(e?.message || e)
      }
    }

    function schedulePreview(src: string) {
      window.clearTimeout(prevTimer)
      prevTimer = window.setTimeout(() => void renderPreview(src), 450)
    }

    function setStatus(ok: boolean, text: string) {
      $status.textContent = text
      $status.style.color = ok ? '#86efac' : '#fca5a5'
      $status.style.borderColor = ok
        ? 'rgba(134,239,172,0.35)'
        : 'rgba(252,165,165,0.35)'
      $status.style.background = ok
        ? 'rgba(134,239,172,0.10)'
        : 'rgba(252,165,165,0.10)'
    }

    let saveTimer: number | undefined
    function persist(g: BPGraph) {
      window.clearTimeout(saveTimer)
      saveTimer = window.setTimeout(() => {
        try {
          localStorage.setItem(LS_KEY, JSON.stringify(g))
        } catch {
          /* storage may be unavailable / full */
        }
      }, 400)
    }

    /** Regenerate source + validate it with the real compiler front
     *  end so the badge reflects whether the graph actually parses. */
    function refresh() {
      const g = editor.getGraph()
      const src = graphToXgis(g)
      $out.value = src
      persist(g)
      if (!src.trim()) {
        setStatus(true, 'empty')
        $msg.textContent = 'Add nodes (or right-click the canvas) to start.'
        $prevMsg.textContent = 'Nothing to preview yet.'
        return
      }
      try {
        new Parser(new Lexer(src).tokenize()).parse()
        setStatus(true, 'parses ✓')
        $msg.textContent =
          g.nodes.length + ' node' + (g.nodes.length === 1 ? '' : 's') + ' · ' +
          g.edges.length + ' wire' + (g.edges.length === 1 ? '' : 's')
        if ($live.checked) schedulePreview(src)
      } catch (e: any) {
        setStatus(false, 'parse error')
        $msg.textContent = String(e?.message || e)
        $prevMsg.textContent = 'Preview paused — fix the parse error.'
      }
    }

    const editor = new BlueprintEditor({ viewport: vp, inspector: $inspector, onChange: refresh })

    // Restore last session, else the README-style starter graph.
    let initial: BPGraph
    try {
      const raw = localStorage.getItem(LS_KEY)
      const parsed = raw ? JSON.parse(raw) : null
      initial =
        parsed && Array.isArray(parsed.nodes) && Array.isArray(parsed.edges)
          ? parsed
          : starterGraph()
    } catch {
      initial = starterGraph()
    }
    editor.load(initial)
    refresh()

    $add.addEventListener('change', () => {
      const t = $add.value as NodeType | ''
      if (t) editor.addNode(t)
      $add.value = ''
    })
    $reset.addEventListener('click', () => editor.resetView())
    $new.addEventListener('click', () => {
      if (confirm('Clear the whole blueprint?')) editor.clear()
    })
    $undo.addEventListener('click', () => editor.undo())
    $redo.addEventListener('click', () => editor.redo())
    $fit.addEventListener('click', () => editor.fit())
    $comment.addEventListener('click', () => editor.addFrame())
    $snap.addEventListener('change', () => editor.setSnap($snap.checked))

    $copy.addEventListener('click', async () => {
      if (!$out.value.trim()) return
      try {
        await navigator.clipboard.writeText($out.value)
        $msg.textContent = 'Copied to clipboard.'
      } catch {
        $out.select()
        document.execCommand('copy')
        $msg.textContent = 'Copied (fallback).'
      }
    })

    /** Identical dev/prod dispatch to /convert: prod ferries via
     *  sessionStorage same-origin; dev probes the playground server
     *  and passes the source through the URL hash cross-origin. */
    async function openInPlayground(source: string): Promise<void> {
      const label = 'Blueprint'
      // eslint-disable-next-line @typescript-eslint/no-explicit-any
      const isDev = !!(import.meta as any).env?.DEV
      if (isDev) {
        let running = false
        try {
          const probe = await fetch('https://localhost:3000/@vite/client', {
            mode: 'no-cors',
            cache: 'no-store',
          })
          running = probe.ok || probe.type === 'opaque'
        } catch {
          running = false
        }
        if (!running) {
          $msg.textContent =
            'Playground dev server not running on https://localhost:3000. ' +
            'Start it with `bun run dev` in playground/ (or `bun run dev:all`).'
          return
        }
        const encoded = btoa(unescape(encodeURIComponent(source)))
        window.location.href =
          `https://localhost:3000/demo.html?id=__import&label=${encodeURIComponent(
            label,
          )}#src=${encoded}`
        return
      }
      try {
        sessionStorage.setItem('__xgisImportSource', source)
        sessionStorage.setItem('__xgisImportLabel', label)
      } catch {
        /* sessionStorage may be unavailable in some embeds */
      }
      window.location.href = playgroundUrl + '?id=__import'
    }

    $open.addEventListener('click', () => {
      const src = $out.value
      if (!src.trim()) {
        $msg.textContent = 'Nothing to open — build a graph first.'
        return
      }
      void openInPlayground(src)
    })

    $render.addEventListener('click', () => {
      window.clearTimeout(prevTimer)
      void renderPreview($out.value)
    })
    $live.addEventListener('change', () => {
      if ($live.checked) void renderPreview($out.value)
    })

    // ── Style → blueprint import ──
    const $impUrl = document.getElementById('bp-imp-url') as HTMLInputElement
    const $impFetch = document.getElementById('bp-imp-fetch') as HTMLButtonElement
    const $impPaste = document.getElementById('bp-imp-paste') as HTMLTextAreaElement
    const $impBuild = document.getElementById('bp-imp-build') as HTMLButtonElement

    function applyGraph(g: BPGraph, label: string) {
      const cur = editor.getGraph()
      const nonTrivial = cur.nodes.length > 0
      if (nonTrivial && !confirm('Replace the current blueprint with the imported one?')) return
      editor.load(g)
      editor.resetView()
      refresh()
      const layers = g.nodes.filter((n) => n.type === 'layer').length
      $msg.textContent = `Imported ${label}: ${g.nodes.length} nodes (${layers} layers). Unsupported layer types were dropped — review the source.`
    }

    async function importFromUrl(url: string) {
      $msg.textContent = 'Fetching ' + url + ' …'
      try {
        const resp = await fetch(url)
        if (!resp.ok) throw new Error('HTTP ' + resp.status)
        const json = await resp.json()
        applyGraph(styleToGraph(json), url)
      } catch (e: any) {
        $msg.textContent =
          'Fetch failed: ' +
          (e?.message || e) +
          ' — likely a CORS block. Paste the JSON below instead.'
      }
    }

    document.querySelectorAll<HTMLButtonElement>('.bp-chip').forEach((b) => {
      b.addEventListener('click', () => {
        const u = b.dataset.url ?? ''
        $impUrl.value = u
        void importFromUrl(u)
      })
    })
    $impFetch.addEventListener('click', () => {
      const u = $impUrl.value.trim()
      if (!u) {
        $msg.textContent = 'Enter a style URL first.'
        return
      }
      void importFromUrl(u)
    })
    $impUrl.addEventListener('keydown', (e) => {
      if (e.key === 'Enter') {
        e.preventDefault()
        $impFetch.click()
      }
    })
    $impBuild.addEventListener('click', () => {
      const t = $impPaste.value.trim()
      if (!t) {
        $msg.textContent = 'Paste a style JSON or .xgis source first.'
        return
      }
      try {
        applyGraph(importText(t), 'pasted text')
      } catch (e: any) {
        $msg.textContent = 'Import failed: ' + (e?.message || e)
      }
    })
  </script>
</Base>
