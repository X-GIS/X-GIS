---
import Base from '../layouts/Base.astro'
import Header from '../components/Header.astro'
import Footer from '../components/Footer.astro'
const base = import.meta.env.BASE_URL.replace(/\/+$/, '')
const playgroundUrl = `${base}/play/demo.html`

interface Preset {
  id: string
  name: string
  url: string
  blurb: string
}

const presets: Preset[] = [
  {
    id: 'openfreemap-liberty',
    name: 'OpenFreeMap · Liberty',
    url: 'https://tiles.openfreemap.org/styles/liberty',
    blurb: 'Detailed, OSM-Liberty-flavoured cartography.',
  },
  {
    id: 'openfreemap-bright',
    name: 'OpenFreeMap · Bright',
    url: 'https://tiles.openfreemap.org/styles/bright',
    blurb: 'Light, busy, road-heavy basemap.',
  },
  {
    id: 'openfreemap-positron',
    name: 'OpenFreeMap · Positron',
    url: 'https://tiles.openfreemap.org/styles/positron',
    blurb: 'Minimal, near-monochrome — good for data overlays.',
  },
  {
    id: 'maplibre-demotiles',
    name: 'MapLibre · Demotiles',
    url: 'https://demotiles.maplibre.org/style.json',
    blurb: 'MapLibre demo style — countries + geolines, no commercial source key.',
  },
]
---

<Base title="Mapbox style → xgis converter">
  <Header />
  <main class="max-w-[1100px] mx-auto px-6 pt-20 pb-24 text-[14px]">
    <h1 class="text-[22px] font-medium tracking-tight">Mapbox style → xgis</h1>
    <p class="mt-2 text-fg-dim">
      Paste a Mapbox Style Spec JSON, or drop in a URL pointing at a
      <code>style.json</code>. The result drops straight into the playground.
    </p>

    <!-- ── Preset chips ── -->
    <section class="mt-6">
      <div class="text-fg-mute text-[11px] uppercase tracking-wider mb-2">Try a public style</div>
      <div class="flex flex-wrap gap-2">
        {presets.map(p => (
          <button
            type="button"
            class="preset-chip text-left px-3 py-2 rounded-md border border-line bg-bg-elev hover:border-accent hover:bg-accent/10 transition-colors"
            data-preset-url={p.url}
            data-preset-name={p.name}
          >
            <div class="text-fg text-[13px] font-medium">{p.name}</div>
            <div class="text-fg-dim text-[11px] mt-0.5">{p.blurb}</div>
          </button>
        ))}
      </div>
    </section>

    <!-- ── URL form (primary) ── -->
    <section class="mt-8 border border-line rounded-md p-4 bg-bg-elev">
      <label for="mapbox-url" class="block text-fg text-[12px] tracking-wide uppercase">URL</label>
      <div class="mt-2 flex flex-wrap gap-2 items-center">
        <input
          id="mapbox-url"
          type="url"
          placeholder="https://example.com/style.json"
          class="flex-1 min-w-[280px] bg-bg border border-line rounded px-3 py-2 text-[13px] focus:outline-none focus:border-accent"
        />
        <button
          id="fetch-btn"
          class="px-4 py-2 bg-accent/15 border border-accent text-accent rounded text-[12px] hover:bg-accent/25 transition-colors"
        >
          Fetch &amp; convert
        </button>
      </div>
      <p class="mt-2 text-fg-dim text-[11px]">
        The page fetches the URL directly in the browser — works for hosts
        that send <code>Access-Control-Allow-Origin</code>. If the request
        is blocked, <button type="button" id="show-paste" class="underline text-accent hover:text-accent-bright">paste the JSON manually instead</button>.
      </p>
    </section>

    <!-- ── Paste form (secondary, hidden until requested) ── -->
    <section id="paste-section" class="mt-4 border border-line rounded-md p-4 bg-bg-elev hidden">
      <label for="mapbox-json" class="block text-fg text-[12px] tracking-wide uppercase">Paste JSON</label>
      <textarea
        id="mapbox-json"
        rows="6"
        placeholder='{ "version": 8, "sources": { ... }, "layers": [ ... ] }'
        class="mt-2 w-full bg-bg border border-line rounded px-3 py-2 text-[12px] font-mono focus:outline-none focus:border-accent"
      ></textarea>
      <button
        id="convert-btn"
        class="mt-3 px-4 py-2 bg-accent/15 border border-accent text-accent rounded text-[12px] hover:bg-accent/25 transition-colors"
      >
        Convert
      </button>
    </section>

    <!-- ── Import shortcut (URL flow only) ── -->
    <!-- Shown after a successful URL fetch — surfaces the new
         splice-form `import "url"` directive so the user can paste a
         single line into their xgis instead of the converted block. -->
    <section id="import-shortcut" class="mt-6 border border-accent/30 rounded-md p-4 bg-accent/5 hidden">
      <div class="flex items-center gap-2 flex-wrap">
        <span class="text-accent text-[11px] uppercase tracking-wider font-medium">1-line import</span>
        <span class="text-fg-dim text-[11px]">
          Skip the paste step — the runtime fetches + converts on load.
        </span>
        <div class="ml-auto flex gap-2">
          <button id="copy-import-btn" class="px-3 py-1 bg-bg border border-line rounded text-[11px] text-fg-dim hover:text-fg hover:border-fg-dim transition-colors">Copy</button>
          <button id="open-import-btn" class="px-3 py-1 bg-accent/15 border border-accent text-accent rounded text-[11px] hover:bg-accent/25 transition-colors">Open as import</button>
        </div>
      </div>
      <pre id="import-snippet" class="mt-2 bg-bg border border-line rounded px-3 py-2 text-[12px] font-mono whitespace-pre overflow-x-auto"></pre>
    </section>

    <!-- ── Output ── -->
    <section class="mt-8" data-playground-url={playgroundUrl}>
      <div class="flex items-center gap-2 flex-wrap">
        <label for="xgis-out" class="text-fg text-[12px] tracking-wide uppercase">xgis source</label>
        <span id="warn-badge" class="hidden text-[11px] px-2 py-0.5 rounded-full bg-amber-500/15 text-amber-300 border border-amber-500/30 cursor-pointer hover:bg-amber-500/25"></span>
        <div class="ml-auto flex gap-2">
          <button id="copy-btn" class="px-3 py-1 bg-bg border border-line rounded text-[11px] text-fg-dim hover:text-fg hover:border-fg-dim transition-colors">Copy</button>
          <button id="open-btn" class="px-3 py-1 bg-accent/15 border border-accent text-accent rounded text-[11px] hover:bg-accent/25 transition-colors">Open in playground</button>
        </div>
      </div>
      <textarea
        id="xgis-out"
        rows="22"
        readonly
        class="mt-2 w-full bg-bg border border-line rounded px-3 py-2 text-[12px] font-mono whitespace-pre"
      ></textarea>
      <p id="status" class="mt-2 text-fg-dim text-[11px] min-h-[1.2em]"></p>

      <!-- Inline notes panel (toggled by warn-badge) -->
      <details id="notes-panel" class="mt-4 hidden">
        <summary class="cursor-pointer text-fg-dim text-[12px] hover:text-fg">Conversion notes</summary>
        <ul id="notes-list" class="mt-2 text-[12px] text-fg-dim space-y-1 max-h-[280px] overflow-auto pr-2"></ul>
      </details>
    </section>

    <!-- ── Compatibility reference ── -->
    <section class="mt-12 border-t border-line pt-8">
      <h2 class="text-fg text-[15px] font-medium tracking-tight">Mapbox style spec compatibility</h2>
      <p class="mt-2 text-fg-dim text-[12px]">
        Goal: 100% of the style spec round-trips. Current state below is what the
        converter <em>knows about</em> — anything else lands in the conversion
        notes block when present.
      </p>
      <div class="mt-4 grid grid-cols-1 md:grid-cols-3 gap-4 text-[12px]">
        <div class="border border-line rounded-md p-3 bg-bg-elev">
          <div class="text-emerald-300 text-[11px] uppercase tracking-wider mb-2">Supported</div>
          <ul class="text-fg-dim space-y-1">
            <li>• Sources: vector (PMTiles + TileJSON), raster, GeoJSON</li>
            <li>• Layers: background, fill, line, fill-extrusion</li>
            <li>• Paint: fill-color/-opacity, line-color/-width/-dasharray/-opacity, fill-extrusion-color/-opacity/-height/-base</li>
            <li>• Filters: legacy + expression form (==/!=/&lt;/&gt;/all/any/in/!in/has/!has)</li>
            <li>• Expressions: get / coalesce / case / match / arithmetic / min / max / to-number</li>
            <li>• Zoom: <code>interpolate(zoom, …)</code> with linear curve</li>
          </ul>
        </div>
        <div class="border border-line rounded-md p-3 bg-bg-elev">
          <div class="text-amber-300 text-[11px] uppercase tracking-wider mb-2">Lossy / heuristic</div>
          <ul class="text-fg-dim space-y-1">
            <li>• <code>interpolate</code> curve type (exponential / cubic-bezier) folded to linear</li>
            <li>• <code>fill-translate</code>, <code>line-translate</code> dropped</li>
            <li>• <code>fill-outline-color</code> emitted as a separate stroke layer when paired</li>
            <li>• <code>$type</code> / <code>$id</code> filters dropped (geometry type implied by utility)</li>
            <li>• Symbol-style <code>fill-pattern</code> / <code>line-pattern</code> dropped (bitmap atlases unimplemented)</li>
          </ul>
        </div>
        <div class="border border-line rounded-md p-3 bg-bg-elev">
          <div class="text-rose-300 text-[11px] uppercase tracking-wider mb-2">Unsupported (engine)</div>
          <ul class="text-fg-dim space-y-1">
            <li>• Symbol layers (text + icons) — SDF font + glyph atlas pending</li>
            <li>• Circle, heatmap, hillshade, sky layers</li>
            <li>• <code>let</code> / <code>var</code> bindings, <code>concat</code>, <code>downcase</code>, <code>number-format</code></li>
            <li>• <code>step</code> expressions, <code>at</code>, <code>distance</code>, <code>distance-from-center</code></li>
            <li>• Top-level <code>light</code>, <code>fog</code>, <code>terrain</code></li>
            <li>• Paint property <code>transition</code> overrides</li>
          </ul>
        </div>
      </div>
    </section>
  </main>
  <Footer />

  <script>
    // Note: this is a regular Astro <script> (not `define:vars` and not
    // `is:inline`) so Astro routes it through Vite as a real ES module.
    // That's required for `import('@xgis/compiler')` (workspace package)
    // to resolve in the browser. `define:vars` wraps the body in an
    // IIFE and emits a non-module script — neither top-level await nor
    // dynamic-imports of bare specifiers work in that mode.
    import { convertMapboxStyle } from '@xgis/compiler'

    const $url = document.getElementById('mapbox-url') as HTMLInputElement
    const $json = document.getElementById('mapbox-json') as HTMLTextAreaElement
    const $out = document.getElementById('xgis-out') as HTMLTextAreaElement
    const $status = document.getElementById('status') as HTMLParagraphElement
    const $fetch = document.getElementById('fetch-btn') as HTMLButtonElement
    const $convert = document.getElementById('convert-btn') as HTMLButtonElement
    const $copy = document.getElementById('copy-btn') as HTMLButtonElement
    const $open = document.getElementById('open-btn') as HTMLButtonElement
    const $showPaste = document.getElementById('show-paste') as HTMLButtonElement
    const $pasteSection = document.getElementById('paste-section') as HTMLElement
    const $warnBadge = document.getElementById('warn-badge') as HTMLElement
    const $notesPanel = document.getElementById('notes-panel') as HTMLDetailsElement
    const $notesList = document.getElementById('notes-list') as HTMLUListElement
    const playgroundUrl =
      ($out.closest('[data-playground-url]') as HTMLElement | null)?.dataset.playgroundUrl ?? ''

    let lastImportLabel = 'Imported'
    let lastFetchedUrl = ''  // URL of last successful fetch (for import shortcut)

    const $importShortcut = document.getElementById('import-shortcut') as HTMLElement
    const $importSnippet = document.getElementById('import-snippet') as HTMLPreElement
    const $copyImport = document.getElementById('copy-import-btn') as HTMLButtonElement
    const $openImport = document.getElementById('open-import-btn') as HTMLButtonElement

    function setStatus(msg: string, kind?: 'ok' | 'err') {
      $status.textContent = msg
      $status.style.color = kind === 'err' ? '#f87171'
                          : kind === 'ok'  ? '#86efac'
                          : ''
    }

    function showWarnings(xgis: string) {
      // Warnings are emitted as `*   • <message>` inside a trailing
      // `/* Conversion notes (review before running): … */` block.
      // Surface them in a hidden-by-default <details> next to the
      // output so the user knows what got dropped without the noise
      // crowding the source itself.
      const matches = [...xgis.matchAll(/^\s*\*\s+•\s+(.+)$/gm)].map(m => m[1].trim())
      if (matches.length === 0) {
        $warnBadge.classList.add('hidden')
        $notesPanel.classList.add('hidden')
        $notesList.innerHTML = ''
        return
      }
      $warnBadge.textContent = `${matches.length} note${matches.length > 1 ? 's' : ''}`
      $warnBadge.classList.remove('hidden')
      $notesPanel.classList.remove('hidden')
      // De-duplicate so 80× "geometry-type dropped" collapses to one line.
      const counts = new Map<string, number>()
      for (const m of matches) counts.set(m, (counts.get(m) ?? 0) + 1)
      $notesList.innerHTML = ''
      for (const [msg, n] of [...counts.entries()].sort((a, b) => b[1] - a[1])) {
        const li = document.createElement('li')
        li.textContent = (n > 1 ? `${n}× ` : '') + msg
        $notesList.appendChild(li)
      }
    }

    function convertJsonString(jsonStr: string, label?: string) {
      try {
        const parsed = JSON.parse(jsonStr)
        const xgis = convertMapboxStyle(parsed)
        $out.value = xgis
        if (label) lastImportLabel = label
        showWarnings(xgis)
        const noteCount = (xgis.match(/^\s*\*\s+•/gm) || []).length
        setStatus(noteCount > 0
          ? 'Converted — see ' + noteCount + ' note' + (noteCount > 1 ? 's' : '') + '.'
          : 'Converted.', 'ok')
      } catch (e: any) {
        setStatus('Conversion failed: ' + (e?.message || e), 'err')
      }
    }

    async function fetchAndConvert(url: string, label?: string) {
      setStatus('Fetching ' + url + ' …')
      try {
        const resp = await fetch(url)
        if (!resp.ok) throw new Error('HTTP ' + resp.status)
        const txt = await resp.text()
        $json.value = txt
        convertJsonString(txt, label)
        // Show the splice-form import shortcut — `import "<url>"` is
        // a one-line equivalent that the runtime resolves on load.
        // Only valid for the URL flow (paste form has no source URL).
        lastFetchedUrl = url
        $importSnippet.textContent = `import "${url}"`
        $importShortcut.classList.remove('hidden')
      } catch (e: any) {
        setStatus(
          'Fetch failed: ' + (e?.message || e) +
          ' — likely a CORS block. Paste the JSON manually instead.',
          'err',
        )
        $pasteSection.classList.remove('hidden')
      }
    }

    // ── Wire up ──
    document.querySelectorAll<HTMLButtonElement>('.preset-chip').forEach(btn => {
      btn.addEventListener('click', () => {
        const url = btn.dataset.presetUrl ?? ''
        const name = btn.dataset.presetName ?? 'Preset'
        $url.value = url
        fetchAndConvert(url, name)
      })
    })

    $convert.addEventListener('click', () => {
      const txt = $json.value.trim()
      if (!txt) { setStatus('Paste a Mapbox style JSON first.', 'err'); return }
      convertJsonString(txt)
    })

    $fetch.addEventListener('click', () => {
      const url = $url.value.trim()
      if (!url) { setStatus('Enter a URL first.', 'err'); return }
      fetchAndConvert(url)
    })

    $showPaste.addEventListener('click', () => {
      $pasteSection.classList.remove('hidden')
      $json.focus()
    })

    $warnBadge.addEventListener('click', () => {
      $notesPanel.open = !$notesPanel.open
    })

    $copy.addEventListener('click', async () => {
      if (!$out.value) { setStatus('Nothing to copy yet.', 'err'); return }
      try {
        await navigator.clipboard.writeText($out.value)
        setStatus('Copied to clipboard.', 'ok')
      } catch {
        $out.select(); document.execCommand('copy')
        setStatus('Copied (fallback).', 'ok')
      }
    })

    /** Hand the converted xgis to the playground.
     *
     *  Production: site + playground share an origin
     *  (x-gis.github.io/X-GIS/play/...). sessionStorage seeds work
     *  same-origin and the demo runner reads it back.
     *
     *  Dev: site (localhost:4323 HTTP) and playground (localhost:3000
     *  HTTPS) are different origins, sessionStorage doesn't cross.
     *  Encode the source into the URL hash — modern browsers handle
     *  multi-MB hash payloads, and the hash never reaches the server.
     *  The demo runner detects `#src=...` and decodes ahead of its
     *  sessionStorage fallback. */
    async function openInPlayground(source: string, label: string): Promise<void> {
      // Vite/Astro inline DEV at build — falls back to false in prod
      // bundles so the dev branch tree-shakes out.
      // eslint-disable-next-line @typescript-eslint/no-explicit-any
      const isDev = !!(import.meta as any).env?.DEV
      if (isDev) {
        // Probe the playground dev server before navigating —
        // a 404/500/timeout up front beats a confusing dead tab. We
        // hit /@vite/client (always served by Vite when running)
        // with a no-cors fetch; failure means server isn't up.
        let playgroundRunning = false
        try {
          const probe = await fetch('https://localhost:3000/@vite/client', {
            mode: 'no-cors', cache: 'no-store',
          })
          playgroundRunning = probe.ok || probe.type === 'opaque'
        } catch {
          playgroundRunning = false
        }
        if (!playgroundRunning) {
          setStatus(
            'Playground dev server not running on https://localhost:3000. ' +
            'Start it with `bun run dev` in playground/ (or `bun run dev:all` ' +
            'from the repo root to start both servers).',
            'err',
          )
          return
        }
        const encoded = btoa(unescape(encodeURIComponent(source)))
        const labelParam = encodeURIComponent(label)
        window.location.href =
          `https://localhost:3000/demo.html?id=__import&label=${labelParam}#src=${encoded}`
        return
      }
      try {
        sessionStorage.setItem('__xgisImportSource', source)
        sessionStorage.setItem('__xgisImportLabel', label)
      } catch { /* sessionStorage may be unavailable in some embeds */ }
      window.location.href = playgroundUrl + '?id=__import'
    }

    $open.addEventListener('click', () => {
      if (!$out.value) { setStatus('Convert first, then open.', 'err'); return }
      void openInPlayground($out.value, lastImportLabel)
    })

    $copyImport.addEventListener('click', async () => {
      const snip = $importSnippet.textContent ?? ''
      if (!snip) return
      try {
        await navigator.clipboard.writeText(snip)
        setStatus('Import line copied.', 'ok')
      } catch {
        setStatus('Copy failed (clipboard API unavailable).', 'err')
      }
    })

    $openImport.addEventListener('click', () => {
      if (!lastFetchedUrl) return
      // The playground compiles whatever the openInPlayground helper
      // hands off — same channel the converted-output button uses,
      // but seeded with the one-line splice form. The runtime then
      // runs the same fetch + convert path on load. Goes through the
      // same dev / prod dispatch as the converted-source button.
      const oneLiner = `import "${lastFetchedUrl}"\n`
      void openInPlayground(oneLiner, lastImportLabel + ' (import)')
    })

    $json.addEventListener('keydown', (e) => {
      if ((e.ctrlKey || e.metaKey) && e.key === 'Enter') {
        e.preventDefault()
        $convert.click()
      }
    })
    $url.addEventListener('keydown', (e) => {
      if (e.key === 'Enter') { e.preventDefault(); $fetch.click() }
    })
  </script>
</Base>
