---
import Base from '../layouts/Base.astro'
import Header from '../components/Header.astro'
import Footer from '../components/Footer.astro'
import { galleryCategories, featuredDemos, runIdOf } from '../content/gallery-demos'

const githubUrl = 'https://github.com/X-GIS/X-GIS'
const examplesPath = `${githubUrl}/blob/main/playground/src/examples`
// Deployed playground lives under /play/ inside the same GH Pages
// artifact (see .github/workflows/deploy-pages.yml). Cards deep-link
// to /play/demo.html?id=<name> so a click loads the running demo
// directly. BASE_URL handles the production /X-GIS/ prefix.
//
// In `astro dev` the playground isn't merged, so the cards target
// the playground's own dev server at https://localhost:3000/demo.html
// (started independently with `bun run dev` from the playground
// workspace). The user accepts the cert warning once and from there
// on dev clicks just work.
const base = import.meta.env.BASE_URL.replace(/\/+$/, '')
const playPath = import.meta.env.DEV
  ? 'https://localhost:3000/demo.html'
  : `${base}/play/demo.html`
// Thumbnails captured by playground/e2e/_capture-thumbnails.spec.ts
// land in site/public/thumbnails/<runId>.jpg, served by Astro under
// `${base}/thumbnails/<runId>.jpg`.
const thumbBase = `${base}/thumbnails`
---

<Base
  title="X-GIS — Examples"
  description="Working .xgis examples organized by topic — basics, PMTiles, vector tiles, data-driven styling, lines, symbols, animation, interaction, raster, and more."
>
  <Header />

  <main class="pt-24 pb-32">

    <!-- Page header -->
    <section class="max-w-[820px] mx-auto px-6 mb-16">
      <p class="text-[13px] font-medium tracking-[-0.01em] text-accent mb-4">
        Examples
      </p>
      <h1 class="font-medium text-fg leading-[1.05] tracking-[-0.035em]
                 text-[40px] sm:text-[56px] lg:text-[64px]">
        Real <code class="font-mono text-fg">.xgis</code> samples.
      </h1>
      <p class="mt-6 text-[17px] sm:text-[18px] leading-[1.55] text-fg-dim">
        Click any card to launch the running demo — pan, zoom, rotate, and inspect.
        Each card also carries a <span class="font-mono text-[14px] text-fg">&lt;&gt;</span> link to the
        underlying <code class="font-mono text-[14px] text-fg">.xgis</code> source on GitHub for copy-paste.
      </p>
    </section>

    <!-- Featured starter — three big cards for the most representative
         entry points. Helps a first-time visitor pick a path without
         scanning the full ~50-card gallery. -->
    <section class="max-w-[1100px] mx-auto px-6 mb-20">
      <p class="text-[12px] font-mono uppercase tracking-wider text-fg-mute mb-4">
        Start here
      </p>
      <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-4">
        {featuredDemos.map(d => (
          <a
            href={`${playPath}?id=${runIdOf(d)}`}
            class="demo-card group block rounded-2xl bg-bg-card border border-line
                   hover:border-line-strong overflow-hidden"
          >
            <div class="aspect-[16/9] bg-bg-elev relative overflow-hidden">
              <img
                src={`${thumbBase}/${runIdOf(d)}.jpg`}
                alt=""
                width="1200"
                height="675"
                loading="lazy"
                class="w-full h-full object-cover"
              />
              <span class="absolute top-3 left-3 inline-flex items-center gap-1 px-1.5 py-0.5 rounded
                           bg-bg/85 backdrop-blur text-accent text-[10px] font-medium tracking-wide uppercase">
                <span class="w-1.5 h-1.5 rounded-full bg-accent inline-block animate-pulse"></span>
                Live
              </span>
            </div>
            <div class="p-5">
              <p class="font-mono text-[11px] text-fg-mute mb-2 truncate">
                {d.id}.xgis
              </p>
              <h3 class="text-[20px] font-medium text-fg leading-[1.25] tracking-[-0.015em] mb-2">
                {d.title}
              </h3>
              <p class="text-[14px] leading-[1.55] text-fg-dim">
                {d.body}
              </p>
              <p class="mt-4 inline-flex items-center gap-1.5 text-[13px] font-medium text-accent group-hover:text-accent-hover transition-colors">
                Run demo
                <svg viewBox="0 0 24 24" width="12" height="12" fill="none" stroke="currentColor" stroke-width="2.4" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                  <path d="M9 6l6 6-6 6"/>
                </svg>
              </p>
            </div>
          </a>
        ))}
      </div>
    </section>

    <!-- Section divider -->
    <div class="max-w-[1100px] mx-auto px-6 mb-12">
      <p class="text-[12px] font-mono uppercase tracking-wider text-fg-mute">
        All examples
      </p>
    </div>

    <!-- Categories -->
    <div class="max-w-[1100px] mx-auto px-6 space-y-20">
      {galleryCategories.map(cat => (
        <section>
          <h2 class="text-[26px] sm:text-[30px] font-medium text-fg leading-[1.2] tracking-[-0.02em] mb-2">
            {cat.title}
          </h2>
          <p class="text-[15px] leading-[1.6] text-fg-dim mb-8 max-w-[680px]">
            {cat.body}
          </p>
          <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-4">
            {cat.demos.map(d => (
              <article
                class="demo-card group relative rounded-2xl bg-bg-card border border-line
                       hover:border-line-strong overflow-hidden"
              >
                <a
                  href={`${playPath}?id=${runIdOf(d)}`}
                  class="block"
                  aria-label={`Run ${d.title} demo`}
                >
                  {!d.noThumb && (
                    <div class="aspect-[16/9] bg-bg-elev relative overflow-hidden">
                      <img
                        src={`${thumbBase}/${runIdOf(d)}.jpg`}
                        alt=""
                        width="1200"
                        height="675"
                        loading="lazy"
                        class="w-full h-full object-cover"
                      />
                      <span class="absolute top-3 left-3 inline-flex items-center gap-1 px-1.5 py-0.5 rounded
                                   bg-bg/85 backdrop-blur text-accent text-[10px] font-medium tracking-wide uppercase">
                        <span class="w-1.5 h-1.5 rounded-full bg-accent inline-block animate-pulse"></span>
                        Live
                      </span>
                    </div>
                  )}
                  <div class="p-5 pr-12">
                    {d.noThumb && (
                      <div class="flex items-center gap-2 mb-2">
                        <span class="inline-flex items-center gap-1 px-1.5 py-0.5 rounded
                                     bg-accent/15 text-accent text-[10px] font-medium tracking-wide uppercase">
                          <span class="w-1.5 h-1.5 rounded-full bg-accent inline-block animate-pulse"></span>
                          Live
                        </span>
                      </div>
                    )}
                    <p class="font-mono text-[11px] text-fg-mute group-hover:text-fg-dim transition-colors truncate mb-2">
                      {d.id}.xgis
                    </p>
                    <h3 class="text-[16px] font-medium text-fg leading-[1.3] tracking-[-0.01em] mb-2">
                      {d.title}
                    </h3>
                    <p class="text-[13px] leading-[1.5] text-fg-dim">
                      {d.body}
                    </p>
                  </div>
                </a>
                <a
                  href={`${examplesPath}/${d.id}.xgis`}
                  target="_blank"
                  rel="noopener"
                  aria-label={`View ${d.id}.xgis source on GitHub`}
                  class="absolute bottom-4 right-4 inline-flex items-center justify-center
                         w-8 h-8 rounded-md text-fg-mute hover:text-fg hover:bg-line
                         transition-colors"
                  title="View source on GitHub"
                >
                  <svg viewBox="0 0 24 24" width="14" height="14" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                    <polyline points="16 18 22 12 16 6" />
                    <polyline points="8 6 2 12 8 18" />
                  </svg>
                </a>
              </article>
            ))}
          </div>
        </section>
      ))}
    </div>

    <!-- Footer pointer -->
    <section class="max-w-[820px] mx-auto px-6 mt-24 pt-12 border-t border-line">
      <p class="text-[14px] leading-[1.6] text-fg-dim">
        The
        <a href={`${examplesPath}`} target="_blank" rel="noopener" class="text-accent hover:text-accent-hover transition-colors">full examples directory</a>
        carries another ~60 fixture and reference-test files used by the e2e harness — useful for
        contributors digging into a specific renderer behavior, less so for learning the language.
      </p>
    </section>
  </main>

  <Footer />
</Base>

<style>
  /* Apple-signature card hover: combined transform + color easing,
   * slow quart-out curve. Color shifts (border, bg) get the same
   * timing as the lift so they read as one motion. */
  .demo-card {
    transition:
      transform 500ms cubic-bezier(0.16, 0.84, 0.32, 1),
      border-color 350ms cubic-bezier(0.16, 0.84, 0.32, 1),
      background-color 350ms cubic-bezier(0.16, 0.84, 0.32, 1);
  }
  .demo-card:hover {
    transform: translateY(-2px);
  }
  @media (prefers-reduced-motion: reduce) {
    .demo-card { transition: none; }
    .demo-card:hover { transform: none; }
  }
</style>
