---
import Base from './Base.astro'
import Header from '../components/Header.astro'
import Footer from '../components/Footer.astro'
import OnThisPage from '../components/OnThisPage.astro'

interface Heading {
  depth: number
  slug: string
  text: string
}

interface Props {
  title?: string
  description?: string
  /** The slug of the current page so the side-nav can highlight it.
   *  Pass the path segment after `/docs/` — e.g., `'reference'`,
   *  `'concepts/rtc'`, `'api'`, `''` for the overview page. */
  current: string
  /** Optional headings list — caller passes `Astro.self.props.headings`
   *  or builds it manually for non-MD pages. When present the
   *  right-side On-this-page TOC renders. */
  headings?: Heading[]
}

const { title, description, current, headings = [] } = Astro.props
const githubBase = 'https://github.com/X-GIS/X-GIS/edit/main/site/src/pages/docs'
const editPath = current === ''
  ? `${githubBase}/index.astro`
  : `${githubBase}/${current}.astro`

const base = import.meta.env.BASE_URL.replace(/\/+$/, '')

interface NavItem {
  label: string
  slug: string
  href: string
}
interface NavGroup {
  title?: string
  items: NavItem[]
}

// Diátaxis layout: Get started → Guides → Reference → Concepts → API.
// Tutorials (quickstart) come first because they're learning-oriented;
// Guides (cookbook, mapbox migration) are goal-oriented; Reference is
// the dry information sink; Concepts explain the WHY; API is the JS-
// surface for embedding.
const navGroups: NavGroup[] = [
  {
    items: [
      { label: 'Overview',           slug: '',                    href: `${base}/docs` },
    ],
  },
  {
    title: 'Get started',
    items: [
      { label: 'Quickstart',         slug: 'quickstart',  href: `${base}/docs/quickstart` },
    ],
  },
  {
    title: 'Guides',
    items: [
      { label: 'Cookbook',           slug: 'cookbook',    href: `${base}/docs/cookbook` },
      { label: 'Mapbox migration',   slug: 'mapbox',      href: `${base}/docs/mapbox` },
    ],
  },
  {
    title: 'Language',
    items: [
      { label: 'Reference',          slug: 'reference',   href: `${base}/docs/reference` },
      { label: 'Sources',            slug: 'sources',     href: `${base}/docs/sources` },
      { label: 'Functions',          slug: 'functions',   href: `${base}/docs/functions` },
      { label: 'Expressions',        slug: 'expressions', href: `${base}/docs/expressions` },
      { label: 'Utility catalog',    slug: 'utilities',   href: `${base}/docs/utilities` },
    ],
  },
  {
    title: 'Concepts',
    items: [
      { label: 'RTC + DSFUN precision',  slug: 'concepts/rtc',         href: `${base}/docs/concepts/rtc` },
      { label: 'Projections',            slug: 'concepts/projections', href: `${base}/docs/concepts/projections` },
      { label: 'Compile pipeline',       slug: 'concepts/pipeline',    href: `${base}/docs/concepts/pipeline` },
    ],
  },
  {
    title: 'API',
    items: [
      { label: 'JavaScript API',  slug: 'api', href: `${base}/docs/api` },
    ],
  },
]
---

<Base title={title ?? 'X-GIS — Documentation'} description={description}>
  <Header />

  <main class="pt-20 pb-32">
    <div class={`max-w-[1280px] mx-auto px-6 grid gap-x-12 ${headings.length > 0 ? 'lg:grid-cols-[220px_minmax(0,1fr)] xl:grid-cols-[220px_minmax(0,1fr)_200px]' : 'lg:grid-cols-[220px_minmax(0,1fr)]'}`}>

      <!-- Side-nav (desktop). On mobile this collapses to a horizontal
           scroll-strip just below the header so the user can still
           jump between pages without a hamburger. -->
      <aside class="hidden lg:block">
        <nav class="sticky top-20 text-[13px] leading-[1.7]">
          {navGroups.map(group => (
            <div class="mb-7">
              {group.title && (
                <p class="text-[11px] font-medium text-fg-mute uppercase tracking-wider mb-3">
                  {group.title}
                </p>
              )}
              <ul class="space-y-1.5">
                {group.items.map(item => {
                  const active = item.slug === current
                  return (
                    <li>
                      <a
                        href={item.href}
                        class={`block transition-colors ${active ? 'text-accent font-medium' : 'text-fg-dim hover:text-fg'}`}
                        aria-current={active ? 'page' : undefined}
                      >
                        {item.label}
                      </a>
                    </li>
                  )
                })}
              </ul>
            </div>
          ))}
        </nav>
      </aside>

      <!-- Mobile docs breadcrumb: shows where you are. Cross-page
           navigation lives in the global mobile drawer (hamburger from
           the header), so duplicating an 8-item scroll-strip here was
           wasted vertical space and a competing tap target. The
           breadcrumb keeps the user oriented without consuming a
           sticky ~44 px row. -->
      {(() => {
        // Flatten nav items with their group title so the breadcrumb
        // can render "Docs · Concepts · RTC + DSFUN precision".
        const flat = navGroups.flatMap(g =>
          g.items.map(it => ({ ...it, groupTitle: g.title }))
        )
        const currentItem = flat.find(it => it.slug === current)
        return (
          <nav class="lg:hidden mb-6 -mx-6 px-6 py-3 border-b border-line text-[12px] flex items-center gap-2 text-fg-mute overflow-x-auto whitespace-nowrap no-scrollbar">
            <a href={`${base}/docs`} class="hover:text-fg transition-colors flex-shrink-0">Docs</a>
            {currentItem && currentItem.slug !== '' && (
              <>
                <svg viewBox="0 0 24 24" width="10" height="10" fill="none" stroke="currentColor" stroke-width="2.4" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true" class="flex-shrink-0">
                  <path d="M9 6l6 6-6 6"/>
                </svg>
                {currentItem.groupTitle && (
                  <>
                    <span class="flex-shrink-0">{currentItem.groupTitle}</span>
                    <svg viewBox="0 0 24 24" width="10" height="10" fill="none" stroke="currentColor" stroke-width="2.4" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true" class="flex-shrink-0">
                      <path d="M9 6l6 6-6 6"/>
                    </svg>
                  </>
                )}
                <span class="text-fg font-medium">{currentItem.label}</span>
              </>
            )}
          </nav>
        )
      })()}

      <!-- Page content -->
      <article class="min-w-0">
        <slot />

        {/* ── Page meta footer: prev/next + edit-on-GitHub ── */}
        {(() => {
          // Flatten sidebar order so prev/next follow the visible
          // reading sequence — same order the user sees on the left.
          const flat = navGroups.flatMap(g => g.items)
          const idx = flat.findIndex(i => i.slug === current)
          const prev = idx > 0 ? flat[idx - 1] : null
          const next = idx >= 0 && idx < flat.length - 1 ? flat[idx + 1] : null
          return (
            <div class="mt-16 pt-8 border-t border-line">
              {(prev || next) && (
                <div class={`grid gap-3 ${prev && next ? 'sm:grid-cols-2' : 'sm:grid-cols-1'}`}>
                  {prev && (
                    <a href={prev.href} class="docs-pagenav group block rounded-xl border border-line px-5 py-4 hover:border-line-strong hover:bg-bg-hover transition-colors text-left">
                      <p class="text-[11px] font-medium text-fg-mute uppercase tracking-wider mb-1.5 flex items-center gap-1.5">
                        <svg viewBox="0 0 24 24" width="11" height="11" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                          <path d="M15 6l-6 6 6 6"/>
                        </svg>
                        Previous
                      </p>
                      <p class="text-[15px] font-medium text-fg group-hover:text-accent transition-colors">{prev.label}</p>
                    </a>
                  )}
                  {next && (
                    <a href={next.href} class={`docs-pagenav group block rounded-xl border border-line px-5 py-4 hover:border-line-strong hover:bg-bg-hover transition-colors text-right ${!prev ? 'sm:col-start-2' : ''}`}>
                      <p class="text-[11px] font-medium text-fg-mute uppercase tracking-wider mb-1.5 flex items-center gap-1.5 justify-end">
                        Next
                        <svg viewBox="0 0 24 24" width="11" height="11" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                          <path d="M9 6l6 6-6 6"/>
                        </svg>
                      </p>
                      <p class="text-[15px] font-medium text-fg group-hover:text-accent transition-colors">{next.label}</p>
                    </a>
                  )}
                </div>
              )}
              <div class="mt-6 flex flex-wrap gap-x-5 gap-y-1 text-[12.5px] text-fg-mute">
                <a href={editPath} target="_blank" rel="noopener" class="hover:text-fg transition-colors inline-flex items-center gap-1.5">
                  <svg viewBox="0 0 24 24" width="12" height="12" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                    <path d="M12 20h9M16.5 3.5a2.121 2.121 0 0 1 3 3L7 19l-4 1 1-4 12.5-12.5z"/>
                  </svg>
                  Edit this page on GitHub
                </a>
                <a href="https://github.com/X-GIS/X-GIS/issues/new" target="_blank" rel="noopener" class="hover:text-fg transition-colors inline-flex items-center gap-1.5">
                  <svg viewBox="0 0 24 24" width="12" height="12" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                    <circle cx="12" cy="12" r="9"/>
                    <path d="M12 8v4M12 16h.01"/>
                  </svg>
                  Report an issue
                </a>
              </div>
            </div>
          )
        })()}
      </article>

      {/* On-this-page TOC (xl+ only — collapses on smaller screens) */}
      <OnThisPage headings={headings} />
    </div>
  </main>

  <Footer />
</Base>

<style>
  /* Hide the scroll bar on the mobile docs nav strip; the strip is
   * still scrollable, just visually clean. */
  .no-scrollbar { scrollbar-width: none; }
  .no-scrollbar::-webkit-scrollbar { display: none; }
</style>
