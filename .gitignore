node_modules/
dist/
*.xgb
# Bulk Natural Earth / xgvt data — large binary files generated by
# the tiler, not source-controlled. The `/*` form (rather than the
# directory form) lets the negation pattern below escape the
# ignore for individual fixture files.
playground/public/data/*
# Fixture data IS checked in — tiny GeoJSON files (<1KB each)
# used by playground/e2e/fixtures.spec.ts. They must travel with
# the tests, unlike the bulk data above.
!playground/public/data/fixture-*.geojson

# Natural Earth 110m countries (~700 KB) — referenced by 19+ demo
# .xgis files (filter-gdp, continent-match, layered-borders, etc.).
# Without this, those demos 404 silently. Small enough to ship
# alongside the tracked xgvt fixtures.
!playground/public/data/ne_110m_countries.geojson

# Natural Earth 110m physical layers (~780 KB total). Same rationale:
# lots of demos use `ne_110m_{ocean,land,coastline,rivers,lakes}.geojson`
# directly; 404 leaves iOS showing the opaque "string did not match
# the expected pattern" (response.json() on an HTML error page).
!playground/public/data/ne_110m_ocean.geojson
!playground/public/data/ne_110m_land.geojson
!playground/public/data/ne_110m_coastline.geojson
!playground/public/data/ne_110m_rivers.geojson
!playground/public/data/ne_110m_lakes.geojson
!playground/public/data/ne_110m_populated_places.geojson

# Playwright e2e artifacts
playground/test-results/
playground/playwright-report/
playground/.playwright/

# Build artifacts in source dirs
**/*.js.map
compiler/src/**/*.d.ts
runtime/src/**/*.d.ts
runtime/src/**/*.js
!compiler/src/tiler/earcut.d.ts
*.tsbuildinfo
nul
